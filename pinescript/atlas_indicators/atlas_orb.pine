//@version=6
indicator(
     title           = "ORB [atlasliquidity]",
     overlay         = true,
     max_lines_count = 20
)

// ============================================================================
// AUTO-DETECT ASSET from chart symbol
// ============================================================================
asset = if syminfo.root == "ES" or syminfo.root == "MES"
    "ES"
else if syminfo.root == "NQ" or syminfo.root == "MNQ"
    "NQ"
else if syminfo.root == "GC" or syminfo.root == "MGC"
    "GC"
else
    "ES"

// ============================================================================
// INPUTS - Display
// ============================================================================
lineWidth = input.int(2, "Line Width", minval=1, maxval=5, group="Display")

// ============================================================================
// INPUTS - ES: Asia
// ============================================================================
i_esAsiaOrbSession = input.session("2000-2015", "ORB Window (ny time)", group="ES: Asia")
esAsiaOrbHighColor = input.color(#2196F3, "ORB High Color", group="ES: Asia")
esAsiaOrbLowColor  = input.color(#A5DFFA, "ORB Low Color", group="ES: Asia")

// ============================================================================
// INPUTS - ES: NY
// ============================================================================
i_esNyOrbSession = input.session("0930-0945", "ORB Window (ny time)", group="ES: NY")
esNyOrbHighColor = input.color(#2196F3, "ORB High Color", group="ES: NY")
esNyOrbLowColor  = input.color(#A5DFFA, "ORB Low Color", group="ES: NY")

// ============================================================================
// INPUTS - NQ: Asia
// ============================================================================
i_nqAsiaOrbSession = input.session("2000-2015", "ORB Window (ny time)", group="NQ: Asia")
nqAsiaOrbHighColor = input.color(#2196F3, "ORB High Color", group="NQ: Asia")
nqAsiaOrbLowColor  = input.color(#A5DFFA, "ORB Low Color", group="NQ: Asia")

// ============================================================================
// INPUTS - NQ: NY
// ============================================================================
i_nqNyOrbSession = input.session("0930-0945", "ORB Window (ny time)", group="NQ: NY")
nqNyOrbHighColor = input.color(#18b79c, "ORB High Color", group="NQ: NY")
nqNyOrbLowColor  = input.color(#94E3DA, "ORB Low Color", group="NQ: NY")

// ============================================================================
// INPUTS - GC: NY
// ============================================================================
i_gcOrbSession = input.session("0930-0938", "ORB Window (ny time)", group="GC: NY")
gcOrbHighColor = input.color(#18b79c, "ORB High Color", group="GC: NY")
gcOrbLowColor  = input.color(#94E3DA, "ORB Low Color", group="GC: NY")

// ============================================================================
// RESOLVE ACTIVE CONFIG
// ============================================================================
enableNY   = asset == "ES" or asset == "NQ" or asset == "GC"
enableAsia = asset == "NQ" or asset == "ES"

nySessionRTH   = "0930-1600"
asiaSessionRTH = "1800-0700"

nyOrbSession = if asset == "ES"
    i_esNyOrbSession
else if asset == "NQ"
    i_nqNyOrbSession
else if asset == "GC"
    i_gcOrbSession
else
    i_esNyOrbSession

asiaOrbSession = if asset == "ES"
    i_esAsiaOrbSession
else if asset == "NQ"
    i_nqAsiaOrbSession
else
    i_esAsiaOrbSession

nyOrbHighColor = if asset == "ES"
    esNyOrbHighColor
else if asset == "NQ"
    nqNyOrbHighColor
else if asset == "GC"
    gcOrbHighColor
else
    esNyOrbHighColor

nyOrbLowColor = if asset == "ES"
    esNyOrbLowColor
else if asset == "NQ"
    nqNyOrbLowColor
else if asset == "GC"
    gcOrbLowColor
else
    esNyOrbLowColor

asiaOrbHighColor = if asset == "ES"
    esAsiaOrbHighColor
else if asset == "NQ"
    nqAsiaOrbHighColor
else
    esAsiaOrbHighColor

asiaOrbLowColor = if asset == "ES"
    esAsiaOrbLowColor
else if asset == "NQ"
    nqAsiaOrbLowColor
else
    esAsiaOrbLowColor

// ============================================================================
// SESSION FILTERS - use 5m so ORB windows align across chart timeframes
// ============================================================================
tz = "America/New_York"

inNyRTH   = not na(time("5", nySessionRTH, tz))
inNyORB   = not na(time("5", nyOrbSession, tz))
inAsiaRTH = not na(time("5", asiaSessionRTH, tz))
inAsiaORB = not na(time("5", asiaOrbSession, tz))

nyRTHStart   = inNyRTH and not inNyRTH[1]
asiaRTHStart = inAsiaRTH and not inAsiaRTH[1]

// Build ORB from 5m bars so the range is consistent on lower/higher chart TFs.
regTicker = ticker.new(syminfo.prefix, syminfo.ticker, session.regular)
[orbH5, orbL5, orbT5] = request.security(regTicker, "5", [high, low, time], lookahead=barmerge.lookahead_on)
orbBarClosed5 = ta.change(orbT5) != 0

// ============================================================================
// NY ORB STATE
// ============================================================================
var float ny_orbHigh = na
var float ny_orbLow  = na
var int   ny_orbStartTime = na
var line  ny_orbHighLine = na
var line  ny_orbLowLine  = na

// ============================================================================
// ASIA ORB STATE
// ============================================================================
var float asia_orbHigh = na
var float asia_orbLow  = na
var int   asia_orbStartTime = na
var line  asia_orbHighLine = na
var line  asia_orbLowLine  = na

// ============================================================================
// RESET TO CURRENT SESSION ONLY
// ============================================================================
if enableNY and nyRTHStart
    if not na(ny_orbHighLine)
        line.delete(ny_orbHighLine)
    if not na(ny_orbLowLine)
        line.delete(ny_orbLowLine)
    if not na(asia_orbHighLine)
        line.delete(asia_orbHighLine)
    if not na(asia_orbLowLine)
        line.delete(asia_orbLowLine)
    ny_orbHigh := na
    ny_orbLow := na
    ny_orbStartTime := na
    ny_orbHighLine := na
    ny_orbLowLine := na
    asia_orbHighLine := na
    asia_orbLowLine := na

if enableAsia and asiaRTHStart
    if not na(asia_orbHighLine)
        line.delete(asia_orbHighLine)
    if not na(asia_orbLowLine)
        line.delete(asia_orbLowLine)
    if not na(ny_orbHighLine)
        line.delete(ny_orbHighLine)
    if not na(ny_orbLowLine)
        line.delete(ny_orbLowLine)
    asia_orbHigh := na
    asia_orbLow := na
    asia_orbStartTime := na
    asia_orbHighLine := na
    asia_orbLowLine := na
    ny_orbHighLine := na
    ny_orbLowLine := na

// ============================================================================
// BUILD ORB RANGES
// ============================================================================
if enableNY and orbBarClosed5 and inNyORB and inNyRTH
    ny_orbStartTime := na(ny_orbStartTime) ? orbT5 : ny_orbStartTime
    ny_orbHigh := na(ny_orbHigh) ? orbH5 : math.max(ny_orbHigh, orbH5)
    ny_orbLow := na(ny_orbLow) ? orbL5 : math.min(ny_orbLow, orbL5)

if enableAsia and orbBarClosed5 and inAsiaORB and inAsiaRTH
    asia_orbStartTime := na(asia_orbStartTime) ? orbT5 : asia_orbStartTime
    asia_orbHigh := na(asia_orbHigh) ? orbH5 : math.max(asia_orbHigh, orbH5)
    asia_orbLow := na(asia_orbLow) ? orbL5 : math.min(asia_orbLow, orbL5)

// ============================================================================
// VISUALS - ORB HIGH/LOW ONLY
// ============================================================================
nyShowOrb = enableNY and inNyRTH and not na(ny_orbHigh) and not na(ny_orbLow)
if nyShowOrb
    if na(ny_orbHighLine)
        ny_orbHighLine := line.new(ny_orbStartTime, ny_orbHigh, time, ny_orbHigh, xloc=xloc.bar_time, color=nyOrbHighColor, width=lineWidth)
        ny_orbLowLine := line.new(ny_orbStartTime, ny_orbLow, time, ny_orbLow, xloc=xloc.bar_time, color=nyOrbLowColor, width=lineWidth)
    else
        line.set_y1(ny_orbHighLine, ny_orbHigh)
        line.set_y2(ny_orbHighLine, ny_orbHigh)
        line.set_x2(ny_orbHighLine, time)
        line.set_y1(ny_orbLowLine, ny_orbLow)
        line.set_y2(ny_orbLowLine, ny_orbLow)
        line.set_x2(ny_orbLowLine, time)

asiaShowOrb = enableAsia and inAsiaRTH and not na(asia_orbHigh) and not na(asia_orbLow)
if asiaShowOrb
    if na(asia_orbHighLine)
        asia_orbHighLine := line.new(asia_orbStartTime, asia_orbHigh, time, asia_orbHigh, xloc=xloc.bar_time, color=asiaOrbHighColor, width=lineWidth)
        asia_orbLowLine := line.new(asia_orbStartTime, asia_orbLow, time, asia_orbLow, xloc=xloc.bar_time, color=asiaOrbLowColor, width=lineWidth)
    else
        line.set_y1(asia_orbHighLine, asia_orbHigh)
        line.set_y2(asia_orbHighLine, asia_orbHigh)
        line.set_x2(asia_orbHighLine, time)
        line.set_y1(asia_orbLowLine, asia_orbLow)
        line.set_y2(asia_orbLowLine, asia_orbLow)
        line.set_x2(asia_orbLowLine, time)
