var float ldnOrb_longTp2   = na

var float ldnOrb_shortEntry = na
var float ldnOrb_shortStop  = na
var float ldnOrb_shortTp1   = na
var float ldnOrb_shortTp2   = na

// ============================================================================
// DRAWING REFERENCES (draw once, update to extend)
// ============================================================================
// NY ORB lines
var line ny_orbHighLine = na
var line ny_orbLowLine  = na
var int  ny_orbLineStart = na

// Asia ORB lines
var line asia_orbHighLine = na
var line asia_orbLowLine  = na
var int  asia_orbLineStart = na

// FVG boxes + labels (draw once, extend right edge)
var box   ny_longFvgBox      = na
var box   ny_shortFvgBox     = na
var box   asia_longFvgBox    = na
var box   asia_shortFvgBox   = na
var label ny_longFvgLabel    = na
var label ny_shortFvgLabel   = na
var label asia_longFvgLabel  = na
var label asia_shortFvgLabel = na

// Track whether ORB lines have been created this session
var bool ny_orbLinesDrawn   = false
var bool asia_orbLinesDrawn = false

// ============================================================================
// TRADE LEVEL STATE - NY
// ============================================================================
var float ny_longEntry = na
var float ny_longStop  = na
var float ny_longTp1   = na
var float ny_longTp2   = na

var float ny_shortEntry = na
var float ny_shortStop  = na
var float ny_shortTp1   = na
var float ny_shortTp2   = na

// ============================================================================
// TRADE LEVEL STATE - Asia
// ============================================================================
var float asia_longEntry = na
var float asia_longStop  = na
var float asia_longTp1   = na
var float asia_longTp2   = na

var float asia_shortEntry = na
var float asia_shortStop  = na
var float asia_shortTp1   = na
var float asia_shortTp2   = na

// ============================================================================
// TRADE LEVEL LINE/LABEL REFS
// ============================================================================
var line ny_longEntryLine = na
var line ny_longStopLine  = na
var line ny_longTp1Line   = na
var line ny_longTp2Line   = na
var label ny_longStopLbl  = na
var label ny_longTp1Lbl   = na
var label ny_longTp2Lbl   = na

var line ny_shortEntryLine = na
var line ny_shortStopLine  = na
var line ny_shortTp1Line   = na
var line ny_shortTp2Line   = na
var label ny_shortStopLbl  = na
var label ny_shortTp1Lbl   = na
var label ny_shortTp2Lbl   = na

var line asia_longEntryLine = na
var line asia_longStopLine  = na
var line asia_longTp1Line   = na
var line asia_longTp2Line   = na
var label asia_longStopLbl  = na
var label asia_longTp1Lbl   = na
var label asia_longTp2Lbl   = na

var line asia_shortEntryLine = na
var line asia_shortStopLine  = na
var line asia_shortTp1Line   = na
var line asia_shortTp2Line   = na
var label asia_shortStopLbl  = na
var label asia_shortTp1Lbl   = na
var label asia_shortTp2Lbl   = na

// LSI NY drawing refs
var line  lsiNy_entryLine = na
var line  lsiNy_stopLine  = na
var line  lsiNy_tp1Line   = na
var line  lsiNy_tp2Line   = na
var label lsiNy_stopLbl   = na
var label lsiNy_tp1Lbl    = na
var label lsiNy_tp2Lbl    = na

// LSI Asia drawing refs
var line  lsiAsia_entryLine = na
var line  lsiAsia_stopLine  = na
var line  lsiAsia_tp1Line   = na
var line  lsiAsia_tp2Line   = na
var label lsiAsia_stopLbl   = na
var label lsiAsia_tp1Lbl    = na
var label lsiAsia_tp2Lbl    = na

// LDN drawing refs
var line  ldn_entryLine = na
var line  ldn_stopLine  = na
var line  ldn_tp1Line   = na
var line  ldn_tp2Line   = na
var label ldn_stopLbl   = na
var label ldn_tp1Lbl    = na
var label ldn_tp2Lbl    = na

// LDN ORB drawing refs
var line ldnOrb_orbHighLine = na
var line ldnOrb_orbLowLine  = na
var int  ldnOrb_orbLineStart = na
var bool ldnOrb_orbLinesDrawn = false

var box   ldnOrb_longFvgBox      = na
var box   ldnOrb_shortFvgBox     = na
var label ldnOrb_longFvgLabel    = na
var label ldnOrb_shortFvgLabel   = na

var line ldnOrb_longEntryLine = na
var line ldnOrb_longStopLine  = na
var line ldnOrb_longTp1Line   = na
var line ldnOrb_longTp2Line   = na
var label ldnOrb_longStopLbl  = na
var label ldnOrb_longTp1Lbl   = na
var label ldnOrb_longTp2Lbl   = na

var line ldnOrb_shortEntryLine = na
var line ldnOrb_shortStopLine  = na
var line ldnOrb_shortTp1Line   = na
var line ldnOrb_shortTp2Line   = na
var label ldnOrb_shortStopLbl  = na
var label ldnOrb_shortTp1Lbl   = na
var label ldnOrb_shortTp2Lbl   = na

// ============================================================================
// RESET ON SESSION START (not calendar day - survives half days & holidays)
// ============================================================================
if nyRTHStart
    ny_orbHigh := na
    ny_orbLow  := na
    ny_orbReady := false
    ny_longFirstFvgFound := false
    ny_shortFirstFvgFound := false
    ny_longFvgTopStored := na
    ny_longFvgBotStored := na
    ny_longFvgStartTime := na
    ny_longFvgText      := na
    ny_shortFvgTopStored := na
    ny_shortFvgBotStored := na
    ny_shortFvgStartTime := na
    ny_shortFvgText      := na
    ny_orbLinesDrawn := false
    ny_orbHighLine := na
    ny_orbLowLine  := na
    ny_orbLineStart := na
    ny_longEntry := na
    ny_longStop  := na
    ny_longTp1   := na
    ny_longTp2   := na
    ny_shortEntry := na
    ny_shortStop  := na
    ny_shortTp1   := na
    ny_shortTp2   := na
    ny_longEntryLine := na
    ny_longStopLine  := na
    ny_longTp1Line   := na
    ny_longTp2Line   := na
    ny_longStopLbl   := na
    ny_longTp1Lbl    := na
    ny_longTp2Lbl    := na
    ny_shortEntryLine := na
    ny_shortStopLine  := na
    ny_shortTp1Line   := na
    ny_shortTp2Line   := na
    ny_shortStopLbl   := na
    ny_shortTp1Lbl    := na
    ny_shortTp2Lbl    := na
    ny_longFvgBox      := na
    ny_shortFvgBox     := na
    ny_longFvgLabel    := na
    ny_shortFvgLabel   := na

if asiaRTHStart
    asia_orbHigh := na
    asia_orbLow  := na
    asia_orbReady := false
    asia_longFirstFvgFound := false
    asia_shortFirstFvgFound := false
    asia_longFvgTopStored := na
    asia_longFvgBotStored := na
    asia_longFvgStartTime := na
    asia_longFvgText      := na
    asia_shortFvgTopStored := na
    asia_shortFvgBotStored := na
    asia_shortFvgStartTime := na
    asia_shortFvgText      := na
    asia_orbLinesDrawn := false
    asia_orbHighLine := na
    asia_orbLowLine  := na
    asia_orbLineStart := na
    asia_longEntry := na
    asia_longStop  := na
    asia_longTp1   := na
    asia_longTp2   := na
    asia_shortEntry := na
    asia_shortStop  := na
    asia_shortTp1   := na
    asia_shortTp2   := na
    asia_longEntryLine := na
    asia_longStopLine  := na
    asia_longTp1Line   := na
    asia_longTp2Line   := na
    asia_longStopLbl   := na
    asia_longTp1Lbl    := na
    asia_longTp2Lbl    := na
    asia_shortEntryLine := na
    asia_shortStopLine  := na
    asia_shortTp1Line   := na
    asia_shortTp2Line   := na
    asia_shortStopLbl   := na
    asia_shortTp1Lbl    := na
    asia_shortTp2Lbl    := na
    asia_longFvgBox    := na
    asia_shortFvgBox   := na
    asia_longFvgLabel  := na
    asia_shortFvgLabel := na

if lsiNyRTHStart
    array.clear(lsiNy_bearFvgs)
    array.clear(lsiNy_bullFvgs)
    lsiNy_armed := false
    lsiNy_dir   := 0
    lsiNy_entry := na
    lsiNy_stop  := na
    lsiNy_tp1   := na
    lsiNy_tp2   := na
    lsiNy_entryLine := na
    lsiNy_stopLine  := na
    lsiNy_tp1Line   := na
    lsiNy_tp2Line   := na
    lsiNy_stopLbl   := na
    lsiNy_tp1Lbl    := na
    lsiNy_tp2Lbl    := na

if lsiAsiaRTHStart
    array.clear(lsiAsia_bearFvgs)
    array.clear(lsiAsia_bullFvgs)
    lsiAsia_armed := false
    lsiAsia_dir   := 0
    lsiAsia_entry := na
    lsiAsia_stop  := na
    lsiAsia_tp1   := na
    lsiAsia_tp2   := na
    lsiAsia_entryLine := na
    lsiAsia_stopLine  := na
    lsiAsia_tp1Line   := na
    lsiAsia_tp2Line   := na
    lsiAsia_stopLbl   := na
    lsiAsia_tp1Lbl    := na
    lsiAsia_tp2Lbl    := na

if ldnRTHStart
    array.clear(ldn_bearFvgs)
    array.clear(ldn_bullFvgs)
    ldn_armed := false
    ldn_dir   := 0
    ldn_entry := na
    ldn_stop  := na
    ldn_tp1   := na
    ldn_tp2   := na
    ldn_entryLine := na
    ldn_stopLine  := na
    ldn_tp1Line   := na
    ldn_tp2Line   := na
    ldn_stopLbl   := na
    ldn_tp1Lbl    := na
    ldn_tp2Lbl    := na
    // LDN ORB reset (shares ldnRTHStart)
    ldnOrb_orbHigh := na
    ldnOrb_orbLow  := na
    ldnOrb_orbReady := false
    ldnOrb_longFirstFvgFound := false
    ldnOrb_shortFirstFvgFound := false
    ldnOrb_longFvgTopStored := na
    ldnOrb_longFvgBotStored := na
    ldnOrb_longFvgStartTime := na
    ldnOrb_longFvgText      := na
    ldnOrb_shortFvgTopStored := na
    ldnOrb_shortFvgBotStored := na
    ldnOrb_shortFvgStartTime := na
    ldnOrb_shortFvgText      := na
    ldnOrb_orbLinesDrawn := false
    ldnOrb_orbHighLine := na
    ldnOrb_orbLowLine  := na
    ldnOrb_orbLineStart := na
    ldnOrb_longEntry := na
    ldnOrb_longStop  := na
    ldnOrb_longTp1   := na
    ldnOrb_longTp2   := na
    ldnOrb_shortEntry := na
    ldnOrb_shortStop  := na
    ldnOrb_shortTp1   := na
    ldnOrb_shortTp2   := na
    ldnOrb_longEntryLine := na
    ldnOrb_longStopLine  := na
    ldnOrb_longTp1Line   := na
    ldnOrb_longTp2Line   := na
    ldnOrb_longStopLbl   := na
    ldnOrb_longTp1Lbl    := na
    ldnOrb_longTp2Lbl    := na
    ldnOrb_shortEntryLine := na
    ldnOrb_shortStopLine  := na
    ldnOrb_shortTp1Line   := na
    ldnOrb_shortTp2Line   := na
    ldnOrb_shortStopLbl   := na
    ldnOrb_shortTp1Lbl    := na
    ldnOrb_shortTp2Lbl    := na
    ldnOrb_longFvgBox      := na
    ldnOrb_shortFvgBox     := na
    ldnOrb_longFvgLabel    := na
    ldnOrb_shortFvgLabel   := na

// ============================================================================
// BUILD ORB - NY (use current-bar 5m ohlc so the ORB is not shifted forward)
// ============================================================================
if enableNY and orbBarClosed5 and inNyORB and inNyRTH
    ny_orbHigh := na(ny_orbHigh) ? orbH5 : math.max(ny_orbHigh, orbH5)
    ny_orbLow  := na(ny_orbLow)  ? orbL5 : math.min(ny_orbLow, orbL5)

if enableNY and orbBarClosed5 and not inNyORB and inNyRTH and not ny_orbReady and not na(ny_orbHigh) and not na(ny_orbLow)
    ny_orbReady := true

// ============================================================================
// BUILD ORB - ASIA (same current-bar ORB feed as NY)
// ============================================================================
if enableAsia and orbBarClosed5 and inAsiaORB and inAsiaRTH
    asia_orbHigh := na(asia_orbHigh) ? orbH5 : math.max(asia_orbHigh, orbH5)
    asia_orbLow  := na(asia_orbLow)  ? orbL5 : math.min(asia_orbLow, orbL5)

if enableAsia and orbBarClosed5 and not inAsiaORB and inAsiaRTH and not asia_orbReady and not na(asia_orbHigh) and not na(asia_orbLow)
    asia_orbReady := true

// ============================================================================
// BUILD ORB - LDN ORB (same current-bar ORB feed as the other ORB sessions)
// ============================================================================
if enableLdnOrb and orbBarClosed5 and inLdnOrbORB and inLdnRTH
    ldnOrb_orbHigh := na(ldnOrb_orbHigh) ? orbH5 : math.max(ldnOrb_orbHigh, orbH5)
    ldnOrb_orbLow  := na(ldnOrb_orbLow)  ? orbL5 : math.min(ldnOrb_orbLow, orbL5)

if enableLdnOrb and orbBarClosed5 and not inLdnOrbORB and inLdnRTH and not ldnOrb_orbReady and not na(ldnOrb_orbHigh) and not na(ldnOrb_orbLow)
    ldnOrb_orbReady := true

// ============================================================================
// DAILY ATR + GLOBEX OPEN
// ============================================================================
nyDailyATR   = request.security(syminfo.tickerid, "D", ta.atr(nyAtrLength)[1], lookahead=barmerge.lookahead_on)
asiaDailyATR = request.security(syminfo.tickerid, "D", ta.atr(asiaAtrLength)[1], lookahead=barmerge.lookahead_on)
lsiNyDailyATR   = request.security(syminfo.tickerid, "D", ta.atr(i_nqLsiNyAtrLength)[1],   lookahead=barmerge.lookahead_on)
lsiAsiaDailyATR = request.security(syminfo.tickerid, "D", ta.atr(i_nqLsiAsiaAtrLength)[1], lookahead=barmerge.lookahead_on)
ldnDailyATR     = request.security(syminfo.tickerid, "D", ta.atr(i_nqLdnAtrLength)[1],     lookahead=barmerge.lookahead_on)
ldnOrbDailyATR  = request.security(syminfo.tickerid, "D", ta.atr(i_nqLdnOrbAtrLength)[1], lookahead=barmerge.lookahead_on)
extTicker  = ticker.new(syminfo.prefix, syminfo.ticker, session.extended)
globexOpen = request.security(extTicker, "D", open, lookahead=barmerge.lookahead_on)

// ============================================================================
// ALERT TRIGGER FLAGS (per-bar, non-persistent)
// ============================================================================
ny_longSetupAlert   = false
ny_shortSetupAlert  = false
asia_longSetupAlert  = false
asia_shortSetupAlert = false
lsiNy_setupAlert   = false
lsiAsia_setupAlert = false
ldn_setupAlert     = false
ldnOrb_longSetupAlert  = false
ldnOrb_shortSetupAlert = false

// ============================================================================
// HELPER: compute bar time at session end time
// ============================================================================
calcEndBarTime(sessionStr, tz) =>
    // parse end time (hhmm after the hyphen) from session string e.g. "0945-1300"
    endPart  = str.substring(sessionStr, 5, 9)
    endHour  = int(str.tonumber(str.substring(endPart, 0, 2)))
    endMin   = int(str.tonumber(str.substring(endPart, 2, 4)))
    // get current bar's time in the session timezone
    barTime   = time
    barMoment = timestamp(tz, year(barTime, tz), month(barTime, tz), dayofmonth(barTime, tz), endHour, endMin, 0)
    // if the end time is earlier than the current bar, push to next day
    barMoment := barMoment < barTime ? barMoment + 24 * 60 * 60 * 1000 : barMoment
    barMoment

// ============================================================================
// FVG SIZE REQUIREMENTS (supports ATR-based and ORB-based sizing)
// ============================================================================
nyOrbRange   = nz(ny_orbHigh - ny_orbLow)
asiaOrbRange = nz(asia_orbHigh - asia_orbLow)

nyMinGap   = nyStopMode == "ORB" ? (nyMinGapPct / 100) * nyOrbRange : (nyMinGapPct / 100) * nz(nyDailyATR)
asiaMinGap = asiaStopMode == "ORB" ? (asiaMinGapPct / 100) * asiaOrbRange : (asiaMinGapPct / 100) * nz(asiaDailyATR)

// ============================================================================
// FVG DETECTION (using 5m OHLC: h5, l5, h5_1, l5_1, h5_2, l5_2)
// with impulse close filter and direction filter
// ============================================================================
longFvgTop     = l5
longFvgBottom  = h5_2
shortFvgTop    = l5_2
shortFvgBottom = h5
longGapSize    = longFvgTop - longFvgBottom
shortGapSize   = shortFvgTop - shortFvgBottom

// NY FVG validation
nyLongGapValid  = longGapSize >= nyMinGap
nyShortGapValid = shortGapSize >= nyMinGap
nyLongBreakout  = longFvgTop > ny_orbHigh or (nyImpulseClose and c5_1 > ny_orbHigh)
nyShortBreakout = shortFvgBottom < ny_orbLow or (nyImpulseClose and c5_1 < ny_orbLow)
nyLongFVG  = nyDetectLongs and h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5 and nyLongBreakout and nyLongGapValid
nyShortFVG = nyDetectShorts and l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5 and nyShortBreakout and nyShortGapValid

// Asia FVG validation
asiaLongGapValid  = longGapSize >= asiaMinGap
asiaShortGapValid = shortGapSize >= asiaMinGap
asiaLongBreakout  = longFvgTop > asia_orbHigh or (asiaImpulseClose and c5_1 > asia_orbHigh)
asiaShortBreakout = shortFvgBottom < asia_orbLow or (asiaImpulseClose and c5_1 < asia_orbLow)
asiaLongFVG  = asiaDetectLongs and h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5 and asiaLongBreakout and asiaLongGapValid
asiaShortFVG = asiaDetectShorts and l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5 and asiaShortBreakout and asiaShortGapValid

// LSI FVG detection (no ORB filter — any qualifying FVG is stored in arrays)
lsiNyMinGap   = (i_nqLsiNyMinGapPct  / 100) * nz(lsiNyDailyATR)
lsiAsiaMinGap = (i_nqLsiAsiaMinGapPct / 100) * nz(lsiAsiaDailyATR)
ldnMinGap     = (i_nqLdnMinGapPct    / 100) * nz(ldnDailyATR)

// LDN ORB FVG validation
ldnOrbMinGap       = (i_nqLdnOrbMinGapPct / 100) * nz(ldnOrbDailyATR)
ldnOrbLongGapValid  = longGapSize >= ldnOrbMinGap
ldnOrbShortGapValid = shortGapSize >= ldnOrbMinGap
ldnOrbLongBreakout  = longFvgTop > ldnOrb_orbHigh or (i_nqLdnOrbImpulseClose and c5_1 > ldnOrb_orbHigh)
ldnOrbShortBreakout = shortFvgBottom < ldnOrb_orbLow or (i_nqLdnOrbImpulseClose and c5_1 < ldnOrb_orbLow)
ldnOrbLongFVG  = ldnOrbDetectLongs and h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5 and ldnOrbLongBreakout and ldnOrbLongGapValid
ldnOrbShortFVG = ldnOrbDetectShorts and l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5 and ldnOrbShortBreakout and ldnOrbShortGapValid

// Base FVG patterns for LSI (bearish FVGs → long inversions, bullish → short)
isBearFvg   = l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5
bearFvgTop  = l5_2
bearFvgBot  = h5
bearGapSize = bearFvgTop - bearFvgBot
isBullFvg   = h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5
bullFvgTop  = l5
bullFvgBot  = h5_2
bullGapSize = bullFvgTop - bullFvgBot

// ============================================================================
// DETECT FIRST FVG - NY
// ============================================================================
nyCanDetect = enableNY and barClosed5 and inNyRTH and inNyEntryWin and ny_orbReady

if nyCanDetect and not ny_longFirstFvgFound and nyLongFVG
    ny_longFirstFvgFound := true
    ny_longSetupAlert := enableAlerts
    ny_longFvgTopStored  := longFvgTop
    ny_longFvgBotStored  := longFvgBottom
    ny_longFvgStartTime  := t5_2
    fvgPts    = longGapSize
    fvgAtrPct = nyDailyATR > 0 ? (fvgPts / nyDailyATR) * 100 : 0.0
    ny_longFvgText := str.tostring(fvgPts, format.mintick) + " pts (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
    ny_longEntry := longFvgTop
    stopDist     = nyStopMode == "ORB" ? (nyStopPct / 100) * nyOrbRange : (nyStopPct / 100) * nz(nyDailyATR)
    ny_longStop  := ny_longEntry - stopDist
    riskPts      = ny_longEntry - ny_longStop
    ny_longTp1   := ny_longEntry + (nyRR * riskPts * nyTp1Ratio)
    ny_longTp2   := ny_longEntry + (nyRR * riskPts)
    if canDraw
        ny_longFvgBox := box.new(ny_longFvgStartTime, ny_longFvgTopStored, time, ny_longFvgBotStored, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(#787b86, 80), border_width=0)
        ny_longFvgLabel := label.new(time, (ny_longFvgTopStored + ny_longFvgBotStored) / 2, ny_longFvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(#787b86, 0), size=size.small)
        slPts  = riskPts
        slAtr  = nyDailyATR > 0 ? (slPts / nyDailyATR) * 100 : 0.0
        tp1Pts = ny_longTp1 - ny_longEntry
        tp1Atr = nyDailyATR > 0 ? (tp1Pts / nyDailyATR) * 100 : 0.0
        tp2Pts = ny_longTp2 - ny_longEntry
        tp2Atr = nyDailyATR > 0 ? (tp2Pts / nyDailyATR) * 100 : 0.0
        nyEndBar = calcEndBarTime(nyEntryWindow, "America/New_York")
        ny_longEntryLine := line.new(time, ny_longEntry, nyEndBar, ny_longEntry, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
        ny_longStopLine  := line.new(time, ny_longStop, nyEndBar, ny_longStop, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
        ny_longTp1Line   := line.new(time, ny_longTp1, nyEndBar, ny_longTp1, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
        ny_longTp2Line   := line.new(time, ny_longTp2, nyEndBar, ny_longTp2, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
        slTxt  = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
        tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
        tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
        ny_longStopLbl := label.new(nyEndBar, ny_longStop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
        ny_longTp1Lbl  := label.new(nyEndBar, ny_longTp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
        ny_longTp2Lbl  := label.new(nyEndBar, ny_longTp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

if nyCanDetect and not ny_shortFirstFvgFound and nyShortFVG
    ny_shortFirstFvgFound := true
    ny_shortSetupAlert := enableAlerts
    ny_shortFvgTopStored  := shortFvgTop
    ny_shortFvgBotStored  := shortFvgBottom
    ny_shortFvgStartTime  := t5_2
    fvgPts    = shortGapSize
    fvgAtrPct = nyDailyATR > 0 ? (fvgPts / nyDailyATR) * 100 : 0.0
    ny_shortFvgText := str.tostring(fvgPts, format.mintick) + " pts (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
    ny_shortEntry := shortFvgBottom
    stopDist      = nyStopMode == "ORB" ? (nyStopPct / 100) * nyOrbRange : (nyStopPct / 100) * nz(nyDailyATR)
    ny_shortStop  := ny_shortEntry + stopDist
    riskPts       = ny_shortStop - ny_shortEntry
    ny_shortTp1   := ny_shortEntry - (nyRR * riskPts * nyTp1Ratio)
    ny_shortTp2   := ny_shortEntry - (nyRR * riskPts)
