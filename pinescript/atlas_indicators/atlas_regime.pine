//@version=6
indicator("Atlas Regime", overlay=true)

// ————— Inputs —————
regimeSymbol      = input.symbol("CME_MINI:NQ1!", "Regime Source Symbol", group="Regime", tooltip="Defaults to NQ continuous futures to mirror the live regime-gate calendar. Built for intraday charts using 5m aggregation with midnight-ET day boundaries.")
trendSmaThreshPct = input.float(0.50, "Trend SMA Threshold %", step=0.01, group="Regime")
trendRetThreshPct = input.float(0.00, "Trend 5D Return Threshold %", step=0.01, group="Regime")
lowConfSmaPct     = input.float(0.25, "Low-Confidence SMA Band %", step=0.01, group="Regime")
lowConfRetPct     = input.float(0.50, "Low-Confidence 5D Return Band %", step=0.01, group="Regime")
lowVolUpperPct    = input.float(12.52, "Low Vol Upper %", step=0.01, group="Vol Thresholds", tooltip="Frozen pre-holdout tercile cutoff from regime research.")
medVolUpperPct    = input.float(20.40, "Medium Vol Upper %", step=0.01, group="Vol Thresholds", tooltip="Frozen pre-holdout tercile cutoff from regime research. Values above this are high vol.")

bullColor         = input.color(color.new(#29D398, 0), "Bull Color", group="Display")
bearColor         = input.color(color.new(#E95678, 0), "Bear Color", group="Display")
sidewaysColor     = input.color(color.new(#F6C177, 0), "Sideways Color", group="Display")
lowVolColor       = input.color(color.new(#7DCFFF, 0), "Low Vol Color", group="Display")
mediumVolColor    = input.color(color.new(#F6C177, 0), "Medium Vol Color", group="Display")
highVolColor      = input.color(color.new(#FF9E64, 0), "High Vol Color", group="Display")
textSize          = input.string("Small", "Text Size", options=["Tiny", "Small", "Normal", "Large", "Huge"], group="Display")
tablePos          = input.string("Bottom Right", "Position", options=["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group="Display")

// ————— Input normalization —————
trendSmaThreshold = trendSmaThreshPct / 100.0
trendRetThreshold = trendRetThreshPct / 100.0
lowConfSmaBand    = lowConfSmaPct / 100.0
lowConfRetBand    = lowConfRetPct / 100.0
lowVolUpper       = lowVolUpperPct / 100.0
mediumVolUpper    = medVolUpperPct / 100.0

sizeVal = switch textSize
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    "Large"  => size.large
    "Huge"   => size.huge

posVal = switch tablePos
    "Top Left"     => position.top_left
    "Top Right"    => position.top_right
    "Bottom Left"  => position.bottom_left
    => position.bottom_right

// ————— Helpers —————
calc_last_sma(array<float> values, int length) =>
    float result = na
    int count = array.size(values)
    if count >= length
        float sum = 0.0
        for i = 0 to length - 1
            sum += array.get(values, count - 1 - i)
        result := sum / length
    result

calc_pct_return(array<float> values, int daysBack) =>
    float result = na
    int count = array.size(values)
    if count > daysBack
        float latest = array.get(values, count - 1)
        float prior = array.get(values, count - 1 - daysBack)
        if not na(prior) and prior != 0
            result := latest / prior - 1.0
    result

calc_sample_stdev(array<float> values, int length) =>
    float result = na
    int count = array.size(values)
    if count >= length and length > 1
        float mean = 0.0
        for i = 0 to length - 1
            mean += array.get(values, count - 1 - i)
        mean /= length

        float sumSq = 0.0
        for i = 0 to length - 1
            float diff = array.get(values, count - 1 - i) - mean
            sumSq += diff * diff
        result := math.sqrt(sumSq / (length - 1))
    result

classify_trend(float closeVsSma20, float ret5d, float smaThreshold, float retThreshold) =>
    string result = "sideways"
    float bearRetThreshold = retThreshold > 0 ? -retThreshold : 0.0
    if closeVsSma20 >= smaThreshold and ret5d > retThreshold
        result := "bull"
    else if closeVsSma20 <= -smaThreshold and ret5d < bearRetThreshold
        result := "bear"
    result

classify_vol(float volValue, float lowUpper, float mediumUpper) =>
    string result = "unknown"
    if not na(volValue)
        if volValue <= lowUpper
            result := "low_vol"
        else if volValue <= mediumUpper
            result := "medium_vol"
        else
            result := "high_vol"
    result

trend_color(string trendValue) =>
    color result = color.white
    if trendValue == "bull"
        result := bullColor
    else if trendValue == "bear"
        result := bearColor
    else if trendValue == "sideways"
        result := sidewaysColor
    else
        result := color.new(color.white, 30)
    result

vol_color(string volValue) =>
    color result = color.white
    if volValue == "low_vol"
        result := lowVolColor
    else if volValue == "medium_vol"
        result := mediumVolColor
    else if volValue == "high_vol"
        result := highVolColor
    else
        result := color.new(color.white, 30)
    result

signed_pct(float value) =>
    na(value) ? "—" : (value >= 0 ? "+" : "") + str.tostring(value * 100.0, "#.##") + "%"

plain_pct(float value) =>
    na(value) ? "—" : str.tostring(value * 100.0, "#.##") + "%"

plain_num(float value) =>
    na(value) ? "—" : str.tostring(value, "#.##")

// ————— Custom daily close series — midnight-ET boundaries (matches backtesting research) —————
[srcClose5, srcTime5] = request.security(regimeSymbol, "5", [close, time], lookahead=barmerge.lookahead_on)
srcBarClosed5 = not na(srcTime5) and ta.change(srcTime5) != 0
srcDateKey = year(srcTime5, "America/New_York") * 10000 + month(srcTime5, "America/New_York") * 100 + dayofmonth(srcTime5, "America/New_York")

var float currentDayClose = na
var int lastDateKey = na
var array<float> dailyCloses = array.new_float()
var array<float> dailyLogReturns = array.new_float()

var float regimeClose = na
var float regimeSma20 = na
var float regimeCloseVsSma20 = na
var float regimeRet5d = na
var float regimeRv21 = na
var bool warmupOk = false
var bool lowConfidence = false
var string trendRegime = "warmup"
var string volRegime = "unknown"
var string combinedRegime = "warmup"

if srcBarClosed5
    if not na(lastDateKey) and srcDateKey != lastDateKey and not na(currentDayClose)
        float priorClose = array.size(dailyCloses) > 0 ? array.get(dailyCloses, array.size(dailyCloses) - 1) : na
        array.push(dailyCloses, currentDayClose)
        if not na(priorClose) and priorClose > 0 and currentDayClose > 0
            array.push(dailyLogReturns, math.log(currentDayClose / priorClose))

        regimeClose := currentDayClose
        regimeSma20 := calc_last_sma(dailyCloses, 20)
        regimeCloseVsSma20 := not na(regimeSma20) and regimeSma20 != 0 ? regimeClose / regimeSma20 - 1.0 : na
        regimeRet5d := calc_pct_return(dailyCloses, 5)
        float volStdev = calc_sample_stdev(dailyLogReturns, 21)
        regimeRv21 := not na(volStdev) ? volStdev * math.sqrt(252.0) : na

        warmupOk := not na(regimeCloseVsSma20) and not na(regimeRet5d) and not na(regimeRv21)
        lowConfidence := warmupOk and ((math.abs(regimeCloseVsSma20) < lowConfSmaBand) or (math.abs(regimeRet5d) < lowConfRetBand))
        trendRegime := warmupOk ? classify_trend(regimeCloseVsSma20, regimeRet5d, trendSmaThreshold, trendRetThreshold) : "warmup"
        volRegime := warmupOk ? classify_vol(regimeRv21, lowVolUpper, mediumVolUpper) : "unknown"
        combinedRegime := warmupOk ? trendRegime + "_" + volRegime : "warmup"

        currentDayClose := srcClose5
    else
        currentDayClose := srcClose5
    lastDateKey := srcDateKey

// ————— Table —————
var color bgColor = color.new(#1e222d, 10)
var color borderColor = color.new(#363a45, 0)
var color mutedColor = color.new(color.white, 40)
var table regimeTable = table.new(posVal, 2, 8, bgcolor=bgColor, border_width=1, border_color=borderColor)

if barstate.islast
    color headlineColor = trend_color(trendRegime)
    string lowConfText = warmupOk ? (lowConfidence ? "Yes" : "No") : "—"

    table.cell(regimeTable, 0, 0, "Regime", text_color=color.white, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 0, combinedRegime, text_color=headlineColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)

    table.cell(regimeTable, 0, 1, "Trend", text_color=mutedColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 1, trendRegime, text_color=trend_color(trendRegime), text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)

    table.cell(regimeTable, 0, 2, "Vol", text_color=mutedColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 2, volRegime, text_color=vol_color(volRegime), text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)

    table.cell(regimeTable, 0, 3, "SMA20", text_color=mutedColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 3, plain_num(regimeSma20), text_color=color.white, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)

    table.cell(regimeTable, 0, 4, "Close vs SMA", text_color=mutedColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 4, signed_pct(regimeCloseVsSma20), text_color=trendRegime == "bull" ? bullColor : trendRegime == "bear" ? bearColor : sidewaysColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)

    table.cell(regimeTable, 0, 5, "5D Return", text_color=mutedColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 5, signed_pct(regimeRet5d), text_color=regimeRet5d >= 0 ? bullColor : bearColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)

    table.cell(regimeTable, 0, 6, "RV21", text_color=mutedColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 6, plain_pct(regimeRv21), text_color=vol_color(volRegime), text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)

    table.cell(regimeTable, 0, 7, "Low Conf", text_color=mutedColor, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(regimeTable, 1, 7, lowConfText, text_color=lowConfidence ? sidewaysColor : color.white, text_size=sizeVal, bgcolor=bgColor, text_halign=text.align_right)
