//@version=6
indicator(
     title              = "LSI [atlasfutures]",
     overlay            = true,
     max_lines_count    = 500,
     max_boxes_count    = 500,
     max_labels_count   = 500
)

// ============================================================================
// AUTO-DETECT ASSET from chart symbol
// ============================================================================
asset = if syminfo.root == "NQ" or syminfo.root == "MNQ"
    "NQ"
else
    "NQ"  // LSI currently NQ-only

// ============================================================================
// INPUTS - Display
// ============================================================================
drawbackDays = input.int(1, "Days Back", minval=1, maxval=50, tooltip="Number of trading days to show drawings for", group="Display")

// ============================================================================
// INPUTS - NQ: NY
// ============================================================================
i_nqNyEntryWindow  = input.session("0935-1530", "Entry Window (ny time)", group="NQ: NY")
i_nqNyDirection    = input.string("Long Only", "Direction", options=["Long Only"], group="NQ: NY")
i_nqNyEntryMode    = input.string("FVG Limit", "Entry Mode", options=["Bar Close", "FVG Limit"], tooltip="Bar Close = enter at inversion bar close. FVG Limit = limit order at FVG boundary after inversion.", group="NQ: NY")
i_nqNyRR           = input.float(3.0, "Reward/Risk", step=0.25, group="NQ: NY")
i_nqNyTp1Ratio     = input.float(0.34, "TP1/BE Level (fraction of R:R)", step=0.01, minval=0.1, maxval=0.9, group="NQ: NY")
i_nqNyAtrLength    = input.int(10, "ATR Length", minval=1, group="NQ: NY")
i_nqNyMinGapPct    = input.float(5.0, "Min Gap (% ATR)", step=0.25, tooltip="Minimum FVG size as percentage of daily ATR", group="NQ: NY")
i_nqNyFvgWindowLeft = input.int(20, "FVG Window Left", minval=0, group="NQ: NY", tooltip="Max bars a qualifying FVG may appear before the sweep.")
i_nqNyFvgWindowRight = input.int(5, "FVG Window Right", minval=0, group="NQ: NY", tooltip="Max bars a qualifying FVG may appear after the sweep.")
i_nqNySwingLeft    = input.int(8, "Swing Left", minval=1, group="NQ: NY", tooltip="Bars to the left of a confirmed swing pivot.")
i_nqNySwingRight   = input.int(60, "Swing Right", minval=1, group="NQ: NY", tooltip="Bars to the right of a confirmed swing pivot.")
nqNyFvgPendColor   = input.color(#787b86, "FVG Pending Color", group="NQ: NY")
nqNyFvgSweptColor  = input.color(#26a69a, "FVG Swept Color", group="NQ: NY")

// ============================================================================
// INPUTS - NQ: Asia
// ============================================================================
i_nqAsiaEntryWindow  = input.session("2045-2200", "Entry Window (ny time)", group="NQ: Asia")
i_nqAsiaDirection    = input.string("Long Only", "Direction", options=["Long Only"], group="NQ: Asia")
i_nqAsiaEntryMode    = input.string("Bar Close", "Entry Mode", options=["Bar Close", "FVG Limit"], tooltip="Bar Close = enter at inversion bar close. FVG Limit = limit order at FVG boundary after inversion.", group="NQ: Asia")
i_nqAsiaRR           = input.float(1.75, "Reward/Risk", step=0.25, group="NQ: Asia")
i_nqAsiaTp1Ratio     = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: Asia")
i_nqAsiaAtrLength    = input.int(40, "ATR Length", minval=1, group="NQ: Asia")
i_nqAsiaMinGapPct    = input.float(1.75, "Min Gap (% ATR)", step=0.25, tooltip="Minimum FVG size as percentage of daily ATR", group="NQ: Asia")
i_nqAsiaFvgWindowLeft = input.int(10, "FVG Window Left", minval=0, group="NQ: Asia", tooltip="Max bars a qualifying FVG may appear before the sweep.")
i_nqAsiaFvgWindowRight = input.int(10, "FVG Window Right", minval=0, group="NQ: Asia", tooltip="Max bars a qualifying FVG may appear after the sweep.")
i_nqAsiaSwingLeft   = input.int(3, "Swing Left", minval=1, group="NQ: Asia", tooltip="Bars to the left of a confirmed swing pivot.")
i_nqAsiaSwingRight  = input.int(3, "Swing Right", minval=1, group="NQ: Asia", tooltip="Bars to the right of a confirmed swing pivot.")
nqAsiaFvgPendColor   = input.color(#787b86, "FVG Pending Color", group="NQ: Asia")
nqAsiaFvgSweptColor  = input.color(#2196F3, "FVG Swept Color", group="NQ: Asia")

// ============================================================================
// INPUTS - Trade Level Colors
// ============================================================================
entryColor = input.color(#787b86, "Entry Color", inline="entry", group="Trade Level Colors")
entryStyle = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="entry", group="Trade Level Colors")
slColor    = input.color(#787b86, "SL Color", inline="sl", group="Trade Level Colors")
slStyle    = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="sl", group="Trade Level Colors")
tp1Color   = input.color(#787b86, "TP1 Color", inline="tp1", group="Trade Level Colors")
tp1Style   = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="tp1", group="Trade Level Colors")
tp2Color   = input.color(#787b86, "TP2 Color", inline="tp2", group="Trade Level Colors")
tp2Style   = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="tp2", group="Trade Level Colors")

// ============================================================================
// INPUTS - Skip Days - NQ: NY  (backtest excludes Wed+Thu)
// ============================================================================
i_nqNySkipMon = input.bool(false, "Skip Monday",    group="NQ: NY Skip Days")
i_nqNySkipTue = input.bool(false, "Skip Tuesday",   group="NQ: NY Skip Days")
i_nqNySkipWed = input.bool(true,  "Skip Wednesday", group="NQ: NY Skip Days")
i_nqNySkipThu = input.bool(true,  "Skip Thursday",  group="NQ: NY Skip Days")
i_nqNySkipFri = input.bool(false, "Skip Friday",    group="NQ: NY Skip Days")


// ============================================================================
// INPUTS - Skip Days - NQ: Asia
// ============================================================================
i_nqAsiaSkipMon = input.bool(false, "Skip Monday",    group="NQ: Asia Skip Days")
i_nqAsiaSkipTue = input.bool(false, "Skip Tuesday",   group="NQ: Asia Skip Days")
i_nqAsiaSkipWed = input.bool(false, "Skip Wednesday", group="NQ: Asia Skip Days")
i_nqAsiaSkipThu = input.bool(false, "Skip Thursday",  group="NQ: Asia Skip Days")
i_nqAsiaSkipFri = input.bool(false, "Skip Friday",    group="NQ: Asia Skip Days")

// ============================================================================
// INPUTS - Alerts
// ============================================================================
enableAlerts = input.bool(true, "Enable Setup Alerts", tooltip="Enable alert conditions for when an LSI setup is armed", group="Alerts")

// ============================================================================
// RESOLVE ACTIVE CONFIG — NQ-only for now
// ============================================================================
enableNY   = true
enableAsia = false

nySessionRTH   = "0930-1600"
asiaSessionRTH = "2000-0700"

nyEntryWindow    = i_nqNyEntryWindow
nyDirection      = i_nqNyDirection
nyEntryMode      = i_nqNyEntryMode
nyRR             = i_nqNyRR
nyTp1Ratio       = i_nqNyTp1Ratio
nyAtrLength      = i_nqNyAtrLength
nyMinGapPct      = i_nqNyMinGapPct
nyFvgWindowLeft  = i_nqNyFvgWindowLeft
nyFvgWindowRight = i_nqNyFvgWindowRight
nySwingLeft      = i_nqNySwingLeft
nySwingRight     = i_nqNySwingRight
nyFvgPendColor   = nqNyFvgPendColor
nyFvgSweptColor  = nqNyFvgSweptColor
nyIsFvgLimit     = nyEntryMode == "FVG Limit"

asiaEntryWindow    = i_nqAsiaEntryWindow
asiaDirection      = i_nqAsiaDirection
asiaEntryMode      = i_nqAsiaEntryMode
asiaRR             = i_nqAsiaRR
asiaTp1Ratio       = i_nqAsiaTp1Ratio
asiaAtrLength      = i_nqAsiaAtrLength
asiaMinGapPct      = i_nqAsiaMinGapPct
asiaFvgWindowLeft  = i_nqAsiaFvgWindowLeft
asiaFvgWindowRight = i_nqAsiaFvgWindowRight
asiaSwingLeft      = i_nqAsiaSwingLeft
asiaSwingRight     = i_nqAsiaSwingRight
asiaFvgPendColor   = nqAsiaFvgPendColor
asiaFvgSweptColor  = nqAsiaFvgSweptColor
asiaIsFvgLimit     = asiaEntryMode == "FVG Limit"

// ============================================================================
// LINE STYLE LOOKUP
// ============================================================================
styleToLine(s) =>
    s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed
entryLineStyle = styleToLine(entryStyle)
slLineStyle    = styleToLine(slStyle)
tp1LineStyle   = styleToLine(tp1Style)
tp2LineStyle   = styleToLine(tp2Style)

// ============================================================================
// SESSION FILTERS - use "5" resolution for correct detection on all chart TFs
// ============================================================================
inNyRTH      = not na(time("5", nySessionRTH, "America/New_York"))
inNyEntryWin = not na(time("5", nyEntryWindow, "America/New_York"))
inAsiaRTH      = not na(time("5", asiaSessionRTH, "America/New_York"))
inAsiaEntryWin = not na(time("5", asiaEntryWindow, "America/New_York"))

// ============================================================================
// DOW SKIP FLAGS
// dayofweek: 1=Sun 2=Mon 3=Tue 4=Wed 5=Thu 6=Fri 7=Sat
// ============================================================================
dow = dayofweek(time, "America/New_York")
nySkipToday   = (dow == dayofweek.monday    and i_nqNySkipMon)
              or (dow == dayofweek.tuesday   and i_nqNySkipTue)
              or (dow == dayofweek.wednesday and i_nqNySkipWed)
              or (dow == dayofweek.thursday  and i_nqNySkipThu)
              or (dow == dayofweek.friday    and i_nqNySkipFri)
asiaSkipToday = (dow == dayofweek.monday    and i_nqAsiaSkipMon)
              or (dow == dayofweek.tuesday   and i_nqAsiaSkipTue)
              or (dow == dayofweek.wednesday and i_nqAsiaSkipWed)
              or (dow == dayofweek.thursday  and i_nqAsiaSkipThu)
              or (dow == dayofweek.friday    and i_nqAsiaSkipFri)

// ============================================================================
// 5m OHLC - stable confirmed data with lookahead_off
// h5/l5 = latest confirmed 5m candle (bar[0]), h5_1/l5_1 = impulse (bar[1]),
// h5_2/l5_2 = "before" candle (bar[2]), c5 = close of confirmed bar
// ============================================================================
regTicker = ticker.new(syminfo.prefix, syminfo.ticker, session.regular)
[h5, l5, h5_1, l5_1, h5_2, l5_2, c5, t5, t5_2] = request.security(regTicker, "5", [high, low, high[1], low[1], high[2], low[2], close, time, time[2]], lookahead=barmerge.lookahead_off)
barClosed5 = ta.change(t5) != 0

// Current-bar 5m data (no [1] shift) for ATR accumulation
[atr_h5, atr_l5, atr_c5, atr_t5] = request.security(regTicker, "5", [high, low, close, time], lookahead=barmerge.lookahead_off)
atr_barClosed5 = ta.change(atr_t5) != 0

// Session start detection (rising edge of RTH filter)
nyRTHStart   = inNyRTH and not inNyRTH[1]
asiaRTHStart = inAsiaRTH and not inAsiaRTH[1]

// ============================================================================
// DRAWBACK FILTER - only draw recent N days
// ============================================================================
barsPerDay = timeframe.in_seconds("D") / timeframe.in_seconds(timeframe.period)
canDraw    = bar_index >= last_bar_index - drawbackDays * barsPerDay

// ============================================================================
// DIRECTION FLAGS
// ============================================================================
nyDetectLongs    = true
nyDetectShorts   = false
asiaDetectLongs  = true
asiaDetectShorts = false

// ============================================================================
// CUSTOM DAILY ATR — midnight-ET boundaries (matches Python engine exactly)
//
// Pine's request.security("D", ta.atr()) uses exchange session boundaries
// (6 PM ET → 5 PM ET for CME futures), but the Python backtester resamples
// 5m bars by calendar date (midnight ET → midnight ET). This causes a 10-15%
// ATR discrepancy. The fix: accumulate 5m OHLC into daily bars at midnight ET,
// then compute Wilder's ATR manually for each session's ATR length.
// ============================================================================
atr_curDay = dayofmonth(atr_t5, "America/New_York")

// Daily OHLC accumulation (shared by both NY and Asia ATR)
var float atr_dayHigh   = na
var float atr_dayLow    = na
var float atr_dayClose  = na
var int   atr_lastDay   = -1
var float atr_lastClose = na

// NY ATR state (Wilder's smoothing)
var float ny_atr_value    = na
var float ny_atr_building = na
var int   ny_atr_count    = 0
var array<float> ny_atr_trHist = array.new<float>(0)

// Asia ATR state (Wilder's smoothing)
var float asia_atr_value    = na
var float asia_atr_building = na
var int   asia_atr_count    = 0
var array<float> asia_atr_trHist = array.new<float>(0)

if atr_barClosed5
    if atr_lastDay != -1 and atr_curDay != atr_lastDay and not na(atr_dayHigh)
        // Day transition — close out the previous calendar day
        if not na(atr_lastClose)
            tr = math.max(atr_dayHigh - atr_dayLow, math.max(math.abs(atr_dayHigh - atr_lastClose), math.abs(atr_dayLow - atr_lastClose)))

            // NY ATR update
            ny_atr_count += 1
            if ny_atr_count <= nyAtrLength
                array.push(ny_atr_trHist, tr)
                if ny_atr_count == nyAtrLength
                    sum = 0.0
                    for i = 0 to nyAtrLength - 1
                        sum += array.get(ny_atr_trHist, i)
                    ny_atr_building := sum / nyAtrLength
            else
                ny_atr_building := (ny_atr_building * (nyAtrLength - 1) + tr) / nyAtrLength

            // Asia ATR update
            asia_atr_count += 1
            if asia_atr_count <= asiaAtrLength
                array.push(asia_atr_trHist, tr)
                if asia_atr_count == asiaAtrLength
                    sum = 0.0
                    for i = 0 to asiaAtrLength - 1
                        sum += array.get(asia_atr_trHist, i)
                    asia_atr_building := sum / asiaAtrLength
            else
                asia_atr_building := (asia_atr_building * (asiaAtrLength - 1) + tr) / asiaAtrLength

        // Lag: bars during the new day see ATR through the previous completed day
        ny_atr_value    := ny_atr_building
        asia_atr_value  := asia_atr_building
        atr_lastClose   := atr_dayClose
        // Reset accumulator for the new day
        atr_dayHigh  := atr_h5
        atr_dayLow   := atr_l5
        atr_dayClose := atr_c5
    else
        // Same day — accumulate
        atr_dayHigh  := na(atr_dayHigh) ? atr_h5 : math.max(atr_dayHigh, atr_h5)
        atr_dayLow   := na(atr_dayLow)  ? atr_l5 : math.min(atr_dayLow, atr_l5)
        atr_dayClose := atr_c5
    atr_lastDay := atr_curDay

nyDailyATR   = ny_atr_value
asiaDailyATR = asia_atr_value

// ============================================================================
// FVG ZONE TYPE
// ============================================================================
type FvgZone
    float top
    float bot
    int   startTime
    int   detectBar
    bool  isBullish
    box   bx
    label lbl
    float rangeHigh  // running max(high) from FVG "before" bar onward (for absolute stop)
    float rangeLow   // running min(low) from FVG "before" bar onward (for absolute stop)

// ============================================================================
// STATE - NY
// ============================================================================
var ny_bearFvgs = array.new<FvgZone>(0)
var ny_bullFvgs = array.new<FvgZone>(0)
var ny_recentBearFvgs = array.new<FvgZone>(0)
var ny_recentBullFvgs = array.new<FvgZone>(0)
var bool  ny_waitingForGap = false
var bool  ny_waitingForInversion = false
var bool  ny_armed = false
var bool  ny_inverted = false  // inversion detected, waiting for limit fill (fvg_limit mode)
var float ny_limitPrice = na   // limit order price (fvg_limit mode)
var int   ny_limitDir = 0      // limit direction (fvg_limit mode)
var FvgZone ny_limitZone = na  // the FVG zone that triggered the limit
var FvgZone ny_activeGap = na
var int   ny_barCount = 0
var int   ny_sweepBarIndex = na
var int   ny_inversionBarIndex = na
var int   ny_sweepDir = 0
var float ny_sweepLevel = na
var float ny_entry = na
var float ny_stop  = na
var float ny_tp1   = na
var float ny_tp2   = na
var int   ny_dir   = 0
var array<float> ny_swingHighs = array.new<float>(0)
var array<float> ny_swingLows = array.new<float>(0)
var int   ny_swingDayKey = -1
var float ny_latestSwingHigh = na
var float ny_latestSwingLow = na
var float ny_prevSwingHigh = na
var float ny_prevSwingLow = na

var line  ny_entryLine = na
var line  ny_stopLine  = na
var line  ny_tp1Line   = na
var line  ny_tp2Line   = na
var label ny_stopLbl   = na
var label ny_tp1Lbl    = na
var label ny_tp2Lbl    = na

// ============================================================================
// STATE - Asia
// ============================================================================
var asia_bearFvgs = array.new<FvgZone>(0)
var asia_bullFvgs = array.new<FvgZone>(0)
var asia_recentBearFvgs = array.new<FvgZone>(0)
var asia_recentBullFvgs = array.new<FvgZone>(0)
var bool  asia_waitingForGap = false
var bool  asia_waitingForInversion = false
var bool  asia_armed = false
var bool  asia_inverted = false
var float asia_limitPrice = na
var int   asia_limitDir = 0
var FvgZone asia_limitZone = na
var FvgZone asia_activeGap = na
var int   asia_barCount = 0
var int   asia_sweepBarIndex = na
var int   asia_inversionBarIndex = na
var int   asia_sweepDir = 0
var float asia_sweepLevel = na
var float asia_entry = na
var float asia_stop  = na
var float asia_tp1   = na
var float asia_tp2   = na
var int   asia_dir   = 0
var array<float> asia_swingHighs = array.new<float>(0)
var array<float> asia_swingLows = array.new<float>(0)
var int   asia_swingDayKey = -1
var float asia_latestSwingHigh = na
var float asia_latestSwingLow = na
var float asia_prevSwingHigh = na
var float asia_prevSwingLow = na

var line  asia_entryLine = na
var line  asia_stopLine  = na
var line  asia_tp1Line   = na
var line  asia_tp2Line   = na
var label asia_stopLbl   = na
var label asia_tp1Lbl    = na
var label asia_tp2Lbl    = na

// ============================================================================
// ALERT FLAGS (per-bar, non-persistent)
// ============================================================================
ny_setupAlert   = false
asia_setupAlert = false

// ============================================================================
// HELPERS
// ============================================================================
calcEndBarTime(sessionStr, tz) =>
    endPart  = str.substring(sessionStr, 5, 9)
    endHour  = int(str.tonumber(str.substring(endPart, 0, 2)))
    endMin   = int(str.tonumber(str.substring(endPart, 2, 4)))
    barTime   = time
    barMoment = timestamp(tz, year(barTime, tz), month(barTime, tz), dayofmonth(barTime, tz), endHour, endMin, 0)
    barMoment := barMoment < barTime ? barMoment + 24 * 60 * 60 * 1000 : barMoment
    barMoment

// ============================================================================
// HELPER: draw trade level lines + labels
// ============================================================================
drawTradeLevels(entryVal, stopVal, tp1Val, tp2Val, dirVal, dailyATR, entryWinStr, sessEndTz) =>
    riskPts = math.abs(entryVal - stopVal)
    endBar  = calcEndBarTime(entryWinStr, sessEndTz)
    eLine   = line.new(time, entryVal, endBar, entryVal, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
    sLine   = line.new(time, stopVal, endBar, stopVal, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
    t1Line  = line.new(time, tp1Val, endBar, tp1Val, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
    t2Line  = line.new(time, tp2Val, endBar, tp2Val, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
    slPts   = riskPts
    slAtr   = dailyATR > 0 ? (slPts / dailyATR) * 100 : 0.0
    tp1Pts  = math.abs(tp1Val - entryVal)
    tp1Atr  = dailyATR > 0 ? (tp1Pts / dailyATR) * 100 : 0.0
    tp2Pts  = math.abs(tp2Val - entryVal)
    tp2Atr  = dailyATR > 0 ? (tp2Pts / dailyATR) * 100 : 0.0
    slTxt   = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
    tp1Txt  = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
    tp2Txt  = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
    sLbl    = label.new(endBar, stopVal, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
    t1Lbl   = label.new(endBar, tp1Val, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
    t2Lbl   = label.new(endBar, tp2Val, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)
    [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl]

// updateSwingState is inlined below to avoid tuple destructuring shadowing var state

makeZone(topVal, botVal, startTimeVal, detectBarVal, isBullishVal, pendColor, gapSizeVal, dailyAtrVal, drawVisuals) =>
    fvgAtrPct = dailyAtrVal > 0 ? (gapSizeVal / dailyAtrVal) * 100 : 0.0
    fvgText   = str.tostring(gapSizeVal, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
    initHigh  = math.max(h5_2, h5_1, h5)
    initLow   = math.min(l5_2, l5_1, l5)
    zone = FvgZone.new(topVal, botVal, startTimeVal, detectBarVal, isBullishVal, na, na, initHigh, initLow)
    if drawVisuals and canDraw
        zone.bx  := box.new(startTimeVal, topVal, time, botVal, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(pendColor, 80), border_width=0)
        zone.lbl := label.new(time, (topVal + botVal) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(pendColor, 0), size=size.small)
    zone

promoteBufferedZone(zone, pendColor, dailyAtrVal) =>
    promoted = makeZone(zone.top, zone.bot, zone.startTime, zone.detectBar, zone.isBullish, pendColor, zone.top - zone.bot, dailyAtrVal, true)
    promoted.rangeHigh := zone.rangeHigh
    promoted.rangeLow  := zone.rangeLow
    promoted

markZoneSelected(zone, sweepColor) =>
    if not na(zone.bx)
        box.set_bgcolor(zone.bx, color.new(sweepColor, 60))

findRecentZone(zones, curBarCount, maxLookback) =>
    FvgZone foundZone = na
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            zone = array.get(zones, i)
            barsAgo = curBarCount - zone.detectBar
            if barsAgo <= maxLookback
                foundZone := zone
                break
    foundZone

pruneRecentZones(zones, curBarCount, maxAge) =>
    idx = array.size(zones) - 1
    while idx >= 0
        zone = array.get(zones, idx)
        if curBarCount - zone.detectBar > maxAge
            array.remove(zones, idx)
        idx -= 1

// extendZones inlined at call sites — Pine v6 forbids mutating UDT fields through function args

longStopForBar(zone, curLow) =>
    math.min(na(zone.rangeLow) ? curLow : zone.rangeLow, curLow)

shortStopForBar(zone, curHigh) =>
    math.max(na(zone.rangeHigh) ? curHigh : zone.rangeHigh, curHigh)

// ============================================================================
// RESET ON SESSION START
// ============================================================================
if nyRTHStart
    array.clear(ny_bearFvgs)
    array.clear(ny_bullFvgs)
    array.clear(ny_recentBearFvgs)
    array.clear(ny_recentBullFvgs)
    ny_waitingForGap := false
    ny_waitingForInversion := false
    ny_armed     := false
    ny_inverted  := false
    ny_limitPrice := na
    ny_limitDir  := 0
    ny_limitZone := na
    ny_activeGap := na
    ny_barCount := 0
    ny_sweepBarIndex := na
    ny_inversionBarIndex := na
    ny_sweepDir := 0
    ny_sweepLevel := na
    ny_entry := na
    ny_stop  := na
    ny_tp1   := na
    ny_tp2   := na
    ny_dir   := 0
    ny_entryLine := na
    ny_stopLine  := na
    ny_tp1Line   := na
    ny_tp2Line   := na
    ny_stopLbl   := na
    ny_tp1Lbl    := na
    ny_tp2Lbl    := na

if asiaRTHStart
    array.clear(asia_bearFvgs)
    array.clear(asia_bullFvgs)
    array.clear(asia_recentBearFvgs)
    array.clear(asia_recentBullFvgs)
    asia_waitingForGap := false
    asia_waitingForInversion := false
    asia_armed     := false
    asia_inverted  := false
    asia_limitPrice := na
    asia_limitDir  := 0
    asia_limitZone := na
    asia_activeGap := na
    asia_barCount := 0
    asia_sweepBarIndex := na
    asia_inversionBarIndex := na
    asia_sweepDir := 0
    asia_sweepLevel := na
    asia_entry := na
    asia_stop  := na
    asia_tp1   := na
    asia_tp2   := na
    asia_dir   := 0
    asia_entryLine := na
    asia_stopLine  := na
    asia_tp1Line   := na
    asia_tp2Line   := na
    asia_stopLbl   := na
    asia_tp1Lbl    := na
    asia_tp2Lbl    := na

// ============================================================================
// FVG SIZE REQUIREMENTS (ATR-based only for LSI)
// ============================================================================
nyMinGap   = (nyMinGapPct / 100) * nz(nyDailyATR)
asiaMinGap = (asiaMinGapPct / 100) * nz(asiaDailyATR)

// ============================================================================
// FVG DETECTION (3-candle pattern, same as atlas_orb but NO ORB filter)
// Bullish FVG: gap between bar[2] high and bar[0] low (price gapped up)
// Bearish FVG: gap between bar[0] high and bar[2] low (price gapped down)
// ============================================================================
bullFvgTop  = l5       // low of "after" candle
bullFvgBot  = h5_2     // high of "before" candle
bullGapSize = bullFvgTop - bullFvgBot
isBullFvg   = h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5

bearFvgTop  = l5_2     // low of "before" candle
bearFvgBot  = h5       // high of "after" candle
bearGapSize = bearFvgTop - bearFvgBot
isBearFvg   = l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5

t5DayKey = year(t5, "America/New_York") * 10000 + month(t5, "America/New_York") * 100 + dayofmonth(t5, "America/New_York")

if barClosed5
    ny_barCount += 1
    asia_barCount += 1

    // --- NY swing state (inlined to preserve var state) ---
    if ny_swingDayKey != -1 and t5DayKey != ny_swingDayKey
        array.clear(ny_swingHighs)
        array.clear(ny_swingLows)
    ny_prevSwingHigh := ny_latestSwingHigh
    ny_prevSwingLow  := ny_latestSwingLow
    array.push(ny_swingHighs, h5)
    array.push(ny_swingLows, l5)
    nyWinSize = nySwingLeft + nySwingRight + 1
    if array.size(ny_swingHighs) > nyWinSize
        array.shift(ny_swingHighs)
        array.shift(ny_swingLows)
    if array.size(ny_swingHighs) == nyWinSize
        nyPivotHigh = array.get(ny_swingHighs, nySwingLeft)
        nyPivotLow  = array.get(ny_swingLows, nySwingLeft)
        nyIsSwHigh = true
        for i = 0 to nySwingLeft - 1
            if array.get(ny_swingHighs, i) >= nyPivotHigh
                nyIsSwHigh := false
                break
        if nyIsSwHigh
            for i = nySwingLeft + 1 to nyWinSize - 1
                if array.get(ny_swingHighs, i) >= nyPivotHigh
                    nyIsSwHigh := false
                    break
        nyIsSwLow = true
        for i = 0 to nySwingLeft - 1
            if array.get(ny_swingLows, i) <= nyPivotLow
                nyIsSwLow := false
                break
        if nyIsSwLow
            for i = nySwingLeft + 1 to nyWinSize - 1
                if array.get(ny_swingLows, i) <= nyPivotLow
                    nyIsSwLow := false
                    break
        if nyIsSwHigh
            ny_latestSwingHigh := nyPivotHigh
        if nyIsSwLow
            ny_latestSwingLow := nyPivotLow
    ny_swingDayKey := t5DayKey

    // --- Asia swing state (inlined to preserve var state) ---
    if asia_swingDayKey != -1 and t5DayKey != asia_swingDayKey
        array.clear(asia_swingHighs)
        array.clear(asia_swingLows)
    asia_prevSwingHigh := asia_latestSwingHigh
    asia_prevSwingLow  := asia_latestSwingLow
    array.push(asia_swingHighs, h5)
    array.push(asia_swingLows, l5)
    asiaWinSize = asiaSwingLeft + asiaSwingRight + 1
    if array.size(asia_swingHighs) > asiaWinSize
        array.shift(asia_swingHighs)
        array.shift(asia_swingLows)
    if array.size(asia_swingHighs) == asiaWinSize
        asiaPivotHigh = array.get(asia_swingHighs, asiaSwingLeft)
        asiaPivotLow  = array.get(asia_swingLows, asiaSwingLeft)
        asiaIsSwHigh = true
        for i = 0 to asiaSwingLeft - 1
            if array.get(asia_swingHighs, i) >= asiaPivotHigh
                asiaIsSwHigh := false
                break
        if asiaIsSwHigh
            for i = asiaSwingLeft + 1 to asiaWinSize - 1
                if array.get(asia_swingHighs, i) >= asiaPivotHigh
                    asiaIsSwHigh := false
                    break
        asiaIsSwLow = true
        for i = 0 to asiaSwingLeft - 1
            if array.get(asia_swingLows, i) <= asiaPivotLow
                asiaIsSwLow := false
                break
        if asiaIsSwLow
            for i = asiaSwingLeft + 1 to asiaWinSize - 1
                if array.get(asia_swingLows, i) <= asiaPivotLow
                    asiaIsSwLow := false
                    break
        if asiaIsSwHigh
            asia_latestSwingHigh := asiaPivotHigh
        if asiaIsSwLow
            asia_latestSwingLow := asiaPivotLow
    asia_swingDayKey := t5DayKey

// ============================================================================
// NY LSI FLOW
// ============================================================================
if barClosed5
    if enableNY and (ny_waitingForGap or ny_waitingForInversion or ny_inverted) and not inNyEntryWin
        ny_waitingForGap := false
        ny_waitingForInversion := false
        ny_inverted := false
        ny_limitPrice := na
        ny_limitDir := 0
        ny_limitZone := na
        ny_activeGap := na
        ny_sweepBarIndex := na
        ny_inversionBarIndex := na
        ny_sweepDir := 0
        ny_sweepLevel := na

    if enableNY and inNyEntryWin and nz(nyDailyATR) > 0 and not nySkipToday and not ny_armed
        nyScanning = not ny_waitingForGap and not ny_waitingForInversion and not ny_inverted
        if nyScanning
            if nyDetectLongs and isBearFvg and bearGapSize >= nyMinGap
                bearZone = makeZone(bearFvgTop, bearFvgBot, t5_2, ny_barCount, false, nyFvgPendColor, bearGapSize, nyDailyATR, false)
                array.push(ny_recentBearFvgs, bearZone)
            if nyDetectShorts and isBullFvg and bullGapSize >= nyMinGap
                bullZone = makeZone(bullFvgTop, bullFvgBot, t5_2, ny_barCount, true, nyFvgPendColor, bullGapSize, nyDailyATR, false)
                array.push(ny_recentBullFvgs, bullZone)
            pruneRecentZones(ny_recentBearFvgs, ny_barCount, nyFvgWindowLeft + nyFvgWindowRight)
            pruneRecentZones(ny_recentBullFvgs, ny_barCount, nyFvgWindowLeft + nyFvgWindowRight)
            sweepDirNow = 0
            float sweepLevelNow = na
            if nyDetectLongs and not na(ny_prevSwingLow) and l5 < ny_prevSwingLow
                sweepDirNow := 1
                sweepLevelNow := ny_prevSwingLow
            else if nyDetectShorts and not na(ny_prevSwingHigh) and h5 > ny_prevSwingHigh
                sweepDirNow := -1
                sweepLevelNow := ny_prevSwingHigh
            if sweepDirNow != 0
                ny_sweepDir := sweepDirNow
                ny_sweepLevel := sweepLevelNow
                ny_sweepBarIndex := ny_barCount
                promotedZone = sweepDirNow == 1 ? findRecentZone(ny_recentBearFvgs, ny_barCount, nyFvgWindowLeft) : findRecentZone(ny_recentBullFvgs, ny_barCount, nyFvgWindowLeft)
                if not na(promotedZone)
                    visibleZone = promoteBufferedZone(promotedZone, nyFvgPendColor, nyDailyATR)
                    ny_activeGap := visibleZone
                    if visibleZone.isBullish
                        array.push(ny_bullFvgs, visibleZone)
                    else
                        array.push(ny_bearFvgs, visibleZone)
                    ny_waitingForInversion := true
                    markZoneSelected(visibleZone, nyFvgSweptColor)
                else
                    ny_waitingForGap := true
        else if ny_waitingForGap
            barsSinceSweep = ny_barCount - nz(ny_sweepBarIndex, ny_barCount)
            if barsSinceSweep > nyFvgWindowRight
                ny_waitingForGap := false
                ny_activeGap := na
                ny_sweepBarIndex := na
                ny_sweepDir := 0
                ny_sweepLevel := na
            else
                if ny_sweepDir == 1 and nyDetectLongs and isBearFvg and bearGapSize >= nyMinGap
                    bearZone = makeZone(bearFvgTop, bearFvgBot, t5_2, ny_barCount, false, nyFvgPendColor, bearGapSize, nyDailyATR, true)
                    array.push(ny_bearFvgs, bearZone)
                    ny_activeGap := bearZone
                    ny_waitingForGap := false
                    ny_waitingForInversion := true
                    markZoneSelected(bearZone, nyFvgSweptColor)
                else if ny_sweepDir == -1 and nyDetectShorts and isBullFvg and bullGapSize >= nyMinGap
                    bullZone = makeZone(bullFvgTop, bullFvgBot, t5_2, ny_barCount, true, nyFvgPendColor, bullGapSize, nyDailyATR, true)
                    array.push(ny_bullFvgs, bullZone)
                    ny_activeGap := bullZone
                    ny_waitingForGap := false
                    ny_waitingForInversion := true
                    markZoneSelected(bullZone, nyFvgSweptColor)

        if ny_waitingForInversion and not na(ny_activeGap)
            gap = ny_activeGap
            if ny_barCount > gap.detectBar
                if not gap.isBullish and nyDetectLongs and c5 > gap.top
                    if nyIsFvgLimit
                        ny_waitingForInversion := false
                        ny_inverted := true
                        ny_limitPrice := gap.top
                        ny_limitDir := 1
                        ny_limitZone := gap
                        ny_inversionBarIndex := ny_barCount
                    else
                        ny_waitingForInversion := false
                        ny_armed := true
                        ny_dir := 1
                        ny_entry := c5
                        ny_stop := longStopForBar(gap, l5)
                        riskPts = ny_entry - ny_stop
                        ny_tp1 := ny_entry + (nyRR * riskPts * nyTp1Ratio)
                        ny_tp2 := ny_entry + (nyRR * riskPts)
                        ny_setupAlert := enableAlerts
                        if canDraw
                            [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(ny_entry, ny_stop, ny_tp1, ny_tp2, ny_dir, nyDailyATR, nyEntryWindow, "America/New_York")
                            ny_entryLine := eLine
                            ny_stopLine  := sLine
                            ny_tp1Line   := t1Line
                            ny_tp2Line   := t2Line
                            ny_stopLbl   := sLbl
                            ny_tp1Lbl    := t1Lbl
                            ny_tp2Lbl    := t2Lbl
                else if gap.isBullish and nyDetectShorts and c5 < gap.bot
                    if nyIsFvgLimit
                        ny_waitingForInversion := false
                        ny_inverted := true
                        ny_limitPrice := gap.bot
                        ny_limitDir := -1
                        ny_limitZone := gap
                        ny_inversionBarIndex := ny_barCount
                    else
                        ny_waitingForInversion := false
                        ny_armed := true
                        ny_dir := -1
                        ny_entry := c5
                        ny_stop := shortStopForBar(gap, h5)
                        riskPts = ny_stop - ny_entry
                        ny_tp1 := ny_entry - (nyRR * riskPts * nyTp1Ratio)
                        ny_tp2 := ny_entry - (nyRR * riskPts)
                        ny_setupAlert := enableAlerts
                        if canDraw
                            [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(ny_entry, ny_stop, ny_tp1, ny_tp2, ny_dir, nyDailyATR, nyEntryWindow, "America/New_York")
                            ny_entryLine := eLine
                            ny_stopLine  := sLine
                            ny_tp1Line   := t1Line
                            ny_tp2Line   := t2Line
                            ny_stopLbl   := sLbl
                            ny_tp1Lbl    := t1Lbl
                            ny_tp2Lbl    := t2Lbl

        if ny_inverted and not ny_armed and not na(ny_limitZone) and ny_barCount > nz(ny_inversionBarIndex, ny_barCount)
            isLong = ny_limitDir == 1
            filled = (isLong and l5 <= ny_limitPrice) or (not isLong and h5 >= ny_limitPrice)
            if filled
                zone = ny_limitZone
                ny_armed := true
                ny_inverted := false
                ny_dir := ny_limitDir
                ny_entry := ny_limitPrice
                if isLong
                    ny_stop := longStopForBar(zone, l5)
                    riskPts = ny_entry - ny_stop
                    ny_tp1 := ny_entry + (nyRR * riskPts * nyTp1Ratio)
                    ny_tp2 := ny_entry + (nyRR * riskPts)
                else
                    ny_stop := shortStopForBar(zone, h5)
                    riskPts = ny_stop - ny_entry
                    ny_tp1 := ny_entry - (nyRR * riskPts * nyTp1Ratio)
                    ny_tp2 := ny_entry - (nyRR * riskPts)
                ny_setupAlert := enableAlerts
                if canDraw
                    [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(ny_entry, ny_stop, ny_tp1, ny_tp2, ny_dir, nyDailyATR, nyEntryWindow, "America/New_York")
                    ny_entryLine := eLine
                    ny_stopLine  := sLine
                    ny_tp1Line   := t1Line
                    ny_tp2Line   := t2Line
                    ny_stopLbl   := sLbl
                    ny_tp1Lbl    := t1Lbl
                    ny_tp2Lbl    := t2Lbl

// ============================================================================
// ASIA LSI FLOW
// ============================================================================
if barClosed5
    if enableAsia and (asia_waitingForGap or asia_waitingForInversion or asia_inverted) and not inAsiaEntryWin
        asia_waitingForGap := false
        asia_waitingForInversion := false
        asia_inverted := false
        asia_limitPrice := na
        asia_limitDir := 0
        asia_limitZone := na
        asia_activeGap := na
        asia_sweepBarIndex := na
        asia_inversionBarIndex := na
        asia_sweepDir := 0
        asia_sweepLevel := na

    if enableAsia and inAsiaEntryWin and nz(asiaDailyATR) > 0 and not asiaSkipToday and not asia_armed
        asiaScanning = not asia_waitingForGap and not asia_waitingForInversion and not asia_inverted
        if asiaScanning
            if asiaDetectLongs and isBearFvg and bearGapSize >= asiaMinGap
                bearZone = makeZone(bearFvgTop, bearFvgBot, t5_2, asia_barCount, false, asiaFvgPendColor, bearGapSize, asiaDailyATR, false)
                array.push(asia_recentBearFvgs, bearZone)
            if asiaDetectShorts and isBullFvg and bullGapSize >= asiaMinGap
                bullZone = makeZone(bullFvgTop, bullFvgBot, t5_2, asia_barCount, true, asiaFvgPendColor, bullGapSize, asiaDailyATR, false)
                array.push(asia_recentBullFvgs, bullZone)
            pruneRecentZones(asia_recentBearFvgs, asia_barCount, asiaFvgWindowLeft + asiaFvgWindowRight)
            pruneRecentZones(asia_recentBullFvgs, asia_barCount, asiaFvgWindowLeft + asiaFvgWindowRight)
            sweepDirNow = 0
            float sweepLevelNow = na
            if asiaDetectLongs and not na(asia_prevSwingLow) and l5 < asia_prevSwingLow
                sweepDirNow := 1
                sweepLevelNow := asia_prevSwingLow
            else if asiaDetectShorts and not na(asia_prevSwingHigh) and h5 > asia_prevSwingHigh
                sweepDirNow := -1
                sweepLevelNow := asia_prevSwingHigh
            if sweepDirNow != 0
                asia_sweepDir := sweepDirNow
                asia_sweepLevel := sweepLevelNow
                asia_sweepBarIndex := asia_barCount
                promotedZone = sweepDirNow == 1 ? findRecentZone(asia_recentBearFvgs, asia_barCount, asiaFvgWindowLeft) : findRecentZone(asia_recentBullFvgs, asia_barCount, asiaFvgWindowLeft)
                if not na(promotedZone)
                    visibleZone = promoteBufferedZone(promotedZone, asiaFvgPendColor, asiaDailyATR)
                    asia_activeGap := visibleZone
                    if visibleZone.isBullish
                        array.push(asia_bullFvgs, visibleZone)
                    else
                        array.push(asia_bearFvgs, visibleZone)
                    asia_waitingForInversion := true
                    markZoneSelected(visibleZone, asiaFvgSweptColor)
                else
                    asia_waitingForGap := true
        else if asia_waitingForGap
            barsSinceSweep = asia_barCount - nz(asia_sweepBarIndex, asia_barCount)
            if barsSinceSweep > asiaFvgWindowRight
                asia_waitingForGap := false
                asia_activeGap := na
                asia_sweepBarIndex := na
                asia_sweepDir := 0
                asia_sweepLevel := na
            else
                if asia_sweepDir == 1 and asiaDetectLongs and isBearFvg and bearGapSize >= asiaMinGap
                    bearZone = makeZone(bearFvgTop, bearFvgBot, t5_2, asia_barCount, false, asiaFvgPendColor, bearGapSize, asiaDailyATR, true)
                    array.push(asia_bearFvgs, bearZone)
                    asia_activeGap := bearZone
                    asia_waitingForGap := false
                    asia_waitingForInversion := true
                    markZoneSelected(bearZone, asiaFvgSweptColor)
                else if asia_sweepDir == -1 and asiaDetectShorts and isBullFvg and bullGapSize >= asiaMinGap
                    bullZone = makeZone(bullFvgTop, bullFvgBot, t5_2, asia_barCount, true, asiaFvgPendColor, bullGapSize, asiaDailyATR, true)
                    array.push(asia_bullFvgs, bullZone)
                    asia_activeGap := bullZone
                    asia_waitingForGap := false
                    asia_waitingForInversion := true
                    markZoneSelected(bullZone, asiaFvgSweptColor)

        if asia_waitingForInversion and not na(asia_activeGap)
            gap = asia_activeGap
            if asia_barCount > gap.detectBar
                if not gap.isBullish and asiaDetectLongs and c5 > gap.top
                    if asiaIsFvgLimit
                        asia_waitingForInversion := false
                        asia_inverted := true
                        asia_limitPrice := gap.top
                        asia_limitDir := 1
                        asia_limitZone := gap
                        asia_inversionBarIndex := asia_barCount
                    else
                        asia_waitingForInversion := false
                        asia_armed := true
                        asia_dir := 1
                        asia_entry := c5
                        asia_stop := longStopForBar(gap, l5)
                        riskPts = asia_entry - asia_stop
                        asia_tp1 := asia_entry + (asiaRR * riskPts * asiaTp1Ratio)
                        asia_tp2 := asia_entry + (asiaRR * riskPts)
                        asia_setupAlert := enableAlerts
                        if canDraw
                            [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(asia_entry, asia_stop, asia_tp1, asia_tp2, asia_dir, asiaDailyATR, asiaEntryWindow, "America/New_York")
                            asia_entryLine := eLine
                            asia_stopLine  := sLine
                            asia_tp1Line   := t1Line
                            asia_tp2Line   := t2Line
                            asia_stopLbl   := sLbl
                            asia_tp1Lbl    := t1Lbl
                            asia_tp2Lbl    := t2Lbl
                else if gap.isBullish and asiaDetectShorts and c5 < gap.bot
                    if asiaIsFvgLimit
                        asia_waitingForInversion := false
                        asia_inverted := true
                        asia_limitPrice := gap.bot
                        asia_limitDir := -1
                        asia_limitZone := gap
                        asia_inversionBarIndex := asia_barCount
                    else
                        asia_waitingForInversion := false
                        asia_armed := true
                        asia_dir := -1
                        asia_entry := c5
                        asia_stop := shortStopForBar(gap, h5)
                        riskPts = asia_stop - asia_entry
                        asia_tp1 := asia_entry - (asiaRR * riskPts * asiaTp1Ratio)
                        asia_tp2 := asia_entry - (asiaRR * riskPts)
                        asia_setupAlert := enableAlerts
                        if canDraw
                            [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(asia_entry, asia_stop, asia_tp1, asia_tp2, asia_dir, asiaDailyATR, asiaEntryWindow, "America/New_York")
                            asia_entryLine := eLine
                            asia_stopLine  := sLine
                            asia_tp1Line   := t1Line
                            asia_tp2Line   := t2Line
                            asia_stopLbl   := sLbl
                            asia_tp1Lbl    := t1Lbl
                            asia_tp2Lbl    := t2Lbl

        if asia_inverted and not asia_armed and not na(asia_limitZone) and asia_barCount > nz(asia_inversionBarIndex, asia_barCount)
            isLong = asia_limitDir == 1
            filled = (isLong and l5 <= asia_limitPrice) or (not isLong and h5 >= asia_limitPrice)
            if filled
                zone = asia_limitZone
                asia_armed := true
                asia_inverted := false
                asia_dir := asia_limitDir
                asia_entry := asia_limitPrice
                if isLong
                    asia_stop := longStopForBar(zone, l5)
                    riskPts = asia_entry - asia_stop
                    asia_tp1 := asia_entry + (asiaRR * riskPts * asiaTp1Ratio)
                    asia_tp2 := asia_entry + (asiaRR * riskPts)
                else
                    asia_stop := shortStopForBar(zone, h5)
                    riskPts = asia_stop - asia_entry
                    asia_tp1 := asia_entry - (asiaRR * riskPts * asiaTp1Ratio)
                    asia_tp2 := asia_entry - (asiaRR * riskPts)
                asia_setupAlert := enableAlerts
                if canDraw
                    [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(asia_entry, asia_stop, asia_tp1, asia_tp2, asia_dir, asiaDailyATR, asiaEntryWindow, "America/New_York")
                    asia_entryLine := eLine
                    asia_stopLine  := sLine
                    asia_tp1Line   := t1Line
                    asia_tp2Line   := t2Line
                    asia_stopLbl   := sLbl
                    asia_tp1Lbl    := t1Lbl
                    asia_tp2Lbl    := t2Lbl

// ============================================================================
// EXTEND FVG BOXES + LABELS + RANGE TRACKING
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin
    if array.size(ny_recentBearFvgs) > 0
        for i = 0 to array.size(ny_recentBearFvgs) - 1
            zone = array.get(ny_recentBearFvgs, i)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)
    if array.size(ny_recentBullFvgs) > 0
        for i = 0 to array.size(ny_recentBullFvgs) - 1
            zone = array.get(ny_recentBullFvgs, i)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)
    if array.size(ny_bearFvgs) > 0
        for i = 0 to array.size(ny_bearFvgs) - 1
            zone = array.get(ny_bearFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)
    if array.size(ny_bullFvgs) > 0
        for i = 0 to array.size(ny_bullFvgs) - 1
            zone = array.get(ny_bullFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)

if enableAsia and inAsiaRTH and inAsiaEntryWin
    if array.size(asia_recentBearFvgs) > 0
        for i = 0 to array.size(asia_recentBearFvgs) - 1
            zone = array.get(asia_recentBearFvgs, i)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)
    if array.size(asia_recentBullFvgs) > 0
        for i = 0 to array.size(asia_recentBullFvgs) - 1
            zone = array.get(asia_recentBullFvgs, i)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)
    if array.size(asia_bearFvgs) > 0
        for i = 0 to array.size(asia_bearFvgs) - 1
            zone = array.get(asia_bearFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)
    if array.size(asia_bullFvgs) > 0
        for i = 0 to array.size(asia_bullFvgs) - 1
            zone = array.get(asia_bullFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh, h5), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, l5), l5)

// ============================================================================
// EXTEND TRADE LEVEL LINES + LABELS
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin and not na(ny_entryLine)
    line.set_x2(ny_entryLine, math.max(time, line.get_x2(ny_entryLine)))
    line.set_x2(ny_stopLine, math.max(time, line.get_x2(ny_stopLine)))
    line.set_x2(ny_tp1Line, math.max(time, line.get_x2(ny_tp1Line)))
    line.set_x2(ny_tp2Line, math.max(time, line.get_x2(ny_tp2Line)))
    label.set_x(ny_stopLbl, math.max(time, label.get_x(ny_stopLbl)))
    label.set_x(ny_tp1Lbl, math.max(time, label.get_x(ny_tp1Lbl)))
    label.set_x(ny_tp2Lbl, math.max(time, label.get_x(ny_tp2Lbl)))

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_entryLine)
    line.set_x2(asia_entryLine, math.max(time, line.get_x2(asia_entryLine)))
    line.set_x2(asia_stopLine, math.max(time, line.get_x2(asia_stopLine)))
    line.set_x2(asia_tp1Line, math.max(time, line.get_x2(asia_tp1Line)))
    line.set_x2(asia_tp2Line, math.max(time, line.get_x2(asia_tp2Line)))
    label.set_x(asia_stopLbl, math.max(time, label.get_x(asia_stopLbl)))
    label.set_x(asia_tp1Lbl, math.max(time, label.get_x(asia_tp1Lbl)))
    label.set_x(asia_tp2Lbl, math.max(time, label.get_x(asia_tp2Lbl)))

// ============================================================================
// ALERTS - fire when a new LSI setup is armed
// ============================================================================
nyDirStr   = ny_dir == 1 ? "Long" : "Short"
asiaDirStr = asia_dir == 1 ? "Long" : "Short"

if ny_setupAlert
    alert(asset + " NY " + nyDirStr + " armed @ " + str.tostring(ny_entry, format.mintick) + " | SL " + str.tostring(ny_stop, format.mintick) + " | TP1 " + str.tostring(ny_tp1, format.mintick) + " | TP2 " + str.tostring(ny_tp2, format.mintick), alert.freq_once_per_bar_close)

if asia_setupAlert
    alert(asset + " Asia " + asiaDirStr + " armed @ " + str.tostring(asia_entry, format.mintick) + " | SL " + str.tostring(asia_stop, format.mintick) + " | TP1 " + str.tostring(asia_tp1, format.mintick) + " | TP2 " + str.tostring(asia_tp2, format.mintick), alert.freq_once_per_bar_close)

alertcondition(ny_setupAlert,   "NY LSI Setup",   "NY LSI setup armed")
alertcondition(asia_setupAlert, "Asia LSI Setup", "Asia LSI setup armed")
alertcondition(ny_setupAlert or asia_setupAlert, "Any LSI Setup", "LSI setup armed")
