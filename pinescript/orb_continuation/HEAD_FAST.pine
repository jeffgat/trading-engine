//@version=6
strategy(
     title              = "HEAD_FAST — ORB Continuation [atlasfutures]",
     overlay            = true,
     initial_capital    = 500000,
     pyramiding         = 6,
     margin_long        = 0,
     margin_short       = 0,
     commission_type    = strategy.commission.cash_per_contract,
     commission_value   = 0.05,
     calc_on_every_tick = true,
     process_orders_on_close = true,
     use_bar_magnifier  = true,
     fill_orders_on_standard_ohlc = false
)

// ============================================================================
// AUTO-DETECT ASSET from chart symbol
// ============================================================================
asset = if syminfo.root == "ES" or syminfo.root == "MES"
    "ES"
else if syminfo.root == "NQ" or syminfo.root == "MNQ"
    "NQ"
else if syminfo.root == "GC" or syminfo.root == "MGC"
    "GC"
else
    "ES"

// ============================================================================
// INPUTS - Risk Settings
// ============================================================================
i_riskUsd    = input.float(5000.0, "Risk per Trade ($)", step=100, minval=1, group="Risk Settings")
i_pointValue = input.float(20.0, "Point Value ($)", step=1, tooltip="Dollar value per point. NQ=20, MNQ=2, ES=50, MES=5, GC=100, MGC=10", group="Risk Settings")
i_minQty     = input.float(1.0, "Min Qty", step=1, group="Risk Settings")
i_qtyStep    = input.float(1.0, "Qty Step", step=1, group="Risk Settings")

// ============================================================================
// INPUTS - NQ: NY
// ============================================================================
i_nqNyOrbSession   = input.session("0930-0950", "ORB Window (ny time)", group="NQ: NY")
i_nqNyEntryWindow  = input.session("0950-1200", "Entry Window (ny time)", group="NQ: NY")
i_nqNyDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: NY")
i_nqNyImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="NQ: NY")
i_nqNyRR           = input.float(3.5, "Reward/Risk", step=0.25, group="NQ: NY")
i_nqNyTp1Ratio     = input.float(0.4, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: NY")
i_nqNyStopMode     = input.string("ATR", "Stop Size Mode", options=["ATR", "ORB"], group="NQ: NY")
i_nqNyAtrLength    = input.int(12, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="NQ: NY")
i_nqNyStopPct      = input.float(7.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="NQ: NY")
i_nqNyMinGapPct    = input.float(2.5, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="NQ: NY")

// ============================================================================
// INPUTS - NQ: Asia
// ============================================================================
i_nqAsiaOrbSession   = input.session("2000-2015", "ORB Window (ny time)", group="NQ: Asia")
i_nqAsiaEntryWindow  = input.session("2015-2230", "Entry Window (ny time)", group="NQ: Asia")
i_nqAsiaDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: Asia")
i_nqAsiaImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="NQ: Asia")
i_nqAsiaRR           = input.float(6.0, "Reward/Risk", step=0.25, group="NQ: Asia")
i_nqAsiaTp1Ratio     = input.float(0.3, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: Asia")
i_nqAsiaStopMode     = input.string("ORB", "Stop Size Mode", options=["ATR", "ORB"], group="NQ: Asia")
i_nqAsiaAtrLength    = input.int(5, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="NQ: Asia")
i_nqAsiaStopPct      = input.float(100.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="NQ: Asia")
i_nqAsiaMinGapPct    = input.float(10.0, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="NQ: Asia")

// ============================================================================
// INPUTS - GC: NY
// ============================================================================
i_gcOrbSession   = input.session("0930-0940", "ORB Window (ny time)", group="GC: NY")
i_gcEntryWindow  = input.session("0940-1200", "Entry Window (ny time)", group="GC: NY")
i_gcDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="GC: NY")
i_gcImpulseClose = input.bool(true, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="GC: NY")
i_gcRR           = input.float(9.0, "Reward/Risk", step=0.25, group="GC: NY")
i_gcTp1Ratio     = input.float(0.35, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="GC: NY")
i_gcStopMode     = input.string("ATR", "Stop Size Mode", options=["ATR", "ORB"], group="GC: NY")
i_gcAtrLength    = input.int(7, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="GC: NY")
i_gcStopPct      = input.float(4.5, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="GC: NY")
i_gcMinGapPct    = input.float(3.0, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="GC: NY")

// ============================================================================
// INPUTS - ES: NY
// ============================================================================
i_esNyOrbSession   = input.session("0930-0945", "ORB Window (ny time)", group="ES: NY")
i_esNyEntryWindow  = input.session("0945-1300", "Entry Window (ny time)", group="ES: NY")
i_esNyDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="ES: NY")
i_esNyImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="ES: NY")
i_esNyRR           = input.float(5.0, "Reward/Risk", step=0.25, group="ES: NY")
i_esNyTp1Ratio     = input.float(0.2, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="ES: NY")
i_esNyStopMode     = input.string("ATR", "Stop Size Mode", options=["ATR", "ORB"], group="ES: NY")
i_esNyAtrLength    = input.int(7, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="ES: NY")
i_esNyStopPct      = input.float(5.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="ES: NY")
i_esNyMinGapPct    = input.float(0.25, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="ES: NY")

// ============================================================================
// INPUTS - ES: Asia
// ============================================================================
i_esAsiaOrbSession   = input.session("2000-2015", "ORB Window (ny time)", group="ES: Asia")
i_esAsiaEntryWindow  = input.session("2015-0300", "Entry Window (ny time)", group="ES: Asia")
i_esAsiaDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="ES: Asia")
i_esAsiaImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="ES: Asia")
i_esAsiaRR           = input.float(1.5, "Reward/Risk", step=0.25, group="ES: Asia")
i_esAsiaTp1Ratio     = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="ES: Asia")
i_esAsiaStopMode     = input.string("ORB", "Stop Size Mode", options=["ATR", "ORB"], group="ES: Asia")
i_esAsiaAtrLength    = input.int(14, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="ES: Asia")
i_esAsiaStopPct      = input.float(125.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="ES: Asia")
i_esAsiaMinGapPct    = input.float(0.5, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="ES: Asia")

// ============================================================================
// INPUTS - NQ: LDN
// ============================================================================
i_nqLdnOrbSession   = input.session("0300-0330", "ORB Window (ny time)", group="NQ: LDN")
i_nqLdnEntryWindow  = input.session("0330-0825", "Entry Window (ny time)", group="NQ: LDN")
i_nqLdnDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: LDN")
i_nqLdnImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="NQ: LDN")
i_nqLdnRR           = input.float(6.0, "Reward/Risk", step=0.25, group="NQ: LDN")
i_nqLdnTp1Ratio     = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: LDN")
i_nqLdnStopMode     = input.string("ATR", "Stop Size Mode", options=["ATR", "ORB"], group="NQ: LDN")
i_nqLdnAtrLength    = input.int(10, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="NQ: LDN")
i_nqLdnStopPct      = input.float(1.5, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="NQ: LDN")
i_nqLdnMinGapPct    = input.float(1.0, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="NQ: LDN")

// ============================================================================
// INPUTS - Skip Days - NQ: NY  (FAST: excl Friday)
// ============================================================================
i_nqNySkipMon = input.bool(false, "Skip Monday",    group="NQ: NY Skip Days")
i_nqNySkipTue = input.bool(false, "Skip Tuesday",   group="NQ: NY Skip Days")
i_nqNySkipWed = input.bool(false, "Skip Wednesday", group="NQ: NY Skip Days")
i_nqNySkipThu = input.bool(false, "Skip Thursday",  group="NQ: NY Skip Days")
i_nqNySkipFri = input.bool(true,  "Skip Friday",    group="NQ: NY Skip Days")

// ============================================================================
// INPUTS - Skip Days - NQ: Asia  (FAST: excl Tuesday)
// ============================================================================
i_nqAsiaSkipMon = input.bool(false, "Skip Monday",    group="NQ: Asia Skip Days")
i_nqAsiaSkipTue = input.bool(true,  "Skip Tuesday",   group="NQ: Asia Skip Days")
i_nqAsiaSkipWed = input.bool(false, "Skip Wednesday", group="NQ: Asia Skip Days")
i_nqAsiaSkipThu = input.bool(false, "Skip Thursday",  group="NQ: Asia Skip Days")
i_nqAsiaSkipFri = input.bool(false, "Skip Friday",    group="NQ: Asia Skip Days")

// ============================================================================
// INPUTS - Skip Days - GC: NY  (FAST: excl Friday)
// ============================================================================
i_gcNySkipMon = input.bool(false, "Skip Monday",    group="GC: NY Skip Days")
i_gcNySkipTue = input.bool(false, "Skip Tuesday",   group="GC: NY Skip Days")
i_gcNySkipWed = input.bool(false, "Skip Wednesday", group="GC: NY Skip Days")
i_gcNySkipThu = input.bool(false, "Skip Thursday",  group="GC: NY Skip Days")
i_gcNySkipFri = input.bool(true,  "Skip Friday",    group="GC: NY Skip Days")

// ============================================================================
// INPUTS - Skip Days - ES: NY  (FAST: excl Thursday)
// ============================================================================
i_esNySkipMon = input.bool(false, "Skip Monday",    group="ES: NY Skip Days")
i_esNySkipTue = input.bool(false, "Skip Tuesday",   group="ES: NY Skip Days")
i_esNySkipWed = input.bool(false, "Skip Wednesday", group="ES: NY Skip Days")
i_esNySkipThu = input.bool(true,  "Skip Thursday",  group="ES: NY Skip Days")
i_esNySkipFri = input.bool(false, "Skip Friday",    group="ES: NY Skip Days")

// ============================================================================
// INPUTS - Skip Days - ES: Asia  (FAST: no exclusion)
// ============================================================================
i_esAsiaSkipMon = input.bool(false, "Skip Monday",    group="ES: Asia Skip Days")
i_esAsiaSkipTue = input.bool(false, "Skip Tuesday",   group="ES: Asia Skip Days")
i_esAsiaSkipWed = input.bool(false, "Skip Wednesday", group="ES: Asia Skip Days")
i_esAsiaSkipThu = input.bool(false, "Skip Thursday",  group="ES: Asia Skip Days")
i_esAsiaSkipFri = input.bool(false, "Skip Friday",    group="ES: Asia Skip Days")

// ============================================================================
// INPUTS - Skip Days - NQ: LDN  (FAST: no exclusion, G5 gated externally)
// ============================================================================
i_nqLdnSkipMon = input.bool(false, "Skip Monday",    group="NQ: LDN Skip Days")
i_nqLdnSkipTue = input.bool(false, "Skip Tuesday",   group="NQ: LDN Skip Days")
i_nqLdnSkipWed = input.bool(false, "Skip Wednesday", group="NQ: LDN Skip Days")
i_nqLdnSkipThu = input.bool(false, "Skip Thursday",  group="NQ: LDN Skip Days")
i_nqLdnSkipFri = input.bool(false, "Skip Friday",    group="NQ: LDN Skip Days")

// ============================================================================
// RESOLVE ACTIVE CONFIG — FAST ORB legs
//   NQ: NY, Asia, LDN  (when chart = NQ/MNQ)
//   GC: NY              (when chart = GC/MGC)
//   ES: NY, Asia        (when chart = ES/MES)
// ============================================================================
enableNqNY    = asset == "NQ"
enableNqAsia  = asset == "NQ"
enableNqLdn   = asset == "NQ"
enableGcNY    = asset == "GC"
enableEsNY    = asset == "ES"
enableEsAsia  = asset == "ES"

// Session RTH (fixed)
nySessionRTH   = "0930-1600"
asiaSessionRTH = "1800-0700"
ldnSessionRTH  = "0200-0930"

// ============================================================================
// RESOLVE PER-LEG PARAMS based on asset
// ============================================================================

// --- NY session ---
nyOrbSession = if asset == "NQ"
    i_nqNyOrbSession
else if asset == "GC"
    i_gcOrbSession
else
    i_esNyOrbSession

nyEntryWindow = if asset == "NQ"
    i_nqNyEntryWindow
else if asset == "GC"
    i_gcEntryWindow
else
    i_esNyEntryWindow

nyDirection = if asset == "NQ"
    i_nqNyDirection
else if asset == "GC"
    i_gcDirection
else
    i_esNyDirection

nyRR = if asset == "NQ"
    i_nqNyRR
else if asset == "GC"
    i_gcRR
else
    i_esNyRR

nyTp1Ratio = if asset == "NQ"
    i_nqNyTp1Ratio
else if asset == "GC"
    i_gcTp1Ratio
else
    i_esNyTp1Ratio

nyImpulseClose = if asset == "NQ"
    i_nqNyImpulseClose
else if asset == "GC"
    i_gcImpulseClose
else
    i_esNyImpulseClose

nyStopMode = if asset == "NQ"
    i_nqNyStopMode
else if asset == "GC"
    i_gcStopMode
else
    i_esNyStopMode

nyStopPct = if asset == "NQ"
    i_nqNyStopPct
else if asset == "GC"
    i_gcStopPct
else
    i_esNyStopPct

nyMinGapPct = if asset == "NQ"
    i_nqNyMinGapPct
else if asset == "GC"
    i_gcMinGapPct
else
    i_esNyMinGapPct

nyAtrLength = if asset == "NQ"
    i_nqNyAtrLength
else if asset == "GC"
    i_gcAtrLength
else
    i_esNyAtrLength

// --- Asia session ---
asiaOrbSession = if asset == "NQ"
    i_nqAsiaOrbSession
else
    i_esAsiaOrbSession

asiaEntryWindow = if asset == "NQ"
    i_nqAsiaEntryWindow
else
    i_esAsiaEntryWindow

asiaDirection = if asset == "NQ"
    i_nqAsiaDirection
else
    i_esAsiaDirection

asiaRR = if asset == "NQ"
    i_nqAsiaRR
else
    i_esAsiaRR

asiaTp1Ratio = if asset == "NQ"
    i_nqAsiaTp1Ratio
else
    i_esAsiaTp1Ratio

asiaImpulseClose = if asset == "NQ"
    i_nqAsiaImpulseClose
else
    i_esAsiaImpulseClose

asiaStopMode = if asset == "NQ"
    i_nqAsiaStopMode
else
    i_esAsiaStopMode

asiaStopPct = if asset == "NQ"
    i_nqAsiaStopPct
else
    i_esAsiaStopPct

asiaMinGapPct = if asset == "NQ"
    i_nqAsiaMinGapPct
else
    i_esAsiaMinGapPct

asiaAtrLength = if asset == "NQ"
    i_nqAsiaAtrLength
else
    i_esAsiaAtrLength

// --- LDN session (NQ only) ---
ldnOrbSession   = i_nqLdnOrbSession
ldnEntryWindow  = i_nqLdnEntryWindow
ldnDirection    = i_nqLdnDirection
ldnRR           = i_nqLdnRR
ldnTp1Ratio     = i_nqLdnTp1Ratio
ldnImpulseClose = i_nqLdnImpulseClose
ldnStopMode     = i_nqLdnStopMode
ldnStopPct      = i_nqLdnStopPct
ldnMinGapPct    = i_nqLdnMinGapPct
ldnAtrLength    = i_nqLdnAtrLength

// ============================================================================
// SESSION FILTERS — use "5" resolution for correct detection on higher TFs
// ============================================================================
inNyRTH      = not na(time("5", nySessionRTH, "America/New_York"))
inNyORB      = not na(time("5", nyOrbSession, "America/New_York"))
inNyEntryWin = not na(time("5", nyEntryWindow, "America/New_York"))
inAsiaRTH      = not na(time("5", asiaSessionRTH, "America/New_York"))
inAsiaORB      = not na(time("5", asiaOrbSession, "America/New_York"))
inAsiaEntryWin = not na(time("5", asiaEntryWindow, "America/New_York"))
inLdnRTH      = not na(time("5", ldnSessionRTH, "America/New_York"))
inLdnORB      = not na(time("5", ldnOrbSession, "America/New_York"))
inLdnEntryWin = not na(time("5", ldnEntryWindow, "America/New_York"))

// ============================================================================
// DOW SKIP FLAGS
// ============================================================================
dow = dayofweek(time, "America/New_York")

nySkipToday = if asset == "NQ"
    (dow == dayofweek.monday    and i_nqNySkipMon)
  or (dow == dayofweek.tuesday   and i_nqNySkipTue)
  or (dow == dayofweek.wednesday and i_nqNySkipWed)
  or (dow == dayofweek.thursday  and i_nqNySkipThu)
  or (dow == dayofweek.friday    and i_nqNySkipFri)
else if asset == "GC"
    (dow == dayofweek.monday    and i_gcNySkipMon)
  or (dow == dayofweek.tuesday   and i_gcNySkipTue)
  or (dow == dayofweek.wednesday and i_gcNySkipWed)
  or (dow == dayofweek.thursday  and i_gcNySkipThu)
  or (dow == dayofweek.friday    and i_gcNySkipFri)
else if asset == "ES"
    (dow == dayofweek.monday    and i_esNySkipMon)
  or (dow == dayofweek.tuesday   and i_esNySkipTue)
  or (dow == dayofweek.wednesday and i_esNySkipWed)
  or (dow == dayofweek.thursday  and i_esNySkipThu)
  or (dow == dayofweek.friday    and i_esNySkipFri)
else
    false

asiaSkipToday = if asset == "NQ"
    (dow == dayofweek.monday    and i_nqAsiaSkipMon)
  or (dow == dayofweek.tuesday   and i_nqAsiaSkipTue)
  or (dow == dayofweek.wednesday and i_nqAsiaSkipWed)
  or (dow == dayofweek.thursday  and i_nqAsiaSkipThu)
  or (dow == dayofweek.friday    and i_nqAsiaSkipFri)
else if asset == "ES"
    (dow == dayofweek.monday    and i_esAsiaSkipMon)
  or (dow == dayofweek.tuesday   and i_esAsiaSkipTue)
  or (dow == dayofweek.wednesday and i_esAsiaSkipWed)
  or (dow == dayofweek.thursday  and i_esAsiaSkipThu)
  or (dow == dayofweek.friday    and i_esAsiaSkipFri)
else
    false

ldnSkipToday = (dow == dayofweek.monday    and i_nqLdnSkipMon)
  or (dow == dayofweek.tuesday   and i_nqLdnSkipTue)
  or (dow == dayofweek.wednesday and i_nqLdnSkipWed)
  or (dow == dayofweek.thursday  and i_nqLdnSkipThu)
  or (dow == dayofweek.friday    and i_nqLdnSkipFri)

// ============================================================================
// 5m OHLC — stable confirmed data via lookahead_on + [1] offset
// ============================================================================
regTicker = ticker.new(syminfo.prefix, syminfo.ticker, session.regular)
[h5, l5, h5_1, l5_1, h5_2, l5_2, c5_1, o5_1, t5, t5_2] = request.security(regTicker, "5", [high[1], low[1], high[2], low[2], high[3], low[3], close[2], open[2], time[1], time[3]], lookahead=barmerge.lookahead_on)
barClosed5 = ta.change(t5) != 0

// ORB OHLC — current bar data (no [1] shift) for building the ORB range
[orbH5, orbL5, orbC5, orbT5] = request.security(regTicker, "5", [high, low, close, time], lookahead=barmerge.lookahead_on)
orbBarClosed5 = ta.change(orbT5) != 0

// Session start detection (rising edge of session filter)
nyRTHStart   = inNyRTH and not inNyRTH[1]
asiaRTHStart = inAsiaRTH and not inAsiaRTH[1]
ldnRTHStart  = inLdnRTH and not inLdnRTH[1]

// ============================================================================
// DIRECTION FLAGS
// ============================================================================
nyDetectLongs    = nyDirection != "Short Only"
nyDetectShorts   = nyDirection != "Long Only"
asiaDetectLongs  = asiaDirection != "Short Only"
asiaDetectShorts = asiaDirection != "Long Only"
ldnDetectLongs   = ldnDirection != "Short Only"
ldnDetectShorts  = ldnDirection != "Long Only"

// ============================================================================
// POSITION SIZING HELPER
// ============================================================================
floorToStep(value, step) =>
    math.max(math.floor(value / step) * step, step)

// ============================================================================
// NY ORB STATE
// ============================================================================
var float ny_orbHigh = na
var float ny_orbLow  = na
var bool  ny_orbReady = false
var bool  ny_longFirstFvgFound  = false
var bool  ny_shortFirstFvgFound = false

// ============================================================================
// ASIA ORB STATE
// ============================================================================
var float asia_orbHigh = na
var float asia_orbLow  = na
var bool  asia_orbReady = false
var bool  asia_longFirstFvgFound  = false
var bool  asia_shortFirstFvgFound = false

// ============================================================================
// LDN ORB STATE
// ============================================================================
var float ldn_orbHigh = na
var float ldn_orbLow  = na
var bool  ldn_orbReady = false
var bool  ldn_longFirstFvgFound  = false
var bool  ldn_shortFirstFvgFound = false

// ============================================================================
// TRADE STATE — track which session trades are active for exit management
// ============================================================================
var bool ny_longArmed   = false
var bool ny_shortArmed  = false
var bool asia_longArmed  = false
var bool asia_shortArmed = false
var bool ldn_longArmed   = false
var bool ldn_shortArmed  = false

// ============================================================================
// RESET ON SESSION START
// ============================================================================
if nyRTHStart
    ny_orbHigh := na
    ny_orbLow  := na
    ny_orbReady := false
    ny_longFirstFvgFound := false
    ny_shortFirstFvgFound := false
    ny_longArmed  := false
    ny_shortArmed := false

if asiaRTHStart
    asia_orbHigh := na
    asia_orbLow  := na
    asia_orbReady := false
    asia_longFirstFvgFound := false
    asia_shortFirstFvgFound := false
    asia_longArmed  := false
    asia_shortArmed := false

if ldnRTHStart
    ldn_orbHigh := na
    ldn_orbLow  := na
    ldn_orbReady := false
    ldn_longFirstFvgFound := false
    ldn_shortFirstFvgFound := false
    ldn_longArmed  := false
    ldn_shortArmed := false

// ============================================================================
// BUILD ORB - NY
// ============================================================================
enableNY = enableNqNY or enableGcNY or enableEsNY
if enableNY and orbBarClosed5 and inNyORB and inNyRTH
    ny_orbHigh := na(ny_orbHigh) ? orbH5 : math.max(ny_orbHigh, orbH5)
    ny_orbLow  := na(ny_orbLow)  ? orbL5 : math.min(ny_orbLow, orbL5)

if enableNY and orbBarClosed5 and not inNyORB and inNyRTH and not ny_orbReady and not na(ny_orbHigh) and not na(ny_orbLow)
    ny_orbReady := true

// ============================================================================
// BUILD ORB - ASIA
// ============================================================================
enableAsia = enableNqAsia or enableEsAsia
if enableAsia and orbBarClosed5 and inAsiaORB and inAsiaRTH
    asia_orbHigh := na(asia_orbHigh) ? orbH5 : math.max(asia_orbHigh, orbH5)
    asia_orbLow  := na(asia_orbLow)  ? orbL5 : math.min(asia_orbLow, orbL5)

if enableAsia and orbBarClosed5 and not inAsiaORB and inAsiaRTH and not asia_orbReady and not na(asia_orbHigh) and not na(asia_orbLow)
    asia_orbReady := true

// ============================================================================
// BUILD ORB - LDN
// ============================================================================
if enableNqLdn and orbBarClosed5 and inLdnORB and inLdnRTH
    ldn_orbHigh := na(ldn_orbHigh) ? orbH5 : math.max(ldn_orbHigh, orbH5)
    ldn_orbLow  := na(ldn_orbLow)  ? orbL5 : math.min(ldn_orbLow, orbL5)

if enableNqLdn and orbBarClosed5 and not inLdnORB and inLdnRTH and not ldn_orbReady and not na(ldn_orbHigh) and not na(ldn_orbLow)
    ldn_orbReady := true

// ============================================================================
// CUSTOM DAILY ATR — midnight-ET boundaries (matches Python engine exactly)
// ============================================================================
atr_curDay = dayofmonth(orbT5, "America/New_York")

var float atr_dayHigh   = na
var float atr_dayLow    = na
var float atr_dayClose  = na
var int   atr_lastDay   = -1
var float atr_lastClose = na

// Separate ATR accumulators for each ATR length used across legs
var float ny_atr_value    = na
var float ny_atr_building = na
var int   ny_atr_count    = 0
var array<float> ny_atr_trHist = array.new<float>(0)

var float asia_atr_value    = na
var float asia_atr_building = na
var int   asia_atr_count    = 0
var array<float> asia_atr_trHist = array.new<float>(0)

var float ldn_atr_value    = na
var float ldn_atr_building = na
var int   ldn_atr_count    = 0
var array<float> ldn_atr_trHist = array.new<float>(0)

if orbBarClosed5
    if atr_lastDay != -1 and atr_curDay != atr_lastDay and not na(atr_dayHigh)
        if not na(atr_lastClose)
            tr = math.max(atr_dayHigh - atr_dayLow, math.max(math.abs(atr_dayHigh - atr_lastClose), math.abs(atr_dayLow - atr_lastClose)))

            // NY ATR
            ny_atr_count += 1
            if ny_atr_count <= nyAtrLength
                array.push(ny_atr_trHist, tr)
                if ny_atr_count == nyAtrLength
                    sum = 0.0
                    for i = 0 to nyAtrLength - 1
                        sum += array.get(ny_atr_trHist, i)
                    ny_atr_building := sum / nyAtrLength
            else
                ny_atr_building := (ny_atr_building * (nyAtrLength - 1) + tr) / nyAtrLength

            // Asia ATR
            asia_atr_count += 1
            if asia_atr_count <= asiaAtrLength
                array.push(asia_atr_trHist, tr)
                if asia_atr_count == asiaAtrLength
                    sum = 0.0
                    for i = 0 to asiaAtrLength - 1
                        sum += array.get(asia_atr_trHist, i)
                    asia_atr_building := sum / asiaAtrLength
            else
                asia_atr_building := (asia_atr_building * (asiaAtrLength - 1) + tr) / asiaAtrLength

            // LDN ATR
            ldn_atr_count += 1
            if ldn_atr_count <= ldnAtrLength
                array.push(ldn_atr_trHist, tr)
                if ldn_atr_count == ldnAtrLength
                    sum = 0.0
                    for i = 0 to ldnAtrLength - 1
                        sum += array.get(ldn_atr_trHist, i)
                    ldn_atr_building := sum / ldnAtrLength
            else
                ldn_atr_building := (ldn_atr_building * (ldnAtrLength - 1) + tr) / ldnAtrLength

        ny_atr_value   := ny_atr_building
        asia_atr_value := asia_atr_building
        ldn_atr_value  := ldn_atr_building
        atr_lastClose  := atr_dayClose
        atr_dayHigh  := orbH5
        atr_dayLow   := orbL5
        atr_dayClose := orbC5
    else
        atr_dayHigh  := na(atr_dayHigh) ? orbH5 : math.max(atr_dayHigh, orbH5)
        atr_dayLow   := na(atr_dayLow)  ? orbL5 : math.min(atr_dayLow, orbL5)
        atr_dayClose := orbC5
    atr_lastDay := atr_curDay

nyDailyATR   = ny_atr_value
asiaDailyATR = asia_atr_value
ldnDailyATR  = ldn_atr_value

// ============================================================================
// FVG SIZE REQUIREMENTS
// ============================================================================
nyOrbRange   = nz(ny_orbHigh - ny_orbLow)
asiaOrbRange = nz(asia_orbHigh - asia_orbLow)
ldnOrbRange  = nz(ldn_orbHigh - ldn_orbLow)

nyMinGap   = nyStopMode == "ORB" ? (nyMinGapPct / 100) * nyOrbRange : (nyMinGapPct / 100) * nz(nyDailyATR)
asiaMinGap = asiaStopMode == "ORB" ? (asiaMinGapPct / 100) * asiaOrbRange : (asiaMinGapPct / 100) * nz(asiaDailyATR)
ldnMinGap  = ldnStopMode == "ORB" ? (ldnMinGapPct / 100) * ldnOrbRange : (ldnMinGapPct / 100) * nz(ldnDailyATR)

// ============================================================================
// FVG DETECTION (using 5m OHLC: h5, l5, h5_1, l5_1, h5_2, l5_2)
// ============================================================================
longFvgTop     = l5
longFvgBottom  = h5_2
shortFvgTop    = l5_2
shortFvgBottom = h5
longGapSize    = longFvgTop - longFvgBottom
shortGapSize   = shortFvgTop - shortFvgBottom

// NY FVG validation
nyLongGapValid  = longGapSize >= nyMinGap
nyShortGapValid = shortGapSize >= nyMinGap
nyLongBreakout  = longFvgTop > ny_orbHigh or (nyImpulseClose and c5_1 > ny_orbHigh)
nyShortBreakout = shortFvgBottom < ny_orbLow or (nyImpulseClose and c5_1 < ny_orbLow)
nyLongFVG  = nyDetectLongs and h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5 and nyLongBreakout and nyLongGapValid
nyShortFVG = nyDetectShorts and l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5 and nyShortBreakout and nyShortGapValid

// Asia FVG validation
asiaLongGapValid  = longGapSize >= asiaMinGap
asiaShortGapValid = shortGapSize >= asiaMinGap
asiaLongBreakout  = longFvgTop > asia_orbHigh or (asiaImpulseClose and c5_1 > asia_orbHigh)
asiaShortBreakout = shortFvgBottom < asia_orbLow or (asiaImpulseClose and c5_1 < asia_orbLow)
asiaLongFVG  = asiaDetectLongs and h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5 and asiaLongBreakout and asiaLongGapValid
asiaShortFVG = asiaDetectShorts and l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5 and asiaShortBreakout and asiaShortGapValid

// LDN FVG validation
ldnLongGapValid  = longGapSize >= ldnMinGap
ldnShortGapValid = shortGapSize >= ldnMinGap
ldnLongBreakout  = longFvgTop > ldn_orbHigh or (ldnImpulseClose and c5_1 > ldn_orbHigh)
ldnShortBreakout = shortFvgBottom < ldn_orbLow or (ldnImpulseClose and c5_1 < ldn_orbLow)
ldnLongFVG  = ldnDetectLongs and h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5 and ldnLongBreakout and ldnLongGapValid
ldnShortFVG = ldnDetectShorts and l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5 and ldnShortBreakout and ldnShortGapValid

// ============================================================================
// DETECT FIRST FVG & PLACE ORDERS - NY
// ============================================================================
nyCanDetect = enableNY and barClosed5 and inNyRTH and inNyEntryWin and ny_orbReady and not nySkipToday

if nyCanDetect and not ny_longFirstFvgFound and nyLongFVG
    ny_longFirstFvgFound := true
    entryPrice = longFvgTop
    stopDist   = nyStopMode == "ORB" ? (nyStopPct / 100) * nyOrbRange : (nyStopPct / 100) * nz(nyDailyATR)
    stopPrice  = entryPrice - stopDist
    riskPts    = entryPrice - stopPrice
    tp1Price   = entryPrice + (nyRR * riskPts * nyTp1Ratio)
    tp2Price   = entryPrice + (nyRR * riskPts)

    riskPerContract = riskPts * i_pointValue
    rawQty   = riskPerContract > 0 ? i_riskUsd / riskPerContract : i_minQty
    totalQty = floorToStep(rawQty, i_qtyStep)
    if totalQty < i_minQty
        totalQty := i_minQty
    tp1Qty = floorToStep(totalQty * 0.5, i_qtyStep)
    tp2Qty = totalQty - tp1Qty

    strategy.entry("NY Long", strategy.long, qty=totalQty, limit=entryPrice)
    strategy.exit("NY Long TP1", "NY Long", qty=tp1Qty, limit=tp1Price, stop=stopPrice)
    strategy.exit("NY Long TP2", "NY Long", qty=tp2Qty, limit=tp2Price, stop=stopPrice)
    ny_longArmed := true

if nyCanDetect and not ny_shortFirstFvgFound and nyShortFVG
    ny_shortFirstFvgFound := true
    entryPrice = shortFvgBottom
    stopDist   = nyStopMode == "ORB" ? (nyStopPct / 100) * nyOrbRange : (nyStopPct / 100) * nz(nyDailyATR)
    stopPrice  = entryPrice + stopDist
    riskPts    = stopPrice - entryPrice
    tp1Price   = entryPrice - (nyRR * riskPts * nyTp1Ratio)
    tp2Price   = entryPrice - (nyRR * riskPts)

    riskPerContract = riskPts * i_pointValue
    rawQty   = riskPerContract > 0 ? i_riskUsd / riskPerContract : i_minQty
    totalQty = floorToStep(rawQty, i_qtyStep)
    if totalQty < i_minQty
        totalQty := i_minQty
    tp1Qty = floorToStep(totalQty * 0.5, i_qtyStep)
    tp2Qty = totalQty - tp1Qty

    strategy.entry("NY Short", strategy.short, qty=totalQty, limit=entryPrice)
    strategy.exit("NY Short TP1", "NY Short", qty=tp1Qty, limit=tp1Price, stop=stopPrice)
    strategy.exit("NY Short TP2", "NY Short", qty=tp2Qty, limit=tp2Price, stop=stopPrice)
    ny_shortArmed := true

// ============================================================================
// DETECT FIRST FVG & PLACE ORDERS - Asia
// ============================================================================
asiaCanDetect = enableAsia and barClosed5 and inAsiaRTH and inAsiaEntryWin and asia_orbReady and not asiaSkipToday

if asiaCanDetect and not asia_longFirstFvgFound and asiaLongFVG
    asia_longFirstFvgFound := true
    entryPrice = longFvgTop
    stopDist   = asiaStopMode == "ORB" ? (asiaStopPct / 100) * asiaOrbRange : (asiaStopPct / 100) * nz(asiaDailyATR)
    stopPrice  = entryPrice - stopDist
    riskPts    = entryPrice - stopPrice
    tp1Price   = entryPrice + (asiaRR * riskPts * asiaTp1Ratio)
    tp2Price   = entryPrice + (asiaRR * riskPts)

    riskPerContract = riskPts * i_pointValue
    rawQty   = riskPerContract > 0 ? i_riskUsd / riskPerContract : i_minQty
    totalQty = floorToStep(rawQty, i_qtyStep)
    if totalQty < i_minQty
        totalQty := i_minQty
    tp1Qty = floorToStep(totalQty * 0.5, i_qtyStep)
    tp2Qty = totalQty - tp1Qty

    strategy.entry("Asia Long", strategy.long, qty=totalQty, limit=entryPrice)
    strategy.exit("Asia Long TP1", "Asia Long", qty=tp1Qty, limit=tp1Price, stop=stopPrice)
    strategy.exit("Asia Long TP2", "Asia Long", qty=tp2Qty, limit=tp2Price, stop=stopPrice)
    asia_longArmed := true

if asiaCanDetect and not asia_shortFirstFvgFound and asiaShortFVG
    asia_shortFirstFvgFound := true
    entryPrice = shortFvgBottom
    stopDist   = asiaStopMode == "ORB" ? (asiaStopPct / 100) * asiaOrbRange : (asiaStopPct / 100) * nz(asiaDailyATR)
    stopPrice  = entryPrice + stopDist
    riskPts    = stopPrice - entryPrice
    tp1Price   = entryPrice - (asiaRR * riskPts * asiaTp1Ratio)
    tp2Price   = entryPrice - (asiaRR * riskPts)

    riskPerContract = riskPts * i_pointValue
    rawQty   = riskPerContract > 0 ? i_riskUsd / riskPerContract : i_minQty
    totalQty = floorToStep(rawQty, i_qtyStep)
    if totalQty < i_minQty
        totalQty := i_minQty
    tp1Qty = floorToStep(totalQty * 0.5, i_qtyStep)
    tp2Qty = totalQty - tp1Qty

    strategy.entry("Asia Short", strategy.short, qty=totalQty, limit=entryPrice)
    strategy.exit("Asia Short TP1", "Asia Short", qty=tp1Qty, limit=tp1Price, stop=stopPrice)
    strategy.exit("Asia Short TP2", "Asia Short", qty=tp2Qty, limit=tp2Price, stop=stopPrice)
    asia_shortArmed := true

// ============================================================================
// DETECT FIRST FVG & PLACE ORDERS - LDN
// ============================================================================
ldnCanDetect = enableNqLdn and barClosed5 and inLdnRTH and inLdnEntryWin and ldn_orbReady and not ldnSkipToday

if ldnCanDetect and not ldn_longFirstFvgFound and ldnLongFVG
    ldn_longFirstFvgFound := true
    entryPrice = longFvgTop
    stopDist   = ldnStopMode == "ORB" ? (ldnStopPct / 100) * ldnOrbRange : (ldnStopPct / 100) * nz(ldnDailyATR)
    stopPrice  = entryPrice - stopDist
    riskPts    = entryPrice - stopPrice
    tp1Price   = entryPrice + (ldnRR * riskPts * ldnTp1Ratio)
    tp2Price   = entryPrice + (ldnRR * riskPts)

    riskPerContract = riskPts * i_pointValue
    rawQty   = riskPerContract > 0 ? i_riskUsd / riskPerContract : i_minQty
    totalQty = floorToStep(rawQty, i_qtyStep)
    if totalQty < i_minQty
        totalQty := i_minQty
    tp1Qty = floorToStep(totalQty * 0.5, i_qtyStep)
    tp2Qty = totalQty - tp1Qty

    strategy.entry("LDN Long", strategy.long, qty=totalQty, limit=entryPrice)
    strategy.exit("LDN Long TP1", "LDN Long", qty=tp1Qty, limit=tp1Price, stop=stopPrice)
    strategy.exit("LDN Long TP2", "LDN Long", qty=tp2Qty, limit=tp2Price, stop=stopPrice)
    ldn_longArmed := true

if ldnCanDetect and not ldn_shortFirstFvgFound and ldnShortFVG
    ldn_shortFirstFvgFound := true
    entryPrice = shortFvgBottom
    stopDist   = ldnStopMode == "ORB" ? (ldnStopPct / 100) * ldnOrbRange : (ldnStopPct / 100) * nz(ldnDailyATR)
    stopPrice  = entryPrice + stopDist
    riskPts    = stopPrice - entryPrice
    tp1Price   = entryPrice - (ldnRR * riskPts * ldnTp1Ratio)
    tp2Price   = entryPrice - (ldnRR * riskPts)

    riskPerContract = riskPts * i_pointValue
    rawQty   = riskPerContract > 0 ? i_riskUsd / riskPerContract : i_minQty
    totalQty = floorToStep(rawQty, i_qtyStep)
    if totalQty < i_minQty
        totalQty := i_minQty
    tp1Qty = floorToStep(totalQty * 0.5, i_qtyStep)
    tp2Qty = totalQty - tp1Qty

    strategy.entry("LDN Short", strategy.short, qty=totalQty, limit=entryPrice)
    strategy.exit("LDN Short TP1", "LDN Short", qty=tp1Qty, limit=tp1Price, stop=stopPrice)
    strategy.exit("LDN Short TP2", "LDN Short", qty=tp2Qty, limit=tp2Price, stop=stopPrice)
    ldn_shortArmed := true

// ============================================================================
// CANCEL UNFILLED LIMITS at entry window close
// ============================================================================
nyEntryWinClosed   = not inNyEntryWin and inNyEntryWin[1]
asiaEntryWinClosed = not inAsiaEntryWin and inAsiaEntryWin[1]
ldnEntryWinClosed  = not inLdnEntryWin and inLdnEntryWin[1]

if nyEntryWinClosed
    if ny_longArmed and strategy.opentrades == 0
        strategy.cancel("NY Long")
    if ny_shortArmed and strategy.opentrades == 0
        strategy.cancel("NY Short")

if asiaEntryWinClosed
    if asia_longArmed and strategy.opentrades == 0
        strategy.cancel("Asia Long")
    if asia_shortArmed and strategy.opentrades == 0
        strategy.cancel("Asia Short")

if ldnEntryWinClosed
    if ldn_longArmed and strategy.opentrades == 0
        strategy.cancel("LDN Long")
    if ldn_shortArmed and strategy.opentrades == 0
        strategy.cancel("LDN Short")

// ============================================================================
// EOD FLATTEN
// ============================================================================
// NY: flatten at 15:50 ET (NQ+ES) or 13:30 ET (GC)
inNyFlatWin = if asset == "GC"
    not na(time("5", "1330-1600", "America/New_York"))
else
    not na(time("5", "1550-1600", "America/New_York"))

if inNyFlatWin
    strategy.close("NY Long",  comment="EOD Flat")
    strategy.close("NY Short", comment="EOD Flat")

// Asia: close when Asia RTH ends
if not inAsiaRTH and inAsiaRTH[1]
    strategy.close("Asia Long",  comment="Asia EOD")
    strategy.close("Asia Short", comment="Asia EOD")

// LDN: flatten at 08:20 ET
inLdnFlatWin = not na(time("5", "0820-0930", "America/New_York"))
if inLdnFlatWin
    strategy.close("LDN Long",  comment="LDN EOD")
    strategy.close("LDN Short", comment="LDN EOD")

// ============================================================================
// PLOTS — ORB range visualization
// ============================================================================
plot(enableNY and ny_orbReady and inNyRTH and inNyEntryWin ? ny_orbHigh : na, "NY ORB High", color=color.new(#18b79c, 30), style=plot.style_linebr, linewidth=2)
plot(enableNY and ny_orbReady and inNyRTH and inNyEntryWin ? ny_orbLow  : na, "NY ORB Low",  color=color.new(#94E3DA, 30), style=plot.style_linebr, linewidth=2)
plot(enableAsia and asia_orbReady and inAsiaRTH and inAsiaEntryWin ? asia_orbHigh : na, "Asia ORB High", color=color.new(#2196F3, 30), style=plot.style_linebr, linewidth=2)
plot(enableAsia and asia_orbReady and inAsiaRTH and inAsiaEntryWin ? asia_orbLow  : na, "Asia ORB Low",  color=color.new(#A5DFFA, 30), style=plot.style_linebr, linewidth=2)
plot(enableNqLdn and ldn_orbReady and inLdnRTH and inLdnEntryWin ? ldn_orbHigh : na, "LDN ORB High", color=color.new(#FF9800, 30), style=plot.style_linebr, linewidth=2)
plot(enableNqLdn and ldn_orbReady and inLdnRTH and inLdnEntryWin ? ldn_orbLow  : na, "LDN ORB Low",  color=color.new(#FFD699, 30), style=plot.style_linebr, linewidth=2)
