        tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
        tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
        ldnOrb_shortStopLbl := label.new(ldnOrbEndBar, ldnOrb_shortStop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
        ldnOrb_shortTp1Lbl  := label.new(ldnOrbEndBar, ldnOrb_shortTp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
        ldnOrb_shortTp2Lbl  := label.new(ldnOrbEndBar, ldnOrb_shortTp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

// ============================================================================
// DETECT & STORE FVGs - LSI NY
// Bearish FVGs tracked for LONG inversions, bullish for SHORT inversions
// ============================================================================
lsiNyCanDetect = enableLsiNy and barClosed5 and inLsiNyRTH and inLsiNyEntryWin and nz(lsiNyDailyATR) > 0

if lsiNyCanDetect
    if lsiNyDetectLongs and isBearFvg and bearGapSize >= lsiNyMinGap
        fvgPts    = bearGapSize
        fvgAtrPct = lsiNyDailyATR > 0 ? (fvgPts / lsiNyDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        zone      = FvgZone.new(bearFvgTop, bearFvgBot, t5_2, na, na)
        if canDraw
            zone.bx  := box.new(t5_2, bearFvgTop, time, bearFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nqLsiNyFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bearFvgTop + bearFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nqLsiNyFvgPendColor, 0), size=size.small)
        array.push(lsiNy_bearFvgs, zone)

    if lsiNyDetectShorts and isBullFvg and bullGapSize >= lsiNyMinGap
        fvgPts    = bullGapSize
        fvgAtrPct = lsiNyDailyATR > 0 ? (fvgPts / lsiNyDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        zone      = FvgZone.new(bullFvgTop, bullFvgBot, t5_2, na, na)
        if canDraw
            zone.bx  := box.new(t5_2, bullFvgTop, time, bullFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nqLsiNyFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bullFvgTop + bullFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nqLsiNyFvgPendColor, 0), size=size.small)
        array.push(lsiNy_bullFvgs, zone)

// ============================================================================
// DETECT & STORE FVGs - LSI Asia
// ============================================================================
lsiAsiaCanDetect = enableLsiAsia and barClosed5 and inLsiAsiaRTH and inLsiAsiaEntryWin and nz(lsiAsiaDailyATR) > 0

if lsiAsiaCanDetect
    if lsiAsiaDetectLongs and isBearFvg and bearGapSize >= lsiAsiaMinGap
        fvgPts    = bearGapSize
        fvgAtrPct = lsiAsiaDailyATR > 0 ? (fvgPts / lsiAsiaDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        zone      = FvgZone.new(bearFvgTop, bearFvgBot, t5_2, na, na)
        if canDraw
            zone.bx  := box.new(t5_2, bearFvgTop, time, bearFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nqLsiAsiaFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bearFvgTop + bearFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nqLsiAsiaFvgPendColor, 0), size=size.small)
        array.push(lsiAsia_bearFvgs, zone)

    if lsiAsiaDetectShorts and isBullFvg and bullGapSize >= lsiAsiaMinGap
        fvgPts    = bullGapSize
        fvgAtrPct = lsiAsiaDailyATR > 0 ? (fvgPts / lsiAsiaDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        zone      = FvgZone.new(bullFvgTop, bullFvgBot, t5_2, na, na)
        if canDraw
            zone.bx  := box.new(t5_2, bullFvgTop, time, bullFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nqLsiAsiaFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bullFvgTop + bullFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nqLsiAsiaFvgPendColor, 0), size=size.small)
        array.push(lsiAsia_bullFvgs, zone)

// ============================================================================
// DETECT & STORE FVGs - LDN
// ============================================================================
ldnCanDetect = enableLdn and barClosed5 and inLdnRTH and inLdnEntryWin and nz(ldnDailyATR) > 0

if ldnCanDetect
    if ldnDetectLongs and isBearFvg and bearGapSize >= ldnMinGap
        fvgPts    = bearGapSize
        fvgAtrPct = ldnDailyATR > 0 ? (fvgPts / ldnDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        zone      = FvgZone.new(bearFvgTop, bearFvgBot, t5_2, na, na)
        if canDraw
            zone.bx  := box.new(t5_2, bearFvgTop, time, bearFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nqLdnFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bearFvgTop + bearFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nqLdnFvgPendColor, 0), size=size.small)
        array.push(ldn_bearFvgs, zone)

    if ldnDetectShorts and isBullFvg and bullGapSize >= ldnMinGap
        fvgPts    = bullGapSize
        fvgAtrPct = ldnDailyATR > 0 ? (fvgPts / ldnDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        zone      = FvgZone.new(bullFvgTop, bullFvgBot, t5_2, na, na)
        if canDraw
            zone.bx  := box.new(t5_2, bullFvgTop, time, bullFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nqLdnFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bullFvgTop + bullFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nqLdnFvgPendColor, 0), size=size.small)
        array.push(ldn_bullFvgs, zone)

// ============================================================================
// INVERSION DETECTION - LSI NY
// Bearish FVG: close > FVG top → LONG inversion
// Bullish FVG: close < FVG bot → SHORT inversion
// First armed setup per session-day wins
// ============================================================================
if enableLsiNy and barClosed5 and inLsiNyRTH and inLsiNyEntryWin and not lsiNy_armed and nz(lsiNyDailyATR) > 0
    if lsiNyDetectLongs and array.size(lsiNy_bearFvgs) > 0
        for i = 0 to array.size(lsiNy_bearFvgs) - 1
            if lsiNy_armed
                break
            zone = array.get(lsiNy_bearFvgs, i)
            if c5 > zone.top
                lsiNy_armed := true
                lsiNy_dir   := 1
                lsiNy_entry := zone.top
                stopDist = (i_nqLsiNyStopPct / 100) * nz(lsiNyDailyATR)
                lsiNy_stop  := lsiNy_entry - stopDist
                riskPts  = lsiNy_entry - lsiNy_stop
                lsiNy_tp1   := lsiNy_entry + (i_nqLsiNyRR * riskPts * i_nqLsiNyTp1Ratio)
                lsiNy_tp2   := lsiNy_entry + (i_nqLsiNyRR * riskPts)
                lsiNy_setupAlert := enableAlerts
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nqLsiNyFvgSweptColor, 60))
                if canDraw
                    lsiNyEndBar = calcEndBarTime(i_nqLsiNyEntryWindow, "America/New_York")
                    lsiNy_entryLine := line.new(time, lsiNy_entry, lsiNyEndBar, lsiNy_entry, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
                    lsiNy_stopLine  := line.new(time, lsiNy_stop, lsiNyEndBar, lsiNy_stop, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
                    lsiNy_tp1Line   := line.new(time, lsiNy_tp1, lsiNyEndBar, lsiNy_tp1, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
                    lsiNy_tp2Line   := line.new(time, lsiNy_tp2, lsiNyEndBar, lsiNy_tp2, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
                    slPts  = riskPts
                    slAtr  = lsiNyDailyATR > 0 ? (slPts / lsiNyDailyATR) * 100 : 0.0
                    tp1Pts = lsiNy_tp1 - lsiNy_entry
                    tp1Atr = lsiNyDailyATR > 0 ? (tp1Pts / lsiNyDailyATR) * 100 : 0.0
                    tp2Pts = lsiNy_tp2 - lsiNy_entry
                    tp2Atr = lsiNyDailyATR > 0 ? (tp2Pts / lsiNyDailyATR) * 100 : 0.0
                    slTxt  = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
                    tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
                    tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
                    lsiNy_stopLbl := label.new(lsiNyEndBar, lsiNy_stop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
                    lsiNy_tp1Lbl  := label.new(lsiNyEndBar, lsiNy_tp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
                    lsiNy_tp2Lbl  := label.new(lsiNyEndBar, lsiNy_tp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

    if not lsiNy_armed and lsiNyDetectShorts and array.size(lsiNy_bullFvgs) > 0
        for i = 0 to array.size(lsiNy_bullFvgs) - 1
            if lsiNy_armed
                break
            zone = array.get(lsiNy_bullFvgs, i)
            if c5 < zone.bot
                lsiNy_armed := true
                lsiNy_dir   := -1
                lsiNy_entry := zone.bot
                stopDist = (i_nqLsiNyStopPct / 100) * nz(lsiNyDailyATR)
                lsiNy_stop  := lsiNy_entry + stopDist
                riskPts  = lsiNy_stop - lsiNy_entry
                lsiNy_tp1   := lsiNy_entry - (i_nqLsiNyRR * riskPts * i_nqLsiNyTp1Ratio)
                lsiNy_tp2   := lsiNy_entry - (i_nqLsiNyRR * riskPts)
                lsiNy_setupAlert := enableAlerts
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nqLsiNyFvgSweptColor, 60))
                if canDraw
                    lsiNyEndBar = calcEndBarTime(i_nqLsiNyEntryWindow, "America/New_York")
                    lsiNy_entryLine := line.new(time, lsiNy_entry, lsiNyEndBar, lsiNy_entry, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
                    lsiNy_stopLine  := line.new(time, lsiNy_stop, lsiNyEndBar, lsiNy_stop, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
                    lsiNy_tp1Line   := line.new(time, lsiNy_tp1, lsiNyEndBar, lsiNy_tp1, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
                    lsiNy_tp2Line   := line.new(time, lsiNy_tp2, lsiNyEndBar, lsiNy_tp2, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
                    slPts  = riskPts
                    slAtr  = lsiNyDailyATR > 0 ? (slPts / lsiNyDailyATR) * 100 : 0.0
                    tp1Pts = lsiNy_entry - lsiNy_tp1
                    tp1Atr = lsiNyDailyATR > 0 ? (tp1Pts / lsiNyDailyATR) * 100 : 0.0
                    tp2Pts = lsiNy_entry - lsiNy_tp2
                    tp2Atr = lsiNyDailyATR > 0 ? (tp2Pts / lsiNyDailyATR) * 100 : 0.0
                    slTxt  = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
                    tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
                    tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
                    lsiNy_stopLbl := label.new(lsiNyEndBar, lsiNy_stop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
                    lsiNy_tp1Lbl  := label.new(lsiNyEndBar, lsiNy_tp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
                    lsiNy_tp2Lbl  := label.new(lsiNyEndBar, lsiNy_tp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

// ============================================================================
// INVERSION DETECTION - LSI Asia
// ============================================================================
if enableLsiAsia and barClosed5 and inLsiAsiaRTH and inLsiAsiaEntryWin and not lsiAsia_armed and nz(lsiAsiaDailyATR) > 0
    if lsiAsiaDetectLongs and array.size(lsiAsia_bearFvgs) > 0
        for i = 0 to array.size(lsiAsia_bearFvgs) - 1
            if lsiAsia_armed
                break
            zone = array.get(lsiAsia_bearFvgs, i)
            if c5 > zone.top
                lsiAsia_armed := true
                lsiAsia_dir   := 1
                lsiAsia_entry := zone.top
                stopDist   = (i_nqLsiAsiaStopPct / 100) * nz(lsiAsiaDailyATR)
                lsiAsia_stop  := lsiAsia_entry - stopDist
                riskPts    = lsiAsia_entry - lsiAsia_stop
                lsiAsia_tp1   := lsiAsia_entry + (i_nqLsiAsiaRR * riskPts * i_nqLsiAsiaTp1Ratio)
                lsiAsia_tp2   := lsiAsia_entry + (i_nqLsiAsiaRR * riskPts)
                lsiAsia_setupAlert := enableAlerts
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nqLsiAsiaFvgSweptColor, 60))
                if canDraw
                    lsiAsiaEndBar = calcEndBarTime(i_nqLsiAsiaEntryWindow, "America/New_York")
                    lsiAsia_entryLine := line.new(time, lsiAsia_entry, lsiAsiaEndBar, lsiAsia_entry, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
                    lsiAsia_stopLine  := line.new(time, lsiAsia_stop, lsiAsiaEndBar, lsiAsia_stop, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
                    lsiAsia_tp1Line   := line.new(time, lsiAsia_tp1, lsiAsiaEndBar, lsiAsia_tp1, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
                    lsiAsia_tp2Line   := line.new(time, lsiAsia_tp2, lsiAsiaEndBar, lsiAsia_tp2, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
                    slPts  = riskPts
                    slAtr  = lsiAsiaDailyATR > 0 ? (slPts / lsiAsiaDailyATR) * 100 : 0.0
                    tp1Pts = lsiAsia_tp1 - lsiAsia_entry
                    tp1Atr = lsiAsiaDailyATR > 0 ? (tp1Pts / lsiAsiaDailyATR) * 100 : 0.0
                    tp2Pts = lsiAsia_tp2 - lsiAsia_entry
                    tp2Atr = lsiAsiaDailyATR > 0 ? (tp2Pts / lsiAsiaDailyATR) * 100 : 0.0
                    slTxt  = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
                    tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
                    tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
                    lsiAsia_stopLbl := label.new(lsiAsiaEndBar, lsiAsia_stop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
                    lsiAsia_tp1Lbl  := label.new(lsiAsiaEndBar, lsiAsia_tp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
                    lsiAsia_tp2Lbl  := label.new(lsiAsiaEndBar, lsiAsia_tp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

    if not lsiAsia_armed and lsiAsiaDetectShorts and array.size(lsiAsia_bullFvgs) > 0
        for i = 0 to array.size(lsiAsia_bullFvgs) - 1
            if lsiAsia_armed
                break
            zone = array.get(lsiAsia_bullFvgs, i)
            if c5 < zone.bot
                lsiAsia_armed := true
                lsiAsia_dir   := -1
                lsiAsia_entry := zone.bot
                stopDist   = (i_nqLsiAsiaStopPct / 100) * nz(lsiAsiaDailyATR)
                lsiAsia_stop  := lsiAsia_entry + stopDist
                riskPts    = lsiAsia_stop - lsiAsia_entry
                lsiAsia_tp1   := lsiAsia_entry - (i_nqLsiAsiaRR * riskPts * i_nqLsiAsiaTp1Ratio)
                lsiAsia_tp2   := lsiAsia_entry - (i_nqLsiAsiaRR * riskPts)
                lsiAsia_setupAlert := enableAlerts
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nqLsiAsiaFvgSweptColor, 60))
                if canDraw
                    lsiAsiaEndBar = calcEndBarTime(i_nqLsiAsiaEntryWindow, "America/New_York")
                    lsiAsia_entryLine := line.new(time, lsiAsia_entry, lsiAsiaEndBar, lsiAsia_entry, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
                    lsiAsia_stopLine  := line.new(time, lsiAsia_stop, lsiAsiaEndBar, lsiAsia_stop, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
                    lsiAsia_tp1Line   := line.new(time, lsiAsia_tp1, lsiAsiaEndBar, lsiAsia_tp1, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
                    lsiAsia_tp2Line   := line.new(time, lsiAsia_tp2, lsiAsiaEndBar, lsiAsia_tp2, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
                    slPts  = riskPts
                    slAtr  = lsiAsiaDailyATR > 0 ? (slPts / lsiAsiaDailyATR) * 100 : 0.0
                    tp1Pts = lsiAsia_entry - lsiAsia_tp1
                    tp1Atr = lsiAsiaDailyATR > 0 ? (tp1Pts / lsiAsiaDailyATR) * 100 : 0.0
                    tp2Pts = lsiAsia_entry - lsiAsia_tp2
                    tp2Atr = lsiAsiaDailyATR > 0 ? (tp2Pts / lsiAsiaDailyATR) * 100 : 0.0
                    slTxt  = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
                    tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
                    tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
                    lsiAsia_stopLbl := label.new(lsiAsiaEndBar, lsiAsia_stop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
                    lsiAsia_tp1Lbl  := label.new(lsiAsiaEndBar, lsiAsia_tp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
                    lsiAsia_tp2Lbl  := label.new(lsiAsiaEndBar, lsiAsia_tp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

// ============================================================================
// INVERSION DETECTION - LDN
// ============================================================================
if enableLdn and barClosed5 and inLdnRTH and inLdnEntryWin and not ldn_armed and nz(ldnDailyATR) > 0
    if ldnDetectLongs and array.size(ldn_bearFvgs) > 0
        for i = 0 to array.size(ldn_bearFvgs) - 1
            if ldn_armed
                break
            zone = array.get(ldn_bearFvgs, i)
            if c5 > zone.top
                ldn_armed := true
                ldn_dir   := 1
                ldn_entry := zone.top
                stopDist = (i_nqLdnStopPct / 100) * nz(ldnDailyATR)
                ldn_stop  := ldn_entry - stopDist
                riskPts  = ldn_entry - ldn_stop
                ldn_tp1   := ldn_entry + (i_nqLdnRR * riskPts * i_nqLdnTp1Ratio)
                ldn_tp2   := ldn_entry + (i_nqLdnRR * riskPts)
                ldn_setupAlert := enableAlerts
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nqLdnFvgSweptColor, 60))
                if canDraw
                    ldnEndBar = calcEndBarTime(i_nqLdnEntryWindow, "America/New_York")
                    ldn_entryLine := line.new(time, ldn_entry, ldnEndBar, ldn_entry, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
                    ldn_stopLine  := line.new(time, ldn_stop, ldnEndBar, ldn_stop, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
                    ldn_tp1Line   := line.new(time, ldn_tp1, ldnEndBar, ldn_tp1, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
                    ldn_tp2Line   := line.new(time, ldn_tp2, ldnEndBar, ldn_tp2, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
                    slPts  = riskPts
                    slAtr  = ldnDailyATR > 0 ? (slPts / ldnDailyATR) * 100 : 0.0
                    tp1Pts = ldn_tp1 - ldn_entry
                    tp1Atr = ldnDailyATR > 0 ? (tp1Pts / ldnDailyATR) * 100 : 0.0
                    tp2Pts = ldn_tp2 - ldn_entry
                    tp2Atr = ldnDailyATR > 0 ? (tp2Pts / ldnDailyATR) * 100 : 0.0
                    slTxt  = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
                    tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
                    tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
                    ldn_stopLbl := label.new(ldnEndBar, ldn_stop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
                    ldn_tp1Lbl  := label.new(ldnEndBar, ldn_tp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
                    ldn_tp2Lbl  := label.new(ldnEndBar, ldn_tp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

    if not ldn_armed and ldnDetectShorts and array.size(ldn_bullFvgs) > 0
        for i = 0 to array.size(ldn_bullFvgs) - 1
            if ldn_armed
                break
            zone = array.get(ldn_bullFvgs, i)
            if c5 < zone.bot
                ldn_armed := true
                ldn_dir   := -1
                ldn_entry := zone.bot
                stopDist = (i_nqLdnStopPct / 100) * nz(ldnDailyATR)
                ldn_stop  := ldn_entry + stopDist
                riskPts  = ldn_stop - ldn_entry
                ldn_tp1   := ldn_entry - (i_nqLdnRR * riskPts * i_nqLdnTp1Ratio)
                ldn_tp2   := ldn_entry - (i_nqLdnRR * riskPts)
                ldn_setupAlert := enableAlerts
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nqLdnFvgSweptColor, 60))
                if canDraw
                    ldnEndBar = calcEndBarTime(i_nqLdnEntryWindow, "America/New_York")
                    ldn_entryLine := line.new(time, ldn_entry, ldnEndBar, ldn_entry, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
                    ldn_stopLine  := line.new(time, ldn_stop, ldnEndBar, ldn_stop, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
                    ldn_tp1Line   := line.new(time, ldn_tp1, ldnEndBar, ldn_tp1, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
                    ldn_tp2Line   := line.new(time, ldn_tp2, ldnEndBar, ldn_tp2, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
                    slPts  = riskPts
                    slAtr  = ldnDailyATR > 0 ? (slPts / ldnDailyATR) * 100 : 0.0
                    tp1Pts = ldn_entry - ldn_tp1
                    tp1Atr = ldnDailyATR > 0 ? (tp1Pts / ldnDailyATR) * 100 : 0.0
                    tp2Pts = ldn_entry - ldn_tp2
                    tp2Atr = ldnDailyATR > 0 ? (tp2Pts / ldnDailyATR) * 100 : 0.0
                    slTxt  = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
                    tp1Txt = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
                    tp2Txt = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
                    ldn_stopLbl := label.new(ldnEndBar, ldn_stop, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
                    ldn_tp1Lbl  := label.new(ldnEndBar, ldn_tp1, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
                    ldn_tp2Lbl  := label.new(ldnEndBar, ldn_tp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

// ============================================================================
// EXTEND FVG BOXES + LABELS (update right edge, not delete+redraw)
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin and not na(ny_longFvgBox)
    box.set_right(ny_longFvgBox, time)
    label.set_x(ny_longFvgLabel, time)

if enableNY and inNyRTH and inNyEntryWin and not na(ny_shortFvgBox)
    box.set_right(ny_shortFvgBox, time)
    label.set_x(ny_shortFvgLabel, time)

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_longFvgBox)
    box.set_right(asia_longFvgBox, time)
    label.set_x(asia_longFvgLabel, time)

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_shortFvgBox)
    box.set_right(asia_shortFvgBox, time)
    label.set_x(asia_shortFvgLabel, time)

if enableLdnOrb and inLdnRTH and inLdnOrbEntryWin and not na(ldnOrb_longFvgBox)
    box.set_right(ldnOrb_longFvgBox, time)
    label.set_x(ldnOrb_longFvgLabel, time)

if enableLdnOrb and inLdnRTH and inLdnOrbEntryWin and not na(ldnOrb_shortFvgBox)
    box.set_right(ldnOrb_shortFvgBox, time)
    label.set_x(ldnOrb_shortFvgLabel, time)

if enableLsiNy and inLsiNyRTH and inLsiNyEntryWin
    if array.size(lsiNy_bearFvgs) > 0
        for i = 0 to array.size(lsiNy_bearFvgs) - 1
            zone = array.get(lsiNy_bearFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
    if array.size(lsiNy_bullFvgs) > 0
        for i = 0 to array.size(lsiNy_bullFvgs) - 1
            zone = array.get(lsiNy_bullFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)

if enableLsiAsia and inLsiAsiaRTH and inLsiAsiaEntryWin
    if array.size(lsiAsia_bearFvgs) > 0
        for i = 0 to array.size(lsiAsia_bearFvgs) - 1
            zone = array.get(lsiAsia_bearFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
    if array.size(lsiAsia_bullFvgs) > 0
        for i = 0 to array.size(lsiAsia_bullFvgs) - 1
            zone = array.get(lsiAsia_bullFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)

if enableLdn and inLdnRTH and inLdnEntryWin
    if array.size(ldn_bearFvgs) > 0
        for i = 0 to array.size(ldn_bearFvgs) - 1
            zone = array.get(ldn_bearFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
    if array.size(ldn_bullFvgs) > 0
        for i = 0 to array.size(ldn_bullFvgs) - 1
            zone = array.get(ldn_bullFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)

// ============================================================================
// EXTEND TRADE LEVEL LINES + LABELS
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin and not na(ny_longEntryLine)
    line.set_x2(ny_longEntryLine, math.max(time, line.get_x2(ny_longEntryLine)))
    line.set_x2(ny_longStopLine, math.max(time, line.get_x2(ny_longStopLine)))
    line.set_x2(ny_longTp1Line, math.max(time, line.get_x2(ny_longTp1Line)))
    line.set_x2(ny_longTp2Line, math.max(time, line.get_x2(ny_longTp2Line)))
    label.set_x(ny_longStopLbl, math.max(time, label.get_x(ny_longStopLbl)))
    label.set_x(ny_longTp1Lbl, math.max(time, label.get_x(ny_longTp1Lbl)))
    label.set_x(ny_longTp2Lbl, math.max(time, label.get_x(ny_longTp2Lbl)))

if enableNY and inNyRTH and inNyEntryWin and not na(ny_shortEntryLine)
    line.set_x2(ny_shortEntryLine, math.max(time, line.get_x2(ny_shortEntryLine)))
    line.set_x2(ny_shortStopLine, math.max(time, line.get_x2(ny_shortStopLine)))
    line.set_x2(ny_shortTp1Line, math.max(time, line.get_x2(ny_shortTp1Line)))
    line.set_x2(ny_shortTp2Line, math.max(time, line.get_x2(ny_shortTp2Line)))
    label.set_x(ny_shortStopLbl, math.max(time, label.get_x(ny_shortStopLbl)))
    label.set_x(ny_shortTp1Lbl, math.max(time, label.get_x(ny_shortTp1Lbl)))
    label.set_x(ny_shortTp2Lbl, math.max(time, label.get_x(ny_shortTp2Lbl)))

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_longEntryLine)
    line.set_x2(asia_longEntryLine, math.max(time, line.get_x2(asia_longEntryLine)))
    line.set_x2(asia_longStopLine, math.max(time, line.get_x2(asia_longStopLine)))
    line.set_x2(asia_longTp1Line, math.max(time, line.get_x2(asia_longTp1Line)))
    line.set_x2(asia_longTp2Line, math.max(time, line.get_x2(asia_longTp2Line)))
    label.set_x(asia_longStopLbl, math.max(time, label.get_x(asia_longStopLbl)))
    label.set_x(asia_longTp1Lbl, math.max(time, label.get_x(asia_longTp1Lbl)))
    label.set_x(asia_longTp2Lbl, math.max(time, label.get_x(asia_longTp2Lbl)))

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_shortEntryLine)
    line.set_x2(asia_shortEntryLine, math.max(time, line.get_x2(asia_shortEntryLine)))
    line.set_x2(asia_shortStopLine, math.max(time, line.get_x2(asia_shortStopLine)))
    line.set_x2(asia_shortTp1Line, math.max(time, line.get_x2(asia_shortTp1Line)))
    line.set_x2(asia_shortTp2Line, math.max(time, line.get_x2(asia_shortTp2Line)))
    label.set_x(asia_shortStopLbl, math.max(time, label.get_x(asia_shortStopLbl)))
    label.set_x(asia_shortTp1Lbl, math.max(time, label.get_x(asia_shortTp1Lbl)))
    label.set_x(asia_shortTp2Lbl, math.max(time, label.get_x(asia_shortTp2Lbl)))

if enableLdnOrb and inLdnRTH and inLdnOrbEntryWin and not na(ldnOrb_longEntryLine)
    line.set_x2(ldnOrb_longEntryLine, math.max(time, line.get_x2(ldnOrb_longEntryLine)))
    line.set_x2(ldnOrb_longStopLine, math.max(time, line.get_x2(ldnOrb_longStopLine)))
    line.set_x2(ldnOrb_longTp1Line, math.max(time, line.get_x2(ldnOrb_longTp1Line)))
    line.set_x2(ldnOrb_longTp2Line, math.max(time, line.get_x2(ldnOrb_longTp2Line)))
    label.set_x(ldnOrb_longStopLbl, math.max(time, label.get_x(ldnOrb_longStopLbl)))
    label.set_x(ldnOrb_longTp1Lbl, math.max(time, label.get_x(ldnOrb_longTp1Lbl)))
    label.set_x(ldnOrb_longTp2Lbl, math.max(time, label.get_x(ldnOrb_longTp2Lbl)))

if enableLdnOrb and inLdnRTH and inLdnOrbEntryWin and not na(ldnOrb_shortEntryLine)
    line.set_x2(ldnOrb_shortEntryLine, math.max(time, line.get_x2(ldnOrb_shortEntryLine)))
    line.set_x2(ldnOrb_shortStopLine, math.max(time, line.get_x2(ldnOrb_shortStopLine)))
    line.set_x2(ldnOrb_shortTp1Line, math.max(time, line.get_x2(ldnOrb_shortTp1Line)))
    line.set_x2(ldnOrb_shortTp2Line, math.max(time, line.get_x2(ldnOrb_shortTp2Line)))
    label.set_x(ldnOrb_shortStopLbl, math.max(time, label.get_x(ldnOrb_shortStopLbl)))
    label.set_x(ldnOrb_shortTp1Lbl, math.max(time, label.get_x(ldnOrb_shortTp1Lbl)))
    label.set_x(ldnOrb_shortTp2Lbl, math.max(time, label.get_x(ldnOrb_shortTp2Lbl)))

if enableLsiNy and inLsiNyRTH and inLsiNyEntryWin and not na(lsiNy_entryLine)
    line.set_x2(lsiNy_entryLine, math.max(time, line.get_x2(lsiNy_entryLine)))
    line.set_x2(lsiNy_stopLine,  math.max(time, line.get_x2(lsiNy_stopLine)))
    line.set_x2(lsiNy_tp1Line,   math.max(time, line.get_x2(lsiNy_tp1Line)))
    line.set_x2(lsiNy_tp2Line,   math.max(time, line.get_x2(lsiNy_tp2Line)))
    label.set_x(lsiNy_stopLbl,   math.max(time, label.get_x(lsiNy_stopLbl)))
    label.set_x(lsiNy_tp1Lbl,    math.max(time, label.get_x(lsiNy_tp1Lbl)))
    label.set_x(lsiNy_tp2Lbl,    math.max(time, label.get_x(lsiNy_tp2Lbl)))

if enableLsiAsia and inLsiAsiaRTH and inLsiAsiaEntryWin and not na(lsiAsia_entryLine)
    line.set_x2(lsiAsia_entryLine, math.max(time, line.get_x2(lsiAsia_entryLine)))
    line.set_x2(lsiAsia_stopLine,  math.max(time, line.get_x2(lsiAsia_stopLine)))
    line.set_x2(lsiAsia_tp1Line,   math.max(time, line.get_x2(lsiAsia_tp1Line)))
    line.set_x2(lsiAsia_tp2Line,   math.max(time, line.get_x2(lsiAsia_tp2Line)))
    label.set_x(lsiAsia_stopLbl,   math.max(time, label.get_x(lsiAsia_stopLbl)))
    label.set_x(lsiAsia_tp1Lbl,    math.max(time, label.get_x(lsiAsia_tp1Lbl)))
    label.set_x(lsiAsia_tp2Lbl,    math.max(time, label.get_x(lsiAsia_tp2Lbl)))

if enableLdn and inLdnRTH and inLdnEntryWin and not na(ldn_entryLine)
    line.set_x2(ldn_entryLine, math.max(time, line.get_x2(ldn_entryLine)))
    line.set_x2(ldn_stopLine,  math.max(time, line.get_x2(ldn_stopLine)))
    line.set_x2(ldn_tp1Line,   math.max(time, line.get_x2(ldn_tp1Line)))
    line.set_x2(ldn_tp2Line,   math.max(time, line.get_x2(ldn_tp2Line)))
    label.set_x(ldn_stopLbl,   math.max(time, label.get_x(ldn_stopLbl)))
    label.set_x(ldn_tp1Lbl,    math.max(time, label.get_x(ldn_tp1Lbl)))
    label.set_x(ldn_tp2Lbl,    math.max(time, label.get_x(ldn_tp2Lbl)))

// ============================================================================
// VISUALS - ORB LINES (draw once per session, project to entry window end)
// ============================================================================
// NY: create lines once when orb is ready, project to end of entry window
nyShowOrb = enableNY and inNyRTH and inNyEntryWin and ny_orbReady
if nyShowOrb and not ny_orbLinesDrawn and canDraw
    ny_orbLineStart := time
    nyEndBar = calcEndBarTime(nyEntryWindow, "America/New_York")
    ny_orbHighLine := line.new(ny_orbLineStart, ny_orbHigh, nyEndBar, ny_orbHigh, xloc=xloc.bar_time, color=nyOrbHighColor, width=2)
    ny_orbLowLine  := line.new(ny_orbLineStart, ny_orbLow, nyEndBar, ny_orbLow, xloc=xloc.bar_time, color=nyOrbLowColor, width=2)
    ny_orbLinesDrawn := true

if nyShowOrb and ny_orbLinesDrawn and not na(ny_orbHighLine)
    line.set_x2(ny_orbHighLine, math.max(time, line.get_x2(ny_orbHighLine)))
    line.set_x2(ny_orbLowLine, math.max(time, line.get_x2(ny_orbLowLine)))

// Asia: create lines once when orb is ready, project to end of entry window
asiaShowOrb = enableAsia and inAsiaRTH and inAsiaEntryWin and asia_orbReady
if asiaShowOrb and not asia_orbLinesDrawn and canDraw
    asia_orbLineStart := time
    asiaEndBar = calcEndBarTime(asiaEntryWindow, "America/New_York")
    asia_orbHighLine := line.new(asia_orbLineStart, asia_orbHigh, asiaEndBar, asia_orbHigh, xloc=xloc.bar_time, color=asiaOrbHighColor, width=2)
    asia_orbLowLine  := line.new(asia_orbLineStart, asia_orbLow, asiaEndBar, asia_orbLow, xloc=xloc.bar_time, color=asiaOrbLowColor, width=2)
    asia_orbLinesDrawn := true

if asiaShowOrb and asia_orbLinesDrawn and not na(asia_orbHighLine)
    line.set_x2(asia_orbHighLine, math.max(time, line.get_x2(asia_orbHighLine)))
    line.set_x2(asia_orbLowLine, math.max(time, line.get_x2(asia_orbLowLine)))

// LDN ORB: create lines once when orb is ready, project to end of entry window
ldnOrbShowOrb = enableLdnOrb and inLdnRTH and inLdnOrbEntryWin and ldnOrb_orbReady
if ldnOrbShowOrb and not ldnOrb_orbLinesDrawn and canDraw
    ldnOrb_orbLineStart := time
    ldnOrbEndBar = calcEndBarTime(i_nqLdnOrbEntryWindow, "America/New_York")
    ldnOrb_orbHighLine := line.new(ldnOrb_orbLineStart, ldnOrb_orbHigh, ldnOrbEndBar, ldnOrb_orbHigh, xloc=xloc.bar_time, color=nqLdnOrbHighColor, width=2)
    ldnOrb_orbLowLine  := line.new(ldnOrb_orbLineStart, ldnOrb_orbLow, ldnOrbEndBar, ldnOrb_orbLow, xloc=xloc.bar_time, color=nqLdnOrbLowColor, width=2)
    ldnOrb_orbLinesDrawn := true

if ldnOrbShowOrb and ldnOrb_orbLinesDrawn and not na(ldnOrb_orbHighLine)
    line.set_x2(ldnOrb_orbHighLine, math.max(time, line.get_x2(ldnOrb_orbHighLine)))
    line.set_x2(ldnOrb_orbLowLine, math.max(time, line.get_x2(ldnOrb_orbLowLine)))

// ============================================================================
// ATR DISTANCE DISPLAY + DEBUG
// ============================================================================
displayATR       = enableNY ? nyDailyATR : asiaDailyATR
displayAtrLength = enableNY ? nyAtrLength : asiaAtrLength
globexDist  = close - globexOpen
globexPct   = displayATR > 0 ? (globexDist / displayATR) * 100 : 0.0
globexSign  = globexDist >= 0 ? "+" : ""
globexColor = globexDist >= 0 ? color.new(#26a69a, 0) : color.new(#ef5350, 0)

var table atrTable = table.new(position.top_right, 1, 3, bgcolor=color.new(#1e222d, 10), border_width=1, border_color=color.new(#363a45, 0))
if barstate.islast
    atrText = "ATR(" + str.tostring(displayAtrLength) + "): " + str.tostring(displayATR, format.mintick)
    globexText = "GlobEx: " + globexSign + str.tostring(globexDist, format.mintick) + " (" + globexSign + str.tostring(globexPct, "#.0") + "% ATR)"
    debugText = "root=" + syminfo.root + " | asset=" + asset + " | RR=" + str.tostring(nyRR) + " | ATR_len=" + str.tostring(nyAtrLength) + " | stop%=" + str.tostring(nyStopPct)
    table.cell(atrTable, 0, 0, atrText, text_color=color.white, text_size=size.small)
    table.cell(atrTable, 0, 1, globexText, text_color=globexColor, text_size=size.small)
    table.cell(atrTable, 0, 2, debugText, text_color=color.yellow, text_size=size.small)

// ============================================================================
// ALERTS - fire when a new setup is detected (must enable in settings)
// ============================================================================
// LSI direction strings
lsiNyDirStr   = lsiNy_dir == 1 ? "Long" : "Short"
lsiAsiaDirStr = lsiAsia_dir == 1 ? "Long" : "Short"
ldnDirStr     = ldn_dir == 1 ? "Long" : "Short"

// LSI alert() calls with direction info
if lsiNy_setupAlert
    alert(asset + " NY LSI " + lsiNyDirStr + " armed @ " + str.tostring(lsiNy_entry, format.mintick) + " | SL " + str.tostring(lsiNy_stop, format.mintick) + " | TP1 " + str.tostring(lsiNy_tp1, format.mintick) + " | TP2 " + str.tostring(lsiNy_tp2, format.mintick), alert.freq_once_per_bar_close)

if lsiAsia_setupAlert
    alert(asset + " Asia LSI " + lsiAsiaDirStr + " armed @ " + str.tostring(lsiAsia_entry, format.mintick) + " | SL " + str.tostring(lsiAsia_stop, format.mintick) + " | TP1 " + str.tostring(lsiAsia_tp1, format.mintick) + " | TP2 " + str.tostring(lsiAsia_tp2, format.mintick), alert.freq_once_per_bar_close)

if ldn_setupAlert
    alert(asset + " LDN LSI " + ldnDirStr + " armed @ " + str.tostring(ldn_entry, format.mintick) + " | SL " + str.tostring(ldn_stop, format.mintick) + " | TP1 " + str.tostring(ldn_tp1, format.mintick) + " | TP2 " + str.tostring(ldn_tp2, format.mintick), alert.freq_once_per_bar_close)

if ldnOrb_longSetupAlert
    alert(asset + " LDN ORB Long @ " + str.tostring(ldnOrb_longEntry, format.mintick) + " | SL " + str.tostring(ldnOrb_longStop, format.mintick) + " | TP1 " + str.tostring(ldnOrb_longTp1, format.mintick) + " | TP2 " + str.tostring(ldnOrb_longTp2, format.mintick), alert.freq_once_per_bar_close)

if ldnOrb_shortSetupAlert
    alert(asset + " LDN ORB Short @ " + str.tostring(ldnOrb_shortEntry, format.mintick) + " | SL " + str.tostring(ldnOrb_shortStop, format.mintick) + " | TP1 " + str.tostring(ldnOrb_shortTp1, format.mintick) + " | TP2 " + str.tostring(ldnOrb_shortTp2, format.mintick), alert.freq_once_per_bar_close)

alertcondition(ny_longSetupAlert,   "NY Long Setup",   "NY long FVG setup detected")
alertcondition(ny_shortSetupAlert,  "NY Short Setup",  "NY short FVG setup detected")
alertcondition(asia_longSetupAlert,  "Asia Long Setup",  "Asia long FVG setup detected")
alertcondition(asia_shortSetupAlert, "Asia Short Setup", "Asia short FVG setup detected")
alertcondition(lsiNy_setupAlert,    "NQ NY LSI Setup",   "NQ NY LSI setup armed")
alertcondition(lsiAsia_setupAlert,  "NQ Asia LSI Setup", "NQ Asia LSI setup armed")
alertcondition(ldn_setupAlert,      "NQ LDN LSI Setup",  "NQ LDN LSI setup armed")
alertcondition(ldnOrb_longSetupAlert,  "NQ LDN ORB Long Setup",  "NQ LDN ORB long FVG setup detected")
alertcondition(ldnOrb_shortSetupAlert, "NQ LDN ORB Short Setup", "NQ LDN ORB short FVG setup detected")
alertcondition(ny_longSetupAlert or ny_shortSetupAlert or asia_longSetupAlert or asia_shortSetupAlert or ldnOrb_longSetupAlert or ldnOrb_shortSetupAlert, "Any ORB Setup", "ORB FVG setup detected")
alertcondition(lsiNy_setupAlert or lsiAsia_setupAlert or ldn_setupAlert, "Any LSI Setup", "LSI setup armed")
