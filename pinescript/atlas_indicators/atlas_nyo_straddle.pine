//@version=6
indicator(
     title   = "NYO Straddle Gate [atlasfutures]",
     overlay = true
)

// ============================================================================
// INPUTS
// ============================================================================
i_maxAtrPct     = input.float(1.74, "Max ATR %", step=0.01, tooltip="Skip day if prior-day ATR(14) / close > this %", group="Filters")
i_minVolRatio   = input.float(1.26, "Min Vol Ratio", step=0.01, tooltip="Skip day if today's volume / 21d avg volume < this", group="Filters")
i_tablePosition = input.string("Bottom Right", "Table Position", options=["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group="Display")
i_tableSize     = input.string("Normal", "Text Size", options=["Small", "Normal", "Large"], group="Display")

// ============================================================================
// TABLE POSITION + SIZE LOOKUP
// ============================================================================
tablePos = switch i_tablePosition
    "Top Left"     => position.top_left
    "Top Right"    => position.top_right
    "Bottom Left"  => position.bottom_left
    => position.bottom_right

textSize = switch i_tableSize
    "Small" => size.small
    "Large" => size.large
    => size.normal

// ============================================================================
// CUSTOM DAILY ATR — midnight-ET boundaries (matches Python engine exactly)
//
// Pine's request.security("D", ta.atr()) uses exchange session boundaries
// (6 PM ET → 5 PM ET for CME futures), but the Python backtester resamples
// 5m bars by calendar date (midnight ET → midnight ET). This causes a 10-15%
// ATR discrepancy. The fix: accumulate 5m OHLC into daily bars at midnight ET,
// then compute Wilder's ATR manually.
// ============================================================================

// Detect midnight ET boundary using 5m bar times (works on any chart TF)
regTicker_atr = ticker.new(syminfo.prefix, syminfo.ticker, session.regular)
[atr_h5, atr_l5, atr_c5, atr_t5] = request.security(regTicker_atr, "5", [high, low, close, time], lookahead=barmerge.lookahead_on)
atr_barClosed5 = ta.change(atr_t5) != 0
atr_curDay     = dayofmonth(atr_t5, "America/New_York")

// Accumulate daily OHLC from 5m bars (midnight-to-midnight ET)
var float atr_dayHigh  = na
var float atr_dayLow   = na
var float atr_dayClose = na
var int   atr_lastDay  = -1   // track last seen calendar day
var float atr_lastClose = na  // close of the most recently completed day

// ATR state (Wilder's smoothing, period=14)
var int   ATR_LENGTH     = 14
var float atr_value      = na   // ATR exposed to bars (lagged 1 completed day)
var float atr_building   = na   // latest computed ATR
var int   atr_dayCount   = 0
var array<float> atr_trHistory = array.new<float>(0)

if atr_barClosed5
    // Check for calendar day transition
    if atr_lastDay != -1 and atr_curDay != atr_lastDay and not na(atr_dayHigh)
        // Close out the previous calendar day
        if not na(atr_lastClose)
            tr = math.max(atr_dayHigh - atr_dayLow, math.max(math.abs(atr_dayHigh - atr_lastClose), math.abs(atr_dayLow - atr_lastClose)))
            atr_dayCount += 1
            if atr_dayCount <= ATR_LENGTH
                array.push(atr_trHistory, tr)
                if atr_dayCount == ATR_LENGTH
                    sum = 0.0
                    for i = 0 to ATR_LENGTH - 1
                        sum += array.get(atr_trHistory, i)
                    atr_building := sum / ATR_LENGTH
            else
                atr_building := (atr_building * (ATR_LENGTH - 1) + tr) / ATR_LENGTH
        // Lag: bars during the NEW day see ATR through the PREVIOUS completed day
        atr_value    := atr_building
        atr_lastClose := atr_dayClose
        // Reset accumulator
        atr_dayHigh  := atr_h5
        atr_dayLow   := atr_l5
        atr_dayClose := atr_c5
    else
        // Same day — accumulate
        atr_dayHigh  := na(atr_dayHigh) ? atr_h5 : math.max(atr_dayHigh, atr_h5)
        atr_dayLow   := na(atr_dayLow)  ? atr_l5 : math.min(atr_dayLow, atr_l5)
        atr_dayClose := atr_c5
    atr_lastDay := atr_curDay

dailyATR14 = atr_value

// ============================================================================
// DAILY CLOSE + VOLUME DATA
// ============================================================================
[dailyClose, dailyVolume, dailyVolMA21] = request.security(
     syminfo.tickerid, "D",
     [close[1], volume, ta.sma(volume, 21)],
     lookahead = barmerge.lookahead_on
)

// ============================================================================
// COMPUTE REGIME FEATURES
// ============================================================================
atrPct   = dailyClose > 0 ? (dailyATR14 / dailyClose) * 100 : na
volRatio = dailyVolMA21 > 0 ? dailyVolume / dailyVolMA21 : na

// ============================================================================
// GATE LOGIC
// ============================================================================
atrPass = na(atrPct) ? false : atrPct <= i_maxAtrPct
volPass = na(volRatio) ? false : volRatio >= i_minVolRatio
allPass = atrPass and volPass

// ============================================================================
// TABLE DISPLAY
// ============================================================================
var table tbl = table.new(tablePos, 2, 4, border_width=1)

if barstate.islast
    // Colors
    passColor = #3dd68c
    failColor = #f0615e
    mutedColor = #62626b
    bgColor = #1c1c21
    borderColor = #2c2c33

    // Row 0: Title
    table.cell(tbl, 0, 0, "NYO Straddle", text_color=allPass ? passColor : failColor, text_size=textSize, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(tbl, 1, 0, allPass ? "YES" : "NO", text_color=allPass ? passColor : failColor, text_size=textSize, bgcolor=bgColor, text_halign=text.align_right)

    // Row 1: ATR %
    atrStr = na(atrPct) ? "—" : str.tostring(atrPct, "#.##") + "%"
    table.cell(tbl, 0, 1, "ATR %", text_color=mutedColor, text_size=size.small, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(tbl, 1, 1, atrStr + (atrPass ? "" : " > " + str.tostring(i_maxAtrPct, "#.##")), text_color=atrPass ? passColor : failColor, text_size=size.small, bgcolor=bgColor, text_halign=text.align_right)

    // Row 2: Vol Ratio
    volStr = na(volRatio) ? "—" : str.tostring(volRatio, "#.##")
    table.cell(tbl, 0, 2, "Vol Ratio", text_color=mutedColor, text_size=size.small, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(tbl, 1, 2, volStr + (volPass ? "" : " < " + str.tostring(i_minVolRatio, "#.##")), text_color=volPass ? passColor : failColor, text_size=size.small, bgcolor=bgColor, text_halign=text.align_right)

    // Row 3: Thresholds summary
    table.cell(tbl, 0, 3, "Thresholds", text_color=mutedColor, text_size=size.tiny, bgcolor=bgColor, text_halign=text.align_left)
    table.cell(tbl, 1, 3, "ATR<" + str.tostring(i_maxAtrPct, "#.##") + "  Vol>" + str.tostring(i_minVolRatio, "#.##"), text_color=mutedColor, text_size=size.tiny, bgcolor=bgColor, text_halign=text.align_right)
