// LDN STATE
// ============================================================================
var ldn_bearFvgs = array.new<FvgZone>(0)
var ldn_bullFvgs = array.new<FvgZone>(0)
var bool  ldn_armed = false
var int   ldn_dir   = 0
var float ldn_entry = na
