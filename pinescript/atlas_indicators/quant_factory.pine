//@version=6
indicator(
     title              = "Indicator [The Quant Factory]",
     overlay            = true,
     max_lines_count    = 500,
     max_boxes_count    = 500,
     max_labels_count   = 500
)

// ============================================================================
// AUTO-DETECT ASSET from chart symbol
// ============================================================================
asset = if syminfo.root == "ES" or syminfo.root == "MES"
    "ES"
else if syminfo.root == "NQ" or syminfo.root == "MNQ"
    "NQ"
else if syminfo.root == "GC" or syminfo.root == "MGC"
    "GC"
else
    "ES"

// ============================================================================
// INPUTS - Display
// ============================================================================
drawbackDays = input.int(1, "Days Back", minval=1, maxval=50, tooltip="Number of trading days to show drawings for", group="Display")

// ============================================================================
// INPUTS - ES: NY
// ============================================================================
i_esOrbSession   = input.session("0930-0945", "ORB Window (ny time)", group="ES: NY")
i_esEntryWindow  = input.session("0945-1300", "Entry Window (ny time)", group="ES: NY")
i_esDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="ES: NY")
i_esImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="ES: NY")
i_esRR           = input.float(5.0, "Reward/Risk", step=0.25, group="ES: NY")
i_esTp1Ratio     = input.float(0.2, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="ES: NY")
i_esStopMode     = input.string("ATR", "Stop Size Mode", options=["ATR", "ORB"], group="ES: NY")
i_esAtrLength    = input.int(7, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="ES: NY")
i_esStopPct      = input.float(5.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="ES: NY")
i_esMinGapPct    = input.float(0.25, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="ES: NY")
esOrbHighColor   = input.color(#18b79c, "ORB High Color", group="ES: NY")
esOrbLowColor    = input.color(#94E3DA, "ORB Low Color", group="ES: NY")

// ============================================================================
// INPUTS - ES: Asia
// ============================================================================
i_esAsiaOrbSession   = input.session("2000-2015", "ORB Window (ny time)", group="ES: Asia")
i_esAsiaEntryWindow  = input.session("2015-0300", "Entry Window (ny time)", group="ES: Asia")
i_esAsiaDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="ES: Asia")
i_esAsiaImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="ES: Asia")
i_esAsiaRR           = input.float(1.5, "Reward/Risk", step=0.25, group="ES: Asia")
i_esAsiaTp1Ratio     = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="ES: Asia")
i_esAsiaStopMode     = input.string("ORB", "Stop Size Mode", options=["ATR", "ORB"], group="ES: Asia")
i_esAsiaAtrLength    = input.int(14, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="ES: Asia")
i_esAsiaStopPct      = input.float(125.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="ES: Asia")
i_esAsiaMinGapPct    = input.float(0.5, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="ES: Asia")
esAsiaOrbHighColor   = input.color(#2196F3, "ORB High Color", group="ES: Asia")
esAsiaOrbLowColor    = input.color(#A5DFFA, "ORB Low Color", group="ES: Asia")

// ============================================================================
// INPUTS - NQ: NY
// ============================================================================
i_nqNyOrbSession   = input.session("0930-0950", "ORB Window (ny time)", group="NQ: NY")
i_nqNyEntryWindow  = input.session("0950-1200", "Entry Window (ny time)", group="NQ: NY")
i_nqNyDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: NY")
i_nqNyImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="NQ: NY")
i_nqNyRR           = input.float(3.5, "Reward/Risk", step=0.25, group="NQ: NY")
i_nqNyTp1Ratio     = input.float(0.4, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: NY")
i_nqNyStopMode     = input.string("ATR", "Stop Size Mode", options=["ATR", "ORB"], group="NQ: NY")
i_nqNyAtrLength    = input.int(12, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="NQ: NY")
i_nqNyStopPct      = input.float(7.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="NQ: NY")
i_nqNyMinGapPct    = input.float(2.5, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="NQ: NY")
nqNyOrbHighColor   = input.color(#18b79c, "ORB High Color", group="NQ: NY")
nqNyOrbLowColor    = input.color(#94E3DA, "ORB Low Color", group="NQ: NY")

// ============================================================================
// INPUTS - NQ: Asia
// ============================================================================
i_nqAsiaOrbSession   = input.session("2000-2015", "ORB Window (ny time)", group="NQ: Asia")
i_nqAsiaEntryWindow  = input.session("2015-2230", "Entry Window (ny time)", group="NQ: Asia")
i_nqAsiaDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: Asia")
i_nqAsiaImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="NQ: Asia")
i_nqAsiaRR           = input.float(6.0, "Reward/Risk", step=0.25, group="NQ: Asia")
i_nqAsiaTp1Ratio     = input.float(0.3, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: Asia")
i_nqAsiaStopMode     = input.string("ORB", "Stop Size Mode", options=["ATR", "ORB"], group="NQ: Asia")
i_nqAsiaAtrLength    = input.int(5, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="NQ: Asia")
i_nqAsiaStopPct      = input.float(100.0, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="NQ: Asia")
i_nqAsiaMinGapPct    = input.float(10.0, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="NQ: Asia")
nqAsiaOrbHighColor   = input.color(#2196F3, "ORB High Color", group="NQ: Asia")
nqAsiaOrbLowColor    = input.color(#A5DFFA, "ORB Low Color", group="NQ: Asia")

// ============================================================================
// INPUTS - GC: NY
// ============================================================================
i_gcOrbSession   = input.session("0930-0938", "ORB Window (ny time)", group="GC: NY")
i_gcEntryWindow  = input.session("0938-1200", "Entry Window (ny time)", group="GC: NY")
i_gcDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="GC: NY")
i_gcImpulseClose = input.bool(true, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="GC: NY")
i_gcRR           = input.float(9.0, "Reward/Risk", step=0.25, group="GC: NY")
i_gcTp1Ratio     = input.float(0.35, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="GC: NY")
i_gcStopMode     = input.string("ATR", "Stop Size Mode", options=["ATR", "ORB"], group="GC: NY")
i_gcAtrLength    = input.int(7, "ATR Length", minval=1, tooltip="Only used when Stop Size Mode is ATR", group="GC: NY")
i_gcStopPct      = input.float(4.5, "Stop (%)", step=0.5, minval=0.5, tooltip="Percentage of daily ATR or ORB range", group="GC: NY")
i_gcMinGapPct    = input.float(3.0, "Min Gap (%)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR or ORB range", group="GC: NY")
gcOrbHighColor   = input.color(#18b79c, "ORB High Color", group="GC: NY")
gcOrbLowColor    = input.color(#94E3DA, "ORB Low Color", group="GC: NY")

// ============================================================================
// INPUTS - NQ: NY LSI
// ============================================================================
i_nqLsiNyEntryWindow  = input.session("0935-1530", "Entry Window (ny time)", group="NQ: NY LSI")
i_nqLsiNyDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: NY LSI")
i_nqLsiNyRR           = input.float(3.0, "Reward/Risk", step=0.25, group="NQ: NY LSI")
i_nqLsiNyTp1Ratio     = input.float(0.3, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: NY LSI")
i_nqLsiNyAtrLength    = input.int(10, "ATR Length", minval=1, group="NQ: NY LSI")
i_nqLsiNyStopPct      = input.float(5.0, "Stop (% ATR)", step=0.5, minval=0.5, tooltip="Stop distance as percentage of daily ATR", group="NQ: NY LSI")
i_nqLsiNyMinGapPct    = input.float(5.0, "Min Gap (% ATR)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR", group="NQ: NY LSI")
nqLsiNyFvgPendColor   = input.color(#FF9800, "FVG Pending Color", group="NQ: NY LSI")
nqLsiNyFvgSweptColor  = input.color(#26a69a, "FVG Swept Color", group="NQ: NY LSI")

// ============================================================================
// INPUTS - NQ: Asia LSI
// ============================================================================
i_nqLsiAsiaEntryWindow  = input.session("2040-2330", "Entry Window (ny time)", group="NQ: Asia LSI")
i_nqLsiAsiaDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: Asia LSI")
i_nqLsiAsiaRR           = input.float(2.0, "Reward/Risk", step=0.25, group="NQ: Asia LSI")
i_nqLsiAsiaTp1Ratio     = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: Asia LSI")
i_nqLsiAsiaAtrLength    = input.int(40, "ATR Length", minval=1, group="NQ: Asia LSI")
i_nqLsiAsiaStopPct      = input.float(5.0, "Stop (% ATR)", step=0.5, minval=0.5, tooltip="Stop distance as percentage of daily ATR", group="NQ: Asia LSI")
i_nqLsiAsiaMinGapPct    = input.float(1.75, "Min Gap (% ATR)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR", group="NQ: Asia LSI")
nqLsiAsiaFvgPendColor   = input.color(#9C27B0, "FVG Pending Color", group="NQ: Asia LSI")
nqLsiAsiaFvgSweptColor  = input.color(#2196F3, "FVG Swept Color", group="NQ: Asia LSI")

// ============================================================================
// INPUTS - NQ: LDN LSI
// ============================================================================
i_nqLdnEntryWindow  = input.session("0330-0700", "Entry Window (ny time)", group="NQ: LDN LSI")
i_nqLdnDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: LDN LSI")
i_nqLdnRR           = input.float(1.65, "Reward/Risk", step=0.05, group="NQ: LDN LSI")
i_nqLdnTp1Ratio     = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: LDN LSI")
i_nqLdnAtrLength    = input.int(10, "ATR Length", minval=1, group="NQ: LDN LSI")
i_nqLdnStopPct      = input.float(5.0, "Stop (% ATR)", step=0.5, minval=0.5, tooltip="Stop distance as percentage of daily ATR", group="NQ: LDN LSI")
i_nqLdnMinGapPct    = input.float(5.0, "Min Gap (% ATR)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR", group="NQ: LDN LSI")
nqLdnFvgPendColor   = input.color(#4CAF50, "FVG Pending Color", group="NQ: LDN LSI")
nqLdnFvgSweptColor  = input.color(#26a69a, "FVG Swept Color", group="NQ: LDN LSI")

// ============================================================================
// INPUTS - NQ: LDN ORB
// ============================================================================
i_nqLdnOrbSession    = input.session("0300-0330", "ORB Window (ny time)", group="NQ: LDN ORB")
i_nqLdnOrbEntryWindow = input.session("0330-0825", "Entry Window (ny time)", group="NQ: LDN ORB")
i_nqLdnOrbDirection  = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: LDN ORB")
i_nqLdnOrbImpulseClose = input.bool(false, "Impulse Close Filter", tooltip="Accept FVGs where the impulse candle closes beyond ORB", group="NQ: LDN ORB")
i_nqLdnOrbRR         = input.float(6.0, "Reward/Risk", step=0.25, group="NQ: LDN ORB")
i_nqLdnOrbTp1Ratio   = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: LDN ORB")
i_nqLdnOrbAtrLength  = input.int(10, "ATR Length", minval=1, group="NQ: LDN ORB")
i_nqLdnOrbStopPct    = input.float(1.5, "Stop (% ATR)", step=0.5, minval=0.5, tooltip="Stop distance as percentage of daily ATR", group="NQ: LDN ORB")
i_nqLdnOrbMinGapPct  = input.float(1.0, "Min Gap (% ATR)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR", group="NQ: LDN ORB")
nqLdnOrbHighColor    = input.color(#FF9800, "ORB High Color", group="NQ: LDN ORB")
nqLdnOrbLowColor     = input.color(#FFB74D, "ORB Low Color", group="NQ: LDN ORB")

// ============================================================================
// INPUTS - Trade Level Colors
// ============================================================================
entryColor = input.color(#787b86, "Entry Color", inline="entry", group="Trade Level Colors")
entryStyle = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="entry", group="Trade Level Colors")
slColor    = input.color(#787b86, "SL Color", inline="sl", group="Trade Level Colors")
slStyle    = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="sl", group="Trade Level Colors")
tp1Color   = input.color(#787b86, "TP1 Color", inline="tp1", group="Trade Level Colors")
tp1Style   = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="tp1", group="Trade Level Colors")
tp2Color   = input.color(#787b86, "TP2 Color", inline="tp2", group="Trade Level Colors")
tp2Style   = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="tp2", group="Trade Level Colors")

// ============================================================================
// INPUTS - Alerts
// ============================================================================
enableAlerts = input.bool(false, "Enable Setup Alerts", tooltip="Enable alert conditions for when a new FVG setup is detected", group="Alerts")

// ============================================================================
// RESOLVE ACTIVE CONFIG — select from per-asset inputs
// ============================================================================
enableNY   = asset == "ES" or asset == "NQ" or asset == "GC"
enableAsia = asset == "NQ" or asset == "ES"
enableLsiNy   = asset == "NQ"
enableLsiAsia = asset == "NQ"
enableLdn     = asset == "NQ"
enableLdnOrb  = asset == "NQ"

// Session RTH (fixed, same for all assets)
nySessionRTH   = "0930-1600"
asiaSessionRTH = "1800-0700"
ldnSessionRTH  = "0200-1000"

// NY session times
nyOrbSession = if asset == "ES"
    i_esOrbSession
else if asset == "NQ"
    i_nqNyOrbSession
else if asset == "GC"
    i_gcOrbSession
else
    i_esOrbSession

nyEntryWindow = if asset == "ES"
    i_esEntryWindow
else if asset == "NQ"
    i_nqNyEntryWindow
else if asset == "GC"
    i_gcEntryWindow
else
    i_esEntryWindow

// NY direction
nyDirection = if asset == "ES"
    i_esDirection
else if asset == "NQ"
    i_nqNyDirection
else if asset == "GC"
    i_gcDirection
else
    "Long Only"

asiaDirection = if asset == "ES"
    i_esAsiaDirection
else if asset == "NQ"
    i_nqAsiaDirection
else
    "Long Only"

// NY trade params
nyRR = if asset == "ES"
    i_esRR
else if asset == "NQ"
    i_nqNyRR
else if asset == "GC"
    i_gcRR
else
    i_esRR

nyTp1Ratio = if asset == "ES"
    i_esTp1Ratio
else if asset == "NQ"
    i_nqNyTp1Ratio
else if asset == "GC"
    i_gcTp1Ratio
else
    i_esTp1Ratio

nyImpulseClose = if asset == "ES"
    i_esImpulseClose
else if asset == "NQ"
    i_nqNyImpulseClose
else if asset == "GC"
    i_gcImpulseClose
else
    false

nyStopMode = if asset == "ES"
    i_esStopMode
else if asset == "NQ"
    i_nqNyStopMode
else if asset == "GC"
    i_gcStopMode
else
    "ATR"

nyStopPct = if asset == "ES"
    i_esStopPct
else if asset == "NQ"
    i_nqNyStopPct
else if asset == "GC"
    i_gcStopPct
else
    i_esStopPct

nyMinGapPct = if asset == "ES"
    i_esMinGapPct
else if asset == "NQ"
    i_nqNyMinGapPct
else if asset == "GC"
    i_gcMinGapPct
else
    i_esMinGapPct

// Per-session ATR lengths
nyAtrLength = if asset == "ES"
    i_esAtrLength
else if asset == "NQ"
    i_nqNyAtrLength
else if asset == "GC"
    i_gcAtrLength
else
    i_esAtrLength

asiaAtrLength = if asset == "ES"
    i_esAsiaAtrLength
else if asset == "NQ"
    i_nqAsiaAtrLength
else
    14

// Asia session times
asiaOrbSession = if asset == "ES"
    i_esAsiaOrbSession
else if asset == "NQ"
    i_nqAsiaOrbSession
else
    "2000-2015"

asiaEntryWindow = if asset == "ES"
    i_esAsiaEntryWindow
else if asset == "NQ"
    i_nqAsiaEntryWindow
else
    "2015-2230"

// Asia trade params
asiaRR = if asset == "ES"
    i_esAsiaRR
else if asset == "NQ"
    i_nqAsiaRR
else
    6.0

asiaTp1Ratio = if asset == "ES"
    i_esAsiaTp1Ratio
else if asset == "NQ"
    i_nqAsiaTp1Ratio
else
    0.3

asiaImpulseClose = if asset == "ES"
    i_esAsiaImpulseClose
else if asset == "NQ"
    i_nqAsiaImpulseClose
else
    false

asiaStopMode = if asset == "ES"
    i_esAsiaStopMode
else if asset == "NQ"
    i_nqAsiaStopMode
else
    "ORB"

asiaStopPct = if asset == "ES"
    i_esAsiaStopPct
else if asset == "NQ"
    i_nqAsiaStopPct
else
    100.0

asiaMinGapPct = if asset == "ES"
    i_esAsiaMinGapPct
else if asset == "NQ"
    i_nqAsiaMinGapPct
else
    10.0

// ORB colors
nyOrbHighColor = if asset == "ES"
    esOrbHighColor
else if asset == "NQ"
    nqNyOrbHighColor
else if asset == "GC"
    gcOrbHighColor
else
    esOrbHighColor

nyOrbLowColor = if asset == "ES"
    esOrbLowColor
else if asset == "NQ"
    nqNyOrbLowColor
else if asset == "GC"
    gcOrbLowColor
else
    esOrbLowColor

asiaOrbHighColor = if asset == "ES"
    esAsiaOrbHighColor
else if asset == "NQ"
    nqAsiaOrbHighColor
else
    #2196F3

asiaOrbLowColor = if asset == "ES"
    esAsiaOrbLowColor
else if asset == "NQ"
    nqAsiaOrbLowColor
else
    #A5DFFA

// ============================================================================
// LINE STYLE LOOKUP
// ============================================================================
styleToLine(s) =>
    s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed
entryLineStyle = styleToLine(entryStyle)
slLineStyle    = styleToLine(slStyle)
tp1LineStyle   = styleToLine(tp1Style)
tp2LineStyle   = styleToLine(tp2Style)

// ============================================================================
// SESSION FILTERS - use "5" resolution so sessions are detected correctly
// even on higher timeframes (e.g. 15m bar spanning the entire ORB window)
// ============================================================================
inNyRTH      = not na(time("5", nySessionRTH, "America/New_York"))
inNyORB      = not na(time("5", nyOrbSession, "America/New_York"))
inNyEntryWin = not na(time("5", nyEntryWindow, "America/New_York"))
inAsiaRTH      = not na(time("5", asiaSessionRTH, "America/New_York"))
inAsiaORB      = not na(time("5", asiaOrbSession, "America/New_York"))
inAsiaEntryWin = not na(time("5", asiaEntryWindow, "America/New_York"))
inLsiNyRTH       = not na(time("5", nySessionRTH,            "America/New_York"))
inLsiNyEntryWin  = not na(time("5", i_nqLsiNyEntryWindow,    "America/New_York"))
inLsiAsiaRTH     = not na(time("5", asiaSessionRTH,          "America/New_York"))
inLsiAsiaEntryWin= not na(time("5", i_nqLsiAsiaEntryWindow,  "America/New_York"))
inLdnRTH         = not na(time("5", ldnSessionRTH,           "America/New_York"))
inLdnEntryWin    = not na(time("5", i_nqLdnEntryWindow,      "America/New_York"))
inLdnOrbORB      = not na(time("5", i_nqLdnOrbSession,      "America/New_York"))
inLdnOrbEntryWin = not na(time("5", i_nqLdnOrbEntryWindow,  "America/New_York"))

// ============================================================================
// 5m OHLC - stable confirmed data via lookahead_on + [1] offset
// uses regular session ticker so 5m bars align identically on all chart tfs
// c5_1 / o5_1 = impulse candle close/open (for impulse close filter)
// ============================================================================
regTicker = ticker.new(syminfo.prefix, syminfo.ticker, session.regular)
[h5, l5, h5_1, l5_1, h5_2, l5_2, c5_1, o5_1, c5, t5, t5_2] = request.security(regTicker, "5", [high[1], low[1], high[2], low[2], high[3], low[3], close[2], open[2], close[1], time[1], time[3]], lookahead=barmerge.lookahead_on)
barClosed5 = ta.change(t5) != 0

// ORB OHLC - current bar data (no [1] shift) so the opening range uses the
// actual 5m candles inside the ORB window instead of the delayed FVG feed.
[orbH5, orbL5, orbC5, orbT5] = request.security(regTicker, "5", [high, low, close, time], lookahead=barmerge.lookahead_on)
orbBarClosed5 = ta.change(orbT5) != 0

// Session start detection (rising edge of session filter)
nyRTHStart   = inNyRTH and not inNyRTH[1]
asiaRTHStart = inAsiaRTH and not inAsiaRTH[1]
lsiNyRTHStart   = inLsiNyRTH  and not inLsiNyRTH[1]
lsiAsiaRTHStart = inLsiAsiaRTH and not inLsiAsiaRTH[1]
ldnRTHStart     = inLdnRTH    and not inLdnRTH[1]

// ============================================================================
// DRAWBACK FILTER - only draw recent N days
// ============================================================================
barsPerDay = timeframe.in_seconds("D") / timeframe.in_seconds(timeframe.period)
canDraw    = bar_index >= last_bar_index - drawbackDays * barsPerDay

// ============================================================================
// DIRECTION FLAGS
// ============================================================================
nyDetectLongs    = nyDirection != "Short Only"
nyDetectShorts   = nyDirection != "Long Only"
asiaDetectLongs  = asiaDirection != "Short Only"
asiaDetectShorts = asiaDirection != "Long Only"
lsiNyDetectLongs    = i_nqLsiNyDirection != "Short Only"
lsiNyDetectShorts   = i_nqLsiNyDirection != "Long Only"
lsiAsiaDetectLongs  = i_nqLsiAsiaDirection != "Short Only"
lsiAsiaDetectShorts = i_nqLsiAsiaDirection != "Long Only"
ldnDetectLongs      = i_nqLdnDirection != "Short Only"
ldnDetectShorts     = i_nqLdnDirection != "Long Only"
ldnOrbDetectLongs   = i_nqLdnOrbDirection != "Short Only"
ldnOrbDetectShorts  = i_nqLdnOrbDirection != "Long Only"

// ============================================================================
// FVG ZONE TYPE (shared by all LSI sessions)
// ============================================================================
type FvgZone
    float top
    float bot
    int   startTime
    box   bx
    label lbl

// ============================================================================
// NY ORB STATE
// ============================================================================
var float ny_orbHigh = na
var float ny_orbLow  = na
var bool  ny_orbReady = false

var bool  ny_longFirstFvgFound  = false
var bool  ny_shortFirstFvgFound = false

var float ny_longFvgTopStored  = na
var float ny_longFvgBotStored  = na
var int   ny_longFvgStartTime  = na
