        ldnOrb_longTp2Lbl  := label.new(ldnOrbEndBar, ldnOrb_longTp2, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

if ldnOrbCanDetect and not ldnOrb_shortFirstFvgFound and ldnOrbShortFVG
