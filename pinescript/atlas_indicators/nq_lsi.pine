//@version=6
strategy(
     title="NQ HTF-LSI Strategy [atlasfutures]",
     overlay=true,
     initial_capital=50000,
     pyramiding=0,
     margin_long=0,
     margin_short=0,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=0.0,
     calc_on_every_tick=true,
     process_orders_on_close=true,
     use_bar_magnifier=true,
     fill_orders_on_standard_ohlc=false
)

// Derived from atlas_lsi.pine.
// This strategy includes the live ALPHA_V1 NQ NY HTF-LSI lag24 long leg.

// ============================================================================
// INPUTS
// ============================================================================
groupRisk = "Risk"
groupLeg = "ALPHA_V1 NQ NY HTF-LSI Lag24"

i_riskUsd = input.float(500.0, "Risk per Trade ($)", minval=1.0, step=50.0, group=groupRisk)
i_maxSingleRiskUsd = input.float(750.0, "Max 1-Contract Risk ($)", minval=0.0, step=50.0, group=groupRisk)
i_pointValue = input.float(20.0, "Point Value ($)", minval=0.01, step=0.25, group=groupRisk)
i_minQty = input.float(1.0, "Min Qty", minval=0.0, step=1.0, group=groupRisk)
i_qtyStep = input.float(1.0, "Qty Step", minval=0.01, step=1.0, group=groupRisk)
i_useBreakeven = input.bool(true, "Move Runner To Breakeven After TP1", group=groupRisk)

i_sweepWindow = input.session("0830-1500", "Sweep Window", group=groupLeg)
i_entryWindow = input.session("0830-1330", "Entry Window", group=groupLeg)
i_flatWindow = input.session("1550-1600", "Flat Window", group=groupLeg)
i_rr = input.float(3.5, "Reward/Risk", step=0.25, group=groupLeg)
i_tp1Ratio = input.float(0.4, "TP1 Ratio", minval=0.05, maxval=0.95, step=0.05, group=groupLeg)
i_atrLength = input.int(14, "ATR Length", minval=1, group=groupLeg)
i_minGapPct = input.float(3.0, "Min Gap (% ATR)", minval=0.0, step=0.25, group=groupLeg)
i_fvgWindowLeft = input.int(20, "FVG Window Left", minval=0, group=groupLeg)
i_fvgWindowRight = input.int(2, "FVG Window Right", minval=0, group=groupLeg)
i_maxFvgToInversionBars = input.int(24, "Max FVG To Inversion Bars", minval=1, group=groupLeg)
i_htfTfMinutes = input.int(60, "HTF Level TF Minutes", options=[30, 60, 90], group=groupLeg)
i_htfNLeft = input.int(3, "HTF Confirm Bars", minval=1, group=groupLeg)
i_tradeMaxPerSession = input.int(2, "Max Trades Per Session", minval=1, maxval=5, group=groupLeg)

// ============================================================================
// HELPERS
// ============================================================================
floorToStep(value, step) =>
    step > 0 ? math.floor(value / step) * step : value

calcQty(entryPrice, stopPrice) =>
    riskPts = math.abs(entryPrice - stopPrice)
    riskPerContract = riskPts * i_pointValue
    rawQty = riskPerContract > 0 ? i_riskUsd / riskPerContract : na
    steppedQty = not na(rawQty) ? floorToStep(rawQty, i_qtyStep) : na
    float qty = na
    if not na(steppedQty)
        if steppedQty >= i_minQty
            qty := steppedQty
        else
            singleRisk = riskPts * i_pointValue * i_minQty
            qty := i_maxSingleRiskUsd <= 0 or singleRisk <= i_maxSingleRiskUsd ? i_minQty : na
    qty

findRecentIndex(barArray, currentBar, maxLookback) =>
    int found = na
    if array.size(barArray) > 0
        for i = array.size(barArray) - 1 to 0 by -1
            detectBar = array.get(barArray, i)
            if currentBar - detectBar <= maxLookback
                found := i
                break
    found

pruneOld(barArray, topArray, botArray, rangeArray, currentBar, maxAge) =>
    while array.size(barArray) > 0 and currentBar - array.get(barArray, 0) > maxAge
        array.shift(barArray)
        array.shift(topArray)
        array.shift(botArray)
        array.shift(rangeArray)

// ============================================================================
// TIMEFRAME / SESSION FILTERS
// ============================================================================
isNqAsset = syminfo.root == "NQ" or syminfo.root == "MNQ"
isFiveMinute = timeframe.isminutes and timeframe.multiplier == 5
canRun = isNqAsset and isFiveMinute
tz = "America/New_York"
nyRth = "0830-1600"

inNyRTH = canRun and not na(time("5", nyRth, tz))
inSweepWin = canRun and not na(time("5", i_sweepWindow, tz))
inEntryWin = canRun and not na(time("5", i_entryWindow, tz))
inFlatWin = canRun and not na(time("5", i_flatWindow, tz))
nyStart = inNyRTH and not inNyRTH[1]

if barstate.isfirst and not isNqAsset
    strategy.cancel_all()

// ============================================================================
// DAILY ATR (MIDNIGHT ET)
// ============================================================================
curDay = dayofmonth(time, tz)

var float dayHigh = na
var float dayLow = na
var float dayClose = na
var float lastClose = na
var int lastDay = na
var float dailyAtr = na
var float atrBuilding = na
var int atrCount = 0
var array<float> atrTrHist = array.new_float()

if canRun
    if not na(lastDay) and curDay != lastDay and not na(dayHigh)
        if not na(lastClose)
            tr = math.max(dayHigh - dayLow, math.max(math.abs(dayHigh - lastClose), math.abs(dayLow - lastClose)))
            atrCount += 1
            if atrCount <= i_atrLength
                array.push(atrTrHist, tr)
                if atrCount == i_atrLength
                    sumTr = 0.0
                    for i = 0 to i_atrLength - 1
                        sumTr += array.get(atrTrHist, i)
                    atrBuilding := sumTr / i_atrLength
            else
                atrBuilding := ((atrBuilding * (i_atrLength - 1)) + tr) / i_atrLength
        dailyAtr := atrBuilding
        lastClose := dayClose
        dayHigh := high
        dayLow := low
        dayClose := close
    else
        dayHigh := na(dayHigh) ? high : math.max(dayHigh, high)
        dayLow := na(dayLow) ? low : math.min(dayLow, low)
        dayClose := close
    lastDay := curDay

// ============================================================================
// HTF UNSWEPT LOW TRACKER
// ============================================================================
var int htfBucketStart = na
var float htfBucketHigh = na
var float htfBucketLow = na
var array<int> pendingLowPublishTimes = array.new_int()
var array<float> pendingLowValues = array.new_float()
var array<bool> pendingLowSwept = array.new_bool()
var float latestHtfLow = na
var int latestHtfLowId = -1
var int nextHtfLowId = 0
var bool latestHtfLowConsumed = false

if canRun
    totalMinutes = hour(time, tz) * 60 + minute(time, tz)
    bucketMinutes = int(math.floor(totalMinutes / i_htfTfMinutes) * i_htfTfMinutes)
    bucketHour = int(bucketMinutes / 60)
    bucketMinute = bucketMinutes % 60
    bucketStart = timestamp(tz, year(time, tz), month(time, tz), dayofmonth(time, tz), bucketHour, bucketMinute)

    if na(htfBucketStart)
        htfBucketStart := bucketStart

    if bucketStart != htfBucketStart and not na(htfBucketLow)
        publishTime = htfBucketStart + ((i_htfNLeft + 1) * i_htfTfMinutes * 60000)
        array.push(pendingLowPublishTimes, publishTime)
        array.push(pendingLowValues, htfBucketLow)
        array.push(pendingLowSwept, false)
        htfBucketStart := bucketStart
        htfBucketHigh := na
        htfBucketLow := na

    while array.size(pendingLowPublishTimes) > 0 and array.get(pendingLowPublishTimes, 0) <= time
        publishLow = array.shift(pendingLowValues)
        wasSwept = array.shift(pendingLowSwept)
        array.shift(pendingLowPublishTimes)
        if not wasSwept
            latestHtfLow := publishLow
            latestHtfLowId := nextHtfLowId
            nextHtfLowId += 1
            latestHtfLowConsumed := false

    if array.size(pendingLowValues) > 0
        for i = 0 to array.size(pendingLowValues) - 1
            if array.get(pendingLowPublishTimes, i) > time and low < array.get(pendingLowValues, i)
                array.set(pendingLowSwept, i, true)

    htfBucketHigh := na(htfBucketHigh) ? high : math.max(htfBucketHigh, high)
    htfBucketLow := na(htfBucketLow) ? low : math.min(htfBucketLow, low)

// ============================================================================
// FVG BUFFER STATE
// ============================================================================
var array<int> recentBearBars = array.new_int()
var array<float> recentBearTops = array.new_float()
var array<float> recentBearBots = array.new_float()
var array<float> recentBearRangeLows = array.new_float()

var bool waitingForGap = false
var bool waitingForInversion = false
var bool inverted = false
var int sweepBar = na
var float activeGapTop = na
var float activeGapBot = na
var float activeGapRangeLow = na
var int activeGapDetectBar = na
var float limitPrice = na
var int inversionBar = na
var int tradesThisSession = 0

var float tradeEntry = na
var float tradeStop = na
var float tradeTp1 = na
var float tradeTp2 = na
var float tradeQty = na
var bool tradeIsSingle = false
var bool orderPending = false
var bool movedToBreakeven = false
var bool tradeActive = false

entryId = "NQHTFLSILong"
tp1Id = "NQHTFLSITP1"
tp2Id = "NQHTFLSITP2"
runnerId = "NQHTFLSIRunner"

if nyStart
    array.clear(recentBearBars)
    array.clear(recentBearTops)
    array.clear(recentBearBots)
    array.clear(recentBearRangeLows)
    waitingForGap := false
    waitingForInversion := false
    inverted := false
    sweepBar := na
    activeGapTop := na
    activeGapBot := na
    activeGapRangeLow := na
    activeGapDetectBar := na
    limitPrice := na
    inversionBar := na
    tradesThisSession := 0
    tradeEntry := na
    tradeStop := na
    tradeTp1 := na
    tradeTp2 := na
    tradeQty := na
    tradeIsSingle := false
    orderPending := false
    movedToBreakeven := false
    tradeActive := false
    strategy.cancel_all()

// ============================================================================
// NQ NY HTF-LSI FLOW
// ============================================================================
minGap = (i_minGapPct / 100.0) * nz(dailyAtr)

bearFvgTop = low[2]
bearFvgBot = high
bearGapSize = bearFvgTop - bearFvgBot
isBearFvg = bar_index >= 2 and low[2] > high and low[2] > low[1] and high[2] > high

if canRun and inNyRTH and inEntryWin and nz(dailyAtr) > 0
    if isBearFvg and bearGapSize >= minGap
        array.push(recentBearBars, bar_index)
        array.push(recentBearTops, bearFvgTop)
        array.push(recentBearBots, bearFvgBot)
        array.push(recentBearRangeLows, math.min(low, math.min(low[1], low[2])))
    pruneOld(recentBearBars, recentBearTops, recentBearBots, recentBearRangeLows, bar_index, i_fvgWindowLeft + i_fvgWindowRight)

if canRun and not inEntryWin and (waitingForGap or waitingForInversion or inverted or orderPending) and strategy.position_size == 0
    waitingForGap := false
    waitingForInversion := false
    inverted := false
    sweepBar := na
    activeGapTop := na
    activeGapBot := na
    activeGapRangeLow := na
    activeGapDetectBar := na
    limitPrice := na
    inversionBar := na
    orderPending := false
    strategy.cancel_all()

canScan = canRun and inNyRTH and inSweepWin and nz(dailyAtr) > 0 and tradesThisSession < i_tradeMaxPerSession and strategy.position_size == 0 and not orderPending and not tradeActive

if canScan
    if not waitingForGap and not waitingForInversion and not inverted
        if not na(latestHtfLow) and not latestHtfLowConsumed and low < latestHtfLow
            latestHtfLowConsumed := true
            if inEntryWin
                sweepBar := bar_index
                idx = findRecentIndex(recentBearBars, bar_index, i_fvgWindowLeft)
                if not na(idx)
                    activeGapTop := array.get(recentBearTops, idx)
                    activeGapBot := array.get(recentBearBots, idx)
                    activeGapRangeLow := array.get(recentBearRangeLows, idx)
                    activeGapDetectBar := array.get(recentBearBars, idx)
                    waitingForInversion := true
                else
                    waitingForGap := true
    else if waitingForGap
        if bar_index - nz(sweepBar, bar_index) > i_fvgWindowRight
            waitingForGap := false
            sweepBar := na
        else if isBearFvg and bearGapSize >= minGap
            waitingForGap := false
            waitingForInversion := true
            activeGapTop := bearFvgTop
            activeGapBot := bearFvgBot
            activeGapRangeLow := math.min(low, math.min(low[1], low[2]))
            activeGapDetectBar := bar_index

if waitingForInversion and not na(activeGapTop)
    activeGapRangeLow := math.min(nz(activeGapRangeLow, low), low)
    fvgTooOld = bar_index - nz(activeGapDetectBar, bar_index) > i_maxFvgToInversionBars
    if fvgTooOld
        waitingForInversion := false
        sweepBar := na
        activeGapTop := na
        activeGapBot := na
        activeGapRangeLow := na
        activeGapDetectBar := na
    else if bar_index > nz(activeGapDetectBar, bar_index) and close > activeGapTop
        waitingForInversion := false
        inverted := true
        limitPrice := activeGapTop
        inversionBar := bar_index

if inverted
    activeGapRangeLow := math.min(nz(activeGapRangeLow, low), low)
    if bar_index > nz(inversionBar, bar_index) and low <= limitPrice
        candidateEntry = limitPrice
        candidateStop = activeGapRangeLow
        riskPts = candidateEntry - candidateStop
        candidateQty = riskPts > 0 ? calcQty(candidateEntry, candidateStop) : na
        inverted := false
        if not na(candidateQty)
            tradeEntry := candidateEntry
            tradeStop := candidateStop
            tradeTp1 := tradeEntry + (i_rr * riskPts * i_tp1Ratio)
            tradeTp2 := tradeEntry + (i_rr * riskPts)
            tradeQty := candidateQty
            tradeIsSingle := tradeQty <= i_minQty
            orderPending := true
            movedToBreakeven := false
            strategy.entry(entryId, strategy.long, qty=tradeQty, limit=tradeEntry)
            if tradeIsSingle
                strategy.exit(tp1Id, entryId, qty_percent=100, limit=tradeTp1, stop=tradeStop)
            else
                strategy.exit(tp1Id, entryId, qty_percent=50, limit=tradeTp1, stop=tradeStop)
                strategy.exit(tp2Id, entryId, qty_percent=50, limit=tradeTp2, stop=tradeStop)
        else
            sweepBar := na
            activeGapTop := na
            activeGapBot := na
            activeGapRangeLow := na
            activeGapDetectBar := na
            limitPrice := na
            inversionBar := na

if orderPending and strategy.position_size > 0
    orderPending := false
    tradeActive := true
    tradesThisSession += 1

if orderPending and not inEntryWin and strategy.position_size == 0
    orderPending := false
    strategy.cancel_all()

if tradeActive and strategy.position_size > 0 and i_useBreakeven and not tradeIsSingle and not movedToBreakeven and high >= nz(tradeTp1)
    movedToBreakeven := true
    strategy.cancel(tp1Id)
    strategy.cancel(tp2Id)
    strategy.exit(runnerId, entryId, qty_percent=100, limit=tradeTp2, stop=tradeEntry)

if tradeActive and strategy.position_size == 0 and strategy.position_size[1] > 0
    tradeActive := false
    movedToBreakeven := false
    waitingForGap := false
    waitingForInversion := false
    inverted := false
    sweepBar := na
    activeGapTop := na
    activeGapBot := na
    activeGapRangeLow := na
    activeGapDetectBar := na
    limitPrice := na
    inversionBar := na

if tradeActive and inFlatWin and strategy.position_size != 0
    strategy.close_all("NY Flat")

// ============================================================================
// VISUALS
// ============================================================================
plot(canRun and (orderPending or tradeActive) ? tradeEntry : na, "Entry", color=color.new(#787B86, 0), style=plot.style_linebr)
plot(canRun and (orderPending or tradeActive) ? tradeStop : na, "Stop", color=color.new(#FF5252, 0), style=plot.style_linebr)
plot(canRun and (orderPending or tradeActive) ? tradeTp1 : na, "TP1", color=color.new(#FFB74D, 0), style=plot.style_linebr)
plot(canRun and (orderPending or tradeActive) and not tradeIsSingle ? tradeTp2 : na, "TP2", color=color.new(#26A69A, 0), style=plot.style_linebr)

if barstate.isfirst and isNqAsset and not isFiveMinute
    label.new(bar_index, high, "Use this strategy on a 5m chart.", style=label.style_label_down, color=color.red, textcolor=color.white)
