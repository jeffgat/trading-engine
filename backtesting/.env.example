# Local secrets for backtesting scripts.
# Copy to .env and fill in your values.

# DataBento historical/live API key.
DATABENTO_API_KEY=your_databento_api_key

# Main DB API. Leave unset to use the default remote main DB.
MAIN_DB_URL=http://143.110.148.234:8100

# Cloudflare R2 credentials for data sync.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=orb-backtests-data
