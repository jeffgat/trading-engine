        ldn_longStopLbl := label.new(ldnEndBar, ldn_longStop, slTxt,  xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor,  size=size.small)
        ldn_longTp1Lbl  := label.new(ldnEndBar, ldn_longTp1,  tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
        ldn_longTp2Lbl  := label.new(ldnEndBar, ldn_longTp2,  tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)

// ============================================================================
// EXTEND FVG BOXES + LABELS (update right edge, not delete+redraw)
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin and not na(ny_longFvgBox)
    box.set_right(ny_longFvgBox, time)
    label.set_x(ny_longFvgLabel, time)

if enableNY and inNyRTH and inNyEntryWin and not na(ny_shortFvgBox)
    box.set_right(ny_shortFvgBox, time)
    label.set_x(ny_shortFvgLabel, time)

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_longFvgBox)
    box.set_right(asia_longFvgBox, time)
    label.set_x(asia_longFvgLabel, time)

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_shortFvgBox)
    box.set_right(asia_shortFvgBox, time)
    label.set_x(asia_shortFvgLabel, time)

if enableLsiNy and inLsiNyRTH and inLsiNyEntryWin and not na(lsiNy_longFvgBox)
    box.set_right(lsiNy_longFvgBox, time)
    label.set_x(lsiNy_longFvgLabel, time)

if enableLsiAsia and inLsiAsiaRTH and inLsiAsiaEntryWin and not na(lsiAsia_longFvgBox)
    box.set_right(lsiAsia_longFvgBox, time)
    label.set_x(lsiAsia_longFvgLabel, time)

if enableLdn and inLdnRTH and inLdnEntryWin and not na(ldn_longFvgBox)
    box.set_right(ldn_longFvgBox, time)
    label.set_x(ldn_longFvgLabel, time)

// ============================================================================
// EXTEND TRADE LEVEL LINES + LABELS
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin and not na(ny_longEntryLine)
    line.set_x2(ny_longEntryLine, math.max(time, line.get_x2(ny_longEntryLine)))
    line.set_x2(ny_longStopLine, math.max(time, line.get_x2(ny_longStopLine)))
    line.set_x2(ny_longTp1Line, math.max(time, line.get_x2(ny_longTp1Line)))
    line.set_x2(ny_longTp2Line, math.max(time, line.get_x2(ny_longTp2Line)))
    label.set_x(ny_longStopLbl, math.max(time, label.get_x(ny_longStopLbl)))
    label.set_x(ny_longTp1Lbl, math.max(time, label.get_x(ny_longTp1Lbl)))
    label.set_x(ny_longTp2Lbl, math.max(time, label.get_x(ny_longTp2Lbl)))

if enableNY and inNyRTH and inNyEntryWin and not na(ny_shortEntryLine)
    line.set_x2(ny_shortEntryLine, math.max(time, line.get_x2(ny_shortEntryLine)))
    line.set_x2(ny_shortStopLine, math.max(time, line.get_x2(ny_shortStopLine)))
    line.set_x2(ny_shortTp1Line, math.max(time, line.get_x2(ny_shortTp1Line)))
    line.set_x2(ny_shortTp2Line, math.max(time, line.get_x2(ny_shortTp2Line)))
    label.set_x(ny_shortStopLbl, math.max(time, label.get_x(ny_shortStopLbl)))
    label.set_x(ny_shortTp1Lbl, math.max(time, label.get_x(ny_shortTp1Lbl)))
    label.set_x(ny_shortTp2Lbl, math.max(time, label.get_x(ny_shortTp2Lbl)))

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_longEntryLine)
    line.set_x2(asia_longEntryLine, math.max(time, line.get_x2(asia_longEntryLine)))
    line.set_x2(asia_longStopLine, math.max(time, line.get_x2(asia_longStopLine)))
    line.set_x2(asia_longTp1Line, math.max(time, line.get_x2(asia_longTp1Line)))
    line.set_x2(asia_longTp2Line, math.max(time, line.get_x2(asia_longTp2Line)))
    label.set_x(asia_longStopLbl, math.max(time, label.get_x(asia_longStopLbl)))
    label.set_x(asia_longTp1Lbl, math.max(time, label.get_x(asia_longTp1Lbl)))
    label.set_x(asia_longTp2Lbl, math.max(time, label.get_x(asia_longTp2Lbl)))

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_shortEntryLine)
    line.set_x2(asia_shortEntryLine, math.max(time, line.get_x2(asia_shortEntryLine)))
    line.set_x2(asia_shortStopLine, math.max(time, line.get_x2(asia_shortStopLine)))
    line.set_x2(asia_shortTp1Line, math.max(time, line.get_x2(asia_shortTp1Line)))
    line.set_x2(asia_shortTp2Line, math.max(time, line.get_x2(asia_shortTp2Line)))
    label.set_x(asia_shortStopLbl, math.max(time, label.get_x(asia_shortStopLbl)))
    label.set_x(asia_shortTp1Lbl, math.max(time, label.get_x(asia_shortTp1Lbl)))
    label.set_x(asia_shortTp2Lbl, math.max(time, label.get_x(asia_shortTp2Lbl)))

if enableLsiNy and inLsiNyRTH and inLsiNyEntryWin and not na(lsiNy_longEntryLine)
    line.set_x2(lsiNy_longEntryLine, math.max(time, line.get_x2(lsiNy_longEntryLine)))
    line.set_x2(lsiNy_longStopLine,  math.max(time, line.get_x2(lsiNy_longStopLine)))
    line.set_x2(lsiNy_longTp1Line,   math.max(time, line.get_x2(lsiNy_longTp1Line)))
    line.set_x2(lsiNy_longTp2Line,   math.max(time, line.get_x2(lsiNy_longTp2Line)))
    label.set_x(lsiNy_longStopLbl,   math.max(time, label.get_x(lsiNy_longStopLbl)))
    label.set_x(lsiNy_longTp1Lbl,    math.max(time, label.get_x(lsiNy_longTp1Lbl)))
    label.set_x(lsiNy_longTp2Lbl,    math.max(time, label.get_x(lsiNy_longTp2Lbl)))

if enableLsiAsia and inLsiAsiaRTH and inLsiAsiaEntryWin and not na(lsiAsia_longEntryLine)
    line.set_x2(lsiAsia_longEntryLine, math.max(time, line.get_x2(lsiAsia_longEntryLine)))
    line.set_x2(lsiAsia_longStopLine,  math.max(time, line.get_x2(lsiAsia_longStopLine)))
    line.set_x2(lsiAsia_longTp1Line,   math.max(time, line.get_x2(lsiAsia_longTp1Line)))
    line.set_x2(lsiAsia_longTp2Line,   math.max(time, line.get_x2(lsiAsia_longTp2Line)))
    label.set_x(lsiAsia_longStopLbl,   math.max(time, label.get_x(lsiAsia_longStopLbl)))
    label.set_x(lsiAsia_longTp1Lbl,    math.max(time, label.get_x(lsiAsia_longTp1Lbl)))
    label.set_x(lsiAsia_longTp2Lbl,    math.max(time, label.get_x(lsiAsia_longTp2Lbl)))

if enableLdn and inLdnRTH and inLdnEntryWin and not na(ldn_longEntryLine)
    line.set_x2(ldn_longEntryLine, math.max(time, line.get_x2(ldn_longEntryLine)))
    line.set_x2(ldn_longStopLine,  math.max(time, line.get_x2(ldn_longStopLine)))
    line.set_x2(ldn_longTp1Line,   math.max(time, line.get_x2(ldn_longTp1Line)))
    line.set_x2(ldn_longTp2Line,   math.max(time, line.get_x2(ldn_longTp2Line)))
    label.set_x(ldn_longStopLbl,   math.max(time, label.get_x(ldn_longStopLbl)))
    label.set_x(ldn_longTp1Lbl,    math.max(time, label.get_x(ldn_longTp1Lbl)))
    label.set_x(ldn_longTp2Lbl,    math.max(time, label.get_x(ldn_longTp2Lbl)))

// ============================================================================
// VISUALS - ORB LINES (draw once per session, project to entry window end)
// ============================================================================
// NY: create lines once when orb is ready, project to end of entry window
nyShowOrb = enableNY and inNyRTH and inNyEntryWin and ny_orbReady
if nyShowOrb and not ny_orbLinesDrawn and canDraw
    ny_orbLineStart := time
    nyEndBar = calcEndBarTime(nyEntryWindow, "America/New_York")
    ny_orbHighLine := line.new(ny_orbLineStart, ny_orbHigh, nyEndBar, ny_orbHigh, xloc=xloc.bar_time, color=nyOrbHighColor, width=2)
    ny_orbLowLine  := line.new(ny_orbLineStart, ny_orbLow, nyEndBar, ny_orbLow, xloc=xloc.bar_time, color=nyOrbLowColor, width=2)
    ny_orbLinesDrawn := true

if nyShowOrb and ny_orbLinesDrawn and not na(ny_orbHighLine)
    line.set_x2(ny_orbHighLine, math.max(time, line.get_x2(ny_orbHighLine)))
    line.set_x2(ny_orbLowLine, math.max(time, line.get_x2(ny_orbLowLine)))

// Asia: create lines once when orb is ready, project to end of entry window
asiaShowOrb = enableAsia and inAsiaRTH and inAsiaEntryWin and asia_orbReady
if asiaShowOrb and not asia_orbLinesDrawn and canDraw
    asia_orbLineStart := time
    asiaEndBar = calcEndBarTime(asiaEntryWindow, "America/New_York")
    asia_orbHighLine := line.new(asia_orbLineStart, asia_orbHigh, asiaEndBar, asia_orbHigh, xloc=xloc.bar_time, color=asiaOrbHighColor, width=2)
    asia_orbLowLine  := line.new(asia_orbLineStart, asia_orbLow, asiaEndBar, asia_orbLow, xloc=xloc.bar_time, color=asiaOrbLowColor, width=2)
    asia_orbLinesDrawn := true

if asiaShowOrb and asia_orbLinesDrawn and not na(asia_orbHighLine)
    line.set_x2(asia_orbHighLine, math.max(time, line.get_x2(asia_orbHighLine)))
    line.set_x2(asia_orbLowLine, math.max(time, line.get_x2(asia_orbLowLine)))

// LSI NY: create lines once when orb is ready, project to end of entry window
lsiNyShowOrb = enableLsiNy and inLsiNyRTH and inLsiNyEntryWin and lsiNy_orbReady
if lsiNyShowOrb and not lsiNy_orbLinesDrawn and canDraw
    lsiNy_orbLineStart := time
    lsiNyEndBar = calcEndBarTime(i_nqLsiNyEntryWindow, "America/New_York")
    lsiNy_orbHighLine := line.new(lsiNy_orbLineStart, lsiNy_orbHigh, lsiNyEndBar, lsiNy_orbHigh, xloc=xloc.bar_time, color=nqLsiNyOrbHighColor, width=2)
    lsiNy_orbLowLine  := line.new(lsiNy_orbLineStart, lsiNy_orbLow,  lsiNyEndBar, lsiNy_orbLow,  xloc=xloc.bar_time, color=nqLsiNyOrbLowColor,  width=2)
    lsiNy_orbLinesDrawn := true

if lsiNyShowOrb and lsiNy_orbLinesDrawn and not na(lsiNy_orbHighLine)
    line.set_x2(lsiNy_orbHighLine, math.max(time, line.get_x2(lsiNy_orbHighLine)))
    line.set_x2(lsiNy_orbLowLine,  math.max(time, line.get_x2(lsiNy_orbLowLine)))

// LSI Asia: create lines once when orb is ready, project to end of entry window
lsiAsiaShowOrb = enableLsiAsia and inLsiAsiaRTH and inLsiAsiaEntryWin and lsiAsia_orbReady
if lsiAsiaShowOrb and not lsiAsia_orbLinesDrawn and canDraw
    lsiAsia_orbLineStart := time
    lsiAsiaEndBar = calcEndBarTime(i_nqLsiAsiaEntryWindow, "America/New_York")
    lsiAsia_orbHighLine := line.new(lsiAsia_orbLineStart, lsiAsia_orbHigh, lsiAsiaEndBar, lsiAsia_orbHigh, xloc=xloc.bar_time, color=nqLsiAsiaOrbHighColor, width=2)
    lsiAsia_orbLowLine  := line.new(lsiAsia_orbLineStart, lsiAsia_orbLow,  lsiAsiaEndBar, lsiAsia_orbLow,  xloc=xloc.bar_time, color=nqLsiAsiaOrbLowColor,  width=2)
    lsiAsia_orbLinesDrawn := true

if lsiAsiaShowOrb and lsiAsia_orbLinesDrawn and not na(lsiAsia_orbHighLine)
    line.set_x2(lsiAsia_orbHighLine, math.max(time, line.get_x2(lsiAsia_orbHighLine)))
    line.set_x2(lsiAsia_orbLowLine,  math.max(time, line.get_x2(lsiAsia_orbLowLine)))

// LDN: create lines once when orb is ready, project to end of entry window
ldnShowOrb = enableLdn and inLdnRTH and inLdnEntryWin and ldn_orbReady
if ldnShowOrb and not ldn_orbLinesDrawn and canDraw
    ldn_orbLineStart := time
    ldnEndBar = calcEndBarTime(i_nqLdnEntryWindow, "America/New_York")
    ldn_orbHighLine := line.new(ldn_orbLineStart, ldn_orbHigh, ldnEndBar, ldn_orbHigh, xloc=xloc.bar_time, color=nqLdnOrbHighColor, width=2)
    ldn_orbLowLine  := line.new(ldn_orbLineStart, ldn_orbLow,  ldnEndBar, ldn_orbLow,  xloc=xloc.bar_time, color=nqLdnOrbLowColor,  width=2)
    ldn_orbLinesDrawn := true

if ldnShowOrb and ldn_orbLinesDrawn and not na(ldn_orbHighLine)
    line.set_x2(ldn_orbHighLine, math.max(time, line.get_x2(ldn_orbHighLine)))
    line.set_x2(ldn_orbLowLine,  math.max(time, line.get_x2(ldn_orbLowLine)))

// ============================================================================
// ATR DISTANCE DISPLAY + DEBUG
// ============================================================================
displayATR       = enableNY ? nyDailyATR : asiaDailyATR
displayAtrLength = enableNY ? nyAtrLength : asiaAtrLength
globexDist  = close - globexOpen
globexPct   = displayATR > 0 ? (globexDist / displayATR) * 100 : 0.0
globexSign  = globexDist >= 0 ? "+" : ""
globexColor = globexDist >= 0 ? color.new(#26a69a, 0) : color.new(#ef5350, 0)

var table atrTable = table.new(position.top_right, 1, 3, bgcolor=color.new(#1e222d, 10), border_width=1, border_color=color.new(#363a45, 0))
if barstate.islast
    atrText = "ATR(" + str.tostring(displayAtrLength) + "): " + str.tostring(displayATR, format.mintick)
    globexText = "GlobEx: " + globexSign + str.tostring(globexDist, format.mintick) + " (" + globexSign + str.tostring(globexPct, "#.0") + "% ATR)"
    debugText = "root=" + syminfo.root + " | asset=" + asset + " | RR=" + str.tostring(nyRR) + " | ATR_len=" + str.tostring(nyAtrLength) + " | stop%=" + str.tostring(nyStopPct)
    table.cell(atrTable, 0, 0, atrText, text_color=color.white, text_size=size.small)
    table.cell(atrTable, 0, 1, globexText, text_color=globexColor, text_size=size.small)
    table.cell(atrTable, 0, 2, debugText, text_color=color.yellow, text_size=size.small)

// ============================================================================
// ALERTS - fire when a new FVG setup is detected (must enable in settings)
// ============================================================================
alertcondition(ny_longSetupAlert,   "NY Long Setup",   "NY long FVG setup detected")
alertcondition(ny_shortSetupAlert,  "NY Short Setup",  "NY short FVG setup detected")
alertcondition(asia_longSetupAlert,  "Asia Long Setup",  "Asia long FVG setup detected")
alertcondition(asia_shortSetupAlert, "Asia Short Setup", "Asia short FVG setup detected")
alertcondition(lsiNy_longSetupAlert,   "NQ NY LSI Long Setup",   "NQ NY LSI long FVG setup detected")
alertcondition(lsiAsia_longSetupAlert, "NQ Asia LSI Long Setup", "NQ Asia LSI long FVG setup detected")
alertcondition(ldn_longSetupAlert,     "NQ LDN LSI Long Setup",  "NQ LDN LSI long FVG setup detected")
alertcondition(ny_longSetupAlert or ny_shortSetupAlert or asia_longSetupAlert or asia_shortSetupAlert, "Any Setup", "FVG setup detected")
