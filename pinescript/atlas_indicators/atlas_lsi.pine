//@version=6
indicator(
     title              = "LSI [atlasfutures]",
     overlay            = true,
     max_lines_count    = 500,
     max_boxes_count    = 500,
     max_labels_count   = 500
)

// ============================================================================
// AUTO-DETECT ASSET from chart symbol
// ============================================================================
asset = if syminfo.root == "NQ" or syminfo.root == "MNQ"
    "NQ"
else
    "NQ"  // LSI currently NQ-only

// ============================================================================
// INPUTS - Display
// ============================================================================
drawbackDays = input.int(1, "Days Back", minval=1, maxval=50, tooltip="Number of trading days to show drawings for", group="Display")

// ============================================================================
// INPUTS - NQ: NY
// ============================================================================
i_nqNyEntryWindow  = input.session("0935-1530", "Entry Window (ny time)", group="NQ: NY")
i_nqNyDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: NY")
i_nqNyEntryMode    = input.string("FVG Limit", "Entry Mode", options=["Bar Close", "FVG Limit"], tooltip="Bar Close = enter at inversion bar close. FVG Limit = limit order at FVG boundary after inversion.", group="NQ: NY")
i_nqNyRR           = input.float(2.5, "Reward/Risk", step=0.25, group="NQ: NY")
i_nqNyTp1Ratio     = input.float(0.2, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: NY")
i_nqNyAtrLength    = input.int(10, "ATR Length", minval=1, group="NQ: NY")
i_nqNyMinGapPct    = input.float(3.75, "Min Gap (% ATR)", step=0.25, tooltip="Minimum FVG size as percentage of daily ATR", group="NQ: NY")
nqNyFvgPendColor   = input.color(#787b86, "FVG Pending Color", group="NQ: NY")
nqNyFvgSweptColor  = input.color(#26a69a, "FVG Swept Color", group="NQ: NY")

// ============================================================================
// INPUTS - NQ: Asia
// ============================================================================
i_nqAsiaEntryWindow  = input.session("2040-2330", "Entry Window (ny time)", group="NQ: Asia")
i_nqAsiaDirection    = input.string("Long Only", "Direction", options=["Long Only", "Short Only", "Both"], group="NQ: Asia")
i_nqAsiaEntryMode    = input.string("Bar Close", "Entry Mode", options=["Bar Close", "FVG Limit"], tooltip="Bar Close = enter at inversion bar close. FVG Limit = limit order at FVG boundary after inversion.", group="NQ: Asia")
i_nqAsiaRR           = input.float(1.75, "Reward/Risk", step=0.25, group="NQ: Asia")
i_nqAsiaTp1Ratio     = input.float(0.7, "TP1/BE Level (fraction of R:R)", step=0.05, minval=0.1, maxval=0.9, group="NQ: Asia")
i_nqAsiaAtrLength    = input.int(40, "ATR Length", minval=1, group="NQ: Asia")
i_nqAsiaMinGapPct    = input.float(1.75, "Min Gap (% ATR)", step=0.25, tooltip="Minimum FVG size as percentage of daily ATR", group="NQ: Asia")
nqAsiaFvgPendColor   = input.color(#787b86, "FVG Pending Color", group="NQ: Asia")
nqAsiaFvgSweptColor  = input.color(#2196F3, "FVG Swept Color", group="NQ: Asia")

// ============================================================================
// INPUTS - Trade Level Colors
// ============================================================================
entryColor = input.color(#787b86, "Entry Color", inline="entry", group="Trade Level Colors")
entryStyle = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="entry", group="Trade Level Colors")
slColor    = input.color(#787b86, "SL Color", inline="sl", group="Trade Level Colors")
slStyle    = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="sl", group="Trade Level Colors")
tp1Color   = input.color(#787b86, "TP1 Color", inline="tp1", group="Trade Level Colors")
tp1Style   = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="tp1", group="Trade Level Colors")
tp2Color   = input.color(#787b86, "TP2 Color", inline="tp2", group="Trade Level Colors")
tp2Style   = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], inline="tp2", group="Trade Level Colors")

// ============================================================================
// INPUTS - Skip Days - NQ: NY  (backtest excludes Wed+Thu)
// ============================================================================
i_nqNySkipMon = input.bool(false, "Skip Monday",    group="NQ: NY Skip Days")
i_nqNySkipTue = input.bool(false, "Skip Tuesday",   group="NQ: NY Skip Days")
i_nqNySkipWed = input.bool(true,  "Skip Wednesday", group="NQ: NY Skip Days")
i_nqNySkipThu = input.bool(true,  "Skip Thursday",  group="NQ: NY Skip Days")
i_nqNySkipFri = input.bool(false, "Skip Friday",    group="NQ: NY Skip Days")


// ============================================================================
// INPUTS - Skip Days - NQ: Asia
// ============================================================================
i_nqAsiaSkipMon = input.bool(false, "Skip Monday",    group="NQ: Asia Skip Days")
i_nqAsiaSkipTue = input.bool(false, "Skip Tuesday",   group="NQ: Asia Skip Days")
i_nqAsiaSkipWed = input.bool(false, "Skip Wednesday", group="NQ: Asia Skip Days")
i_nqAsiaSkipThu = input.bool(false, "Skip Thursday",  group="NQ: Asia Skip Days")
i_nqAsiaSkipFri = input.bool(false, "Skip Friday",    group="NQ: Asia Skip Days")

// ============================================================================
// INPUTS - Alerts
// ============================================================================
enableAlerts = input.bool(true, "Enable Setup Alerts", tooltip="Enable alert conditions for when an LSI setup is armed", group="Alerts")

// ============================================================================
// RESOLVE ACTIVE CONFIG — NQ-only for now
// ============================================================================
enableNY   = true
enableAsia = true

nySessionRTH   = "0930-1600"
asiaSessionRTH = "1800-0700"

nyEntryWindow    = i_nqNyEntryWindow
nyDirection      = i_nqNyDirection
nyEntryMode      = i_nqNyEntryMode
nyRR             = i_nqNyRR
nyTp1Ratio       = i_nqNyTp1Ratio
nyAtrLength      = i_nqNyAtrLength
nyMinGapPct      = i_nqNyMinGapPct
nyFvgPendColor   = nqNyFvgPendColor
nyFvgSweptColor  = nqNyFvgSweptColor
nyIsFvgLimit     = nyEntryMode == "FVG Limit"

asiaEntryWindow    = i_nqAsiaEntryWindow
asiaDirection      = i_nqAsiaDirection
asiaEntryMode      = i_nqAsiaEntryMode
asiaRR             = i_nqAsiaRR
asiaTp1Ratio       = i_nqAsiaTp1Ratio
asiaAtrLength      = i_nqAsiaAtrLength
asiaMinGapPct      = i_nqAsiaMinGapPct
asiaFvgPendColor   = nqAsiaFvgPendColor
asiaFvgSweptColor  = nqAsiaFvgSweptColor
asiaIsFvgLimit     = asiaEntryMode == "FVG Limit"

// ============================================================================
// LINE STYLE LOOKUP
// ============================================================================
styleToLine(s) =>
    s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed
entryLineStyle = styleToLine(entryStyle)
slLineStyle    = styleToLine(slStyle)
tp1LineStyle   = styleToLine(tp1Style)
tp2LineStyle   = styleToLine(tp2Style)

// ============================================================================
// SESSION FILTERS - use "5" resolution for correct detection on all chart TFs
// ============================================================================
inNyRTH      = not na(time("5", nySessionRTH, "America/New_York"))
inNyEntryWin = not na(time("5", nyEntryWindow, "America/New_York"))
inAsiaRTH      = not na(time("5", asiaSessionRTH, "America/New_York"))
inAsiaEntryWin = not na(time("5", asiaEntryWindow, "America/New_York"))

// ============================================================================
// DOW SKIP FLAGS
// dayofweek: 1=Sun 2=Mon 3=Tue 4=Wed 5=Thu 6=Fri 7=Sat
// ============================================================================
dow = dayofweek(time, "America/New_York")
nySkipToday   = (dow == dayofweek.monday    and i_nqNySkipMon)
              or (dow == dayofweek.tuesday   and i_nqNySkipTue)
              or (dow == dayofweek.wednesday and i_nqNySkipWed)
              or (dow == dayofweek.thursday  and i_nqNySkipThu)
              or (dow == dayofweek.friday    and i_nqNySkipFri)
asiaSkipToday = (dow == dayofweek.monday    and i_nqAsiaSkipMon)
              or (dow == dayofweek.tuesday   and i_nqAsiaSkipTue)
              or (dow == dayofweek.wednesday and i_nqAsiaSkipWed)
              or (dow == dayofweek.thursday  and i_nqAsiaSkipThu)
              or (dow == dayofweek.friday    and i_nqAsiaSkipFri)

// ============================================================================
// 5m OHLC - stable confirmed data via lookahead_on + [1] offset
// h5/l5 = "after" candle (bar[0]), h5_1/l5_1 = impulse (bar[1]),
// h5_2/l5_2 = "before" candle (bar[2]), c5 = close of confirmed bar
// ============================================================================
regTicker = ticker.new(syminfo.prefix, syminfo.ticker, session.regular)
[h5, l5, h5_1, l5_1, h5_2, l5_2, c5, t5, t5_2] = request.security(regTicker, "5", [high[1], low[1], high[2], low[2], high[3], low[3], close[1], time[1], time[3]], lookahead=barmerge.lookahead_on)
barClosed5 = ta.change(t5) != 0

// Current-bar 5m data (no [1] shift) for ATR accumulation and real-time alerts
// The main FVG feed uses [1] shift for look-ahead safety on historical bars,
// which delays alerts by 5 minutes. This feed uses [0] so alerts fire immediately.
[atr_h5, atr_l5, atr_c5, atr_t5] = request.security(regTicker, "5", [high, low, close, time], lookahead=barmerge.lookahead_on)
atr_barClosed5 = ta.change(atr_t5) != 0

// Real-time FVG + close data for immediate alert detection
[rt_h5, rt_l5, rt_h5_1, rt_l5_1, rt_h5_2, rt_l5_2, rt_c5, rt_t5, rt_t5_2] = request.security(regTicker, "5", [high, low, high[1], low[1], high[2], low[2], close, time, time[2]], lookahead=barmerge.lookahead_on)
rtBarClosed5 = ta.change(rt_t5) != 0

// Session start detection (rising edge of RTH filter)
nyRTHStart   = inNyRTH and not inNyRTH[1]
asiaRTHStart = inAsiaRTH and not inAsiaRTH[1]

// ============================================================================
// DRAWBACK FILTER - only draw recent N days
// ============================================================================
barsPerDay = timeframe.in_seconds("D") / timeframe.in_seconds(timeframe.period)
canDraw    = bar_index >= last_bar_index - drawbackDays * barsPerDay

// ============================================================================
// DIRECTION FLAGS
// ============================================================================
nyDetectLongs    = nyDirection != "Short Only"
nyDetectShorts   = nyDirection != "Long Only"
asiaDetectLongs  = asiaDirection != "Short Only"
asiaDetectShorts = asiaDirection != "Long Only"

// ============================================================================
// CUSTOM DAILY ATR — midnight-ET boundaries (matches Python engine exactly)
//
// Pine's request.security("D", ta.atr()) uses exchange session boundaries
// (6 PM ET → 5 PM ET for CME futures), but the Python backtester resamples
// 5m bars by calendar date (midnight ET → midnight ET). This causes a 10-15%
// ATR discrepancy. The fix: accumulate 5m OHLC into daily bars at midnight ET,
// then compute Wilder's ATR manually for each session's ATR length.
// ============================================================================
atr_curDay = dayofmonth(atr_t5, "America/New_York")

// Daily OHLC accumulation (shared by both NY and Asia ATR)
var float atr_dayHigh   = na
var float atr_dayLow    = na
var float atr_dayClose  = na
var int   atr_lastDay   = -1
var float atr_lastClose = na

// NY ATR state (Wilder's smoothing)
var float ny_atr_value    = na
var float ny_atr_building = na
var int   ny_atr_count    = 0
var array<float> ny_atr_trHist = array.new<float>(0)

// Asia ATR state (Wilder's smoothing)
var float asia_atr_value    = na
var float asia_atr_building = na
var int   asia_atr_count    = 0
var array<float> asia_atr_trHist = array.new<float>(0)

if atr_barClosed5
    if atr_lastDay != -1 and atr_curDay != atr_lastDay and not na(atr_dayHigh)
        // Day transition — close out the previous calendar day
        if not na(atr_lastClose)
            tr = math.max(atr_dayHigh - atr_dayLow, math.max(math.abs(atr_dayHigh - atr_lastClose), math.abs(atr_dayLow - atr_lastClose)))

            // NY ATR update
            ny_atr_count += 1
            if ny_atr_count <= nyAtrLength
                array.push(ny_atr_trHist, tr)
                if ny_atr_count == nyAtrLength
                    sum = 0.0
                    for i = 0 to nyAtrLength - 1
                        sum += array.get(ny_atr_trHist, i)
                    ny_atr_building := sum / nyAtrLength
            else
                ny_atr_building := (ny_atr_building * (nyAtrLength - 1) + tr) / nyAtrLength

            // Asia ATR update
            asia_atr_count += 1
            if asia_atr_count <= asiaAtrLength
                array.push(asia_atr_trHist, tr)
                if asia_atr_count == asiaAtrLength
                    sum = 0.0
                    for i = 0 to asiaAtrLength - 1
                        sum += array.get(asia_atr_trHist, i)
                    asia_atr_building := sum / asiaAtrLength
            else
                asia_atr_building := (asia_atr_building * (asiaAtrLength - 1) + tr) / asiaAtrLength

        // Lag: bars during the new day see ATR through the previous completed day
        ny_atr_value    := ny_atr_building
        asia_atr_value  := asia_atr_building
        atr_lastClose   := atr_dayClose
        // Reset accumulator for the new day
        atr_dayHigh  := atr_h5
        atr_dayLow   := atr_l5
        atr_dayClose := atr_c5
    else
        // Same day — accumulate
        atr_dayHigh  := na(atr_dayHigh) ? atr_h5 : math.max(atr_dayHigh, atr_h5)
        atr_dayLow   := na(atr_dayLow)  ? atr_l5 : math.min(atr_dayLow, atr_l5)
        atr_dayClose := atr_c5
    atr_lastDay := atr_curDay

nyDailyATR   = ny_atr_value
asiaDailyATR = asia_atr_value

// ============================================================================
// FVG ZONE TYPE
// ============================================================================
type FvgZone
    float top
    float bot
    int   startTime
    box   bx
    label lbl
    float rangeHigh  // running max(high) from FVG "before" bar onward (for absolute stop)
    float rangeLow   // running min(low) from FVG "before" bar onward (for absolute stop)

// ============================================================================
// STATE - NY
// ============================================================================
var ny_bearFvgs = array.new<FvgZone>(0)
var ny_bullFvgs = array.new<FvgZone>(0)
var bool  ny_armed = false
var bool  ny_inverted = false  // inversion detected, waiting for limit fill (fvg_limit mode)
var float ny_limitPrice = na   // limit order price (fvg_limit mode)
var int   ny_limitDir = 0      // limit direction (fvg_limit mode)
var FvgZone ny_limitZone = na  // the FVG zone that triggered the limit
var float ny_entry = na
var float ny_stop  = na
var float ny_tp1   = na
var float ny_tp2   = na
var int   ny_dir   = 0

var line  ny_entryLine = na
var line  ny_stopLine  = na
var line  ny_tp1Line   = na
var line  ny_tp2Line   = na
var label ny_stopLbl   = na
var label ny_tp1Lbl    = na
var label ny_tp2Lbl    = na

// ============================================================================
// STATE - Asia
// ============================================================================
var asia_bearFvgs = array.new<FvgZone>(0)
var asia_bullFvgs = array.new<FvgZone>(0)
var bool  asia_armed = false
var bool  asia_inverted = false
var float asia_limitPrice = na
var int   asia_limitDir = 0
var FvgZone asia_limitZone = na
var float asia_entry = na
var float asia_stop  = na
var float asia_tp1   = na
var float asia_tp2   = na
var int   asia_dir   = 0

var line  asia_entryLine = na
var line  asia_stopLine  = na
var line  asia_tp1Line   = na
var line  asia_tp2Line   = na
var label asia_stopLbl   = na
var label asia_tp1Lbl    = na
var label asia_tp2Lbl    = na

// ============================================================================
// ALERT FLAGS (per-bar, non-persistent)
// ============================================================================
ny_setupAlert   = false
asia_setupAlert = false

// ============================================================================
// REAL-TIME ALERT STATE (no [1] delay — fires 5min earlier)
// ============================================================================
var bool rt_ny_alerted   = false
var bool rt_asia_alerted = false
// Real-time FVG zone arrays (populated 5min ahead of delayed arrays)
var rt_ny_bearFvgs  = array.new<FvgZone>(0)
var rt_ny_bullFvgs  = array.new<FvgZone>(0)
var rt_asia_bearFvgs = array.new<FvgZone>(0)
var rt_asia_bullFvgs = array.new<FvgZone>(0)

// ============================================================================
// HELPER: compute bar time at session end
// ============================================================================
calcEndBarTime(sessionStr, tz) =>
    endPart  = str.substring(sessionStr, 5, 9)
    endHour  = int(str.tonumber(str.substring(endPart, 0, 2)))
    endMin   = int(str.tonumber(str.substring(endPart, 2, 4)))
    barTime   = time
    barMoment = timestamp(tz, year(barTime, tz), month(barTime, tz), dayofmonth(barTime, tz), endHour, endMin, 0)
    barMoment := barMoment < barTime ? barMoment + 24 * 60 * 60 * 1000 : barMoment
    barMoment

// ============================================================================
// HELPER: draw trade level lines + labels
// ============================================================================
drawTradeLevels(entryVal, stopVal, tp1Val, tp2Val, dirVal, dailyATR, entryWinStr, sessEndTz) =>
    riskPts = math.abs(entryVal - stopVal)
    endBar  = calcEndBarTime(entryWinStr, sessEndTz)
    eLine   = line.new(time, entryVal, endBar, entryVal, xloc=xloc.bar_time, color=entryColor, style=entryLineStyle, width=1)
    sLine   = line.new(time, stopVal, endBar, stopVal, xloc=xloc.bar_time, color=slColor, style=slLineStyle, width=1)
    t1Line  = line.new(time, tp1Val, endBar, tp1Val, xloc=xloc.bar_time, color=tp1Color, style=tp1LineStyle, width=1)
    t2Line  = line.new(time, tp2Val, endBar, tp2Val, xloc=xloc.bar_time, color=tp2Color, style=tp2LineStyle, width=1)
    slPts   = riskPts
    slAtr   = dailyATR > 0 ? (slPts / dailyATR) * 100 : 0.0
    tp1Pts  = math.abs(tp1Val - entryVal)
    tp1Atr  = dailyATR > 0 ? (tp1Pts / dailyATR) * 100 : 0.0
    tp2Pts  = math.abs(tp2Val - entryVal)
    tp2Atr  = dailyATR > 0 ? (tp2Pts / dailyATR) * 100 : 0.0
    slTxt   = "SL: " + str.tostring(slPts, format.mintick) + " (" + str.tostring(slAtr, "#.0") + "% ATR)"
    tp1Txt  = "TP1: " + str.tostring(tp1Pts, format.mintick) + " (" + str.tostring(tp1Atr, "#.0") + "% ATR)"
    tp2Txt  = "TP2: " + str.tostring(tp2Pts, format.mintick) + " (" + str.tostring(tp2Atr, "#.0") + "% ATR)"
    sLbl    = label.new(endBar, stopVal, slTxt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=slColor, size=size.small)
    t1Lbl   = label.new(endBar, tp1Val, tp1Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp1Color, size=size.small)
    t2Lbl   = label.new(endBar, tp2Val, tp2Txt, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=tp2Color, size=size.small)
    [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl]

// ============================================================================
// RESET ON SESSION START
// ============================================================================
if nyRTHStart
    array.clear(ny_bearFvgs)
    array.clear(ny_bullFvgs)
    array.clear(rt_ny_bearFvgs)
    array.clear(rt_ny_bullFvgs)
    rt_ny_alerted := false
    ny_armed     := false
    ny_inverted  := false
    ny_limitPrice := na
    ny_limitDir  := 0
    ny_limitZone := na
    ny_entry := na
    ny_stop  := na
    ny_tp1   := na
    ny_tp2   := na
    ny_dir   := 0
    ny_entryLine := na
    ny_stopLine  := na
    ny_tp1Line   := na
    ny_tp2Line   := na
    ny_stopLbl   := na
    ny_tp1Lbl    := na
    ny_tp2Lbl    := na

if asiaRTHStart
    array.clear(asia_bearFvgs)
    array.clear(asia_bullFvgs)
    array.clear(rt_asia_bearFvgs)
    array.clear(rt_asia_bullFvgs)
    rt_asia_alerted := false
    asia_armed     := false
    asia_inverted  := false
    asia_limitPrice := na
    asia_limitDir  := 0
    asia_limitZone := na
    asia_entry := na
    asia_stop  := na
    asia_tp1   := na
    asia_tp2   := na
    asia_dir   := 0
    asia_entryLine := na
    asia_stopLine  := na
    asia_tp1Line   := na
    asia_tp2Line   := na
    asia_stopLbl   := na
    asia_tp1Lbl    := na
    asia_tp2Lbl    := na

// ============================================================================
// FVG SIZE REQUIREMENTS (ATR-based only for LSI)
// ============================================================================
nyMinGap   = (nyMinGapPct / 100) * nz(nyDailyATR)
asiaMinGap = (asiaMinGapPct / 100) * nz(asiaDailyATR)

// ============================================================================
// FVG DETECTION (3-candle pattern, same as atlas_orb but NO ORB filter)
// Bullish FVG: gap between bar[2] high and bar[0] low (price gapped up)
// Bearish FVG: gap between bar[0] high and bar[2] low (price gapped down)
// ============================================================================
bullFvgTop  = l5       // low of "after" candle
bullFvgBot  = h5_2     // high of "before" candle
bullGapSize = bullFvgTop - bullFvgBot
isBullFvg   = h5_2 < l5 and h5_2 < h5_1 and l5_2 < l5

bearFvgTop  = l5_2     // low of "before" candle
bearFvgBot  = h5       // high of "after" candle
bearGapSize = bearFvgTop - bearFvgBot
isBearFvg   = l5_2 > h5 and l5_2 > l5_1 and h5_2 > h5

// Real-time FVG detection (no [1] shift) for immediate alerts
rt_bullFvgTop  = rt_l5
rt_bullFvgBot  = rt_h5_2
rt_bullGapSize = rt_bullFvgTop - rt_bullFvgBot
rt_isBullFvg   = rt_h5_2 < rt_l5 and rt_h5_2 < rt_h5_1 and rt_l5_2 < rt_l5

rt_bearFvgTop  = rt_l5_2
rt_bearFvgBot  = rt_h5
rt_bearGapSize = rt_bearFvgTop - rt_bearFvgBot
rt_isBearFvg   = rt_l5_2 > rt_h5 and rt_l5_2 > rt_l5_1 and rt_h5_2 > rt_h5

// ============================================================================
// DETECT & STORE FVGs - NY
// Bearish FVGs tracked for LONG inversions, bullish for SHORT inversions
// ============================================================================
nyCanDetect = enableNY and barClosed5 and inNyRTH and inNyEntryWin and nz(nyDailyATR) > 0 and not nySkipToday

if nyCanDetect
    if nyDetectLongs and isBearFvg and bearGapSize >= nyMinGap
        fvgPts    = bearGapSize
        fvgAtrPct = nyDailyATR > 0 ? (fvgPts / nyDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        initHigh  = math.max(h5_2, h5_1, h5)
        initLow   = math.min(l5_2, l5_1, l5)
        zone      = FvgZone.new(bearFvgTop, bearFvgBot, t5_2, na, na, initHigh, initLow)
        if canDraw
            zone.bx  := box.new(t5_2, bearFvgTop, time, bearFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nyFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bearFvgTop + bearFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nyFvgPendColor, 0), size=size.small)
        array.push(ny_bearFvgs, zone)

    if nyDetectShorts and isBullFvg and bullGapSize >= nyMinGap
        fvgPts    = bullGapSize
        fvgAtrPct = nyDailyATR > 0 ? (fvgPts / nyDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        initHigh  = math.max(h5_2, h5_1, h5)
        initLow   = math.min(l5_2, l5_1, l5)
        zone      = FvgZone.new(bullFvgTop, bullFvgBot, t5_2, na, na, initHigh, initLow)
        if canDraw
            zone.bx  := box.new(t5_2, bullFvgTop, time, bullFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(nyFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bullFvgTop + bullFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(nyFvgPendColor, 0), size=size.small)
        array.push(ny_bullFvgs, zone)

// ============================================================================
// DETECT & STORE FVGs - Asia
// ============================================================================
asiaCanDetect = enableAsia and barClosed5 and inAsiaRTH and inAsiaEntryWin and nz(asiaDailyATR) > 0 and not asiaSkipToday

if asiaCanDetect
    if asiaDetectLongs and isBearFvg and bearGapSize >= asiaMinGap
        fvgPts    = bearGapSize
        fvgAtrPct = asiaDailyATR > 0 ? (fvgPts / asiaDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        initHigh  = math.max(h5_2, h5_1, h5)
        initLow   = math.min(l5_2, l5_1, l5)
        zone      = FvgZone.new(bearFvgTop, bearFvgBot, t5_2, na, na, initHigh, initLow)
        if canDraw
            zone.bx  := box.new(t5_2, bearFvgTop, time, bearFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(asiaFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bearFvgTop + bearFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(asiaFvgPendColor, 0), size=size.small)
        array.push(asia_bearFvgs, zone)

    if asiaDetectShorts and isBullFvg and bullGapSize >= asiaMinGap
        fvgPts    = bullGapSize
        fvgAtrPct = asiaDailyATR > 0 ? (fvgPts / asiaDailyATR) * 100 : 0.0
        fvgText   = str.tostring(fvgPts, format.mintick) + " (" + str.tostring(fvgAtrPct, "#.0") + "% ATR)"
        initHigh  = math.max(h5_2, h5_1, h5)
        initLow   = math.min(l5_2, l5_1, l5)
        zone      = FvgZone.new(bullFvgTop, bullFvgBot, t5_2, na, na, initHigh, initLow)
        if canDraw
            zone.bx  := box.new(t5_2, bullFvgTop, time, bullFvgBot, xloc=xloc.bar_time, border_color=color.new(color.white, 100), bgcolor=color.new(asiaFvgPendColor, 80), border_width=0)
            zone.lbl := label.new(time, (bullFvgTop + bullFvgBot) / 2, fvgText, xloc=xloc.bar_time, style=label.style_label_left, color=color.new(color.white, 100), textcolor=color.new(asiaFvgPendColor, 0), size=size.small)
        array.push(asia_bullFvgs, zone)

// ============================================================================
// REAL-TIME FVG STORAGE (no [1] delay — zones appear 5min earlier for alerts)
// No drawings — just zone data for the real-time inversion check below
// ============================================================================
rt_nyCanDetect   = enableNY and rtBarClosed5 and inNyRTH and inNyEntryWin and nz(nyDailyATR) > 0 and not nySkipToday
rt_asiaCanDetect = enableAsia and rtBarClosed5 and inAsiaRTH and inAsiaEntryWin and nz(asiaDailyATR) > 0 and not asiaSkipToday

if rt_nyCanDetect
    if nyDetectLongs and rt_isBearFvg and rt_bearGapSize >= nyMinGap
        initHigh = math.max(rt_h5_2, rt_h5_1, rt_h5)
        initLow  = math.min(rt_l5_2, rt_l5_1, rt_l5)
        array.push(rt_ny_bearFvgs, FvgZone.new(rt_bearFvgTop, rt_bearFvgBot, rt_t5_2, na, na, initHigh, initLow))
    if nyDetectShorts and rt_isBullFvg and rt_bullGapSize >= nyMinGap
        initHigh = math.max(rt_h5_2, rt_h5_1, rt_h5)
        initLow  = math.min(rt_l5_2, rt_l5_1, rt_l5)
        array.push(rt_ny_bullFvgs, FvgZone.new(rt_bullFvgTop, rt_bullFvgBot, rt_t5_2, na, na, initHigh, initLow))

if rt_asiaCanDetect
    if asiaDetectLongs and rt_isBearFvg and rt_bearGapSize >= asiaMinGap
        initHigh = math.max(rt_h5_2, rt_h5_1, rt_h5)
        initLow  = math.min(rt_l5_2, rt_l5_1, rt_l5)
        array.push(rt_asia_bearFvgs, FvgZone.new(rt_bearFvgTop, rt_bearFvgBot, rt_t5_2, na, na, initHigh, initLow))
    if asiaDetectShorts and rt_isBullFvg and rt_bullGapSize >= asiaMinGap
        initHigh = math.max(rt_h5_2, rt_h5_1, rt_h5)
        initLow  = math.min(rt_l5_2, rt_l5_1, rt_l5)
        array.push(rt_asia_bullFvgs, FvgZone.new(rt_bullFvgTop, rt_bullFvgBot, rt_t5_2, na, na, initHigh, initLow))

// ============================================================================
// REAL-TIME INVERSION DETECTION (for alerts — fires 5min earlier than drawings)
// Only sets alert flags + trade levels for alert text. Drawings handled by delayed block.
// ============================================================================
// NY real-time inversion
if rtBarClosed5 and inNyRTH and inNyEntryWin and not ny_armed and not rt_ny_alerted and nz(nyDailyATR) > 0 and not nySkipToday
    // Check bearish FVGs for LONG inversion
    if nyDetectLongs and array.size(rt_ny_bearFvgs) > 0
        for i = 0 to array.size(rt_ny_bearFvgs) - 1
            if rt_ny_alerted
                break
            zone = array.get(rt_ny_bearFvgs, i)
            if rt_c5 > zone.top
                if not nyIsFvgLimit
                    rt_ny_alerted := true
                    ny_setupAlert := enableAlerts
                    ny_dir   := 1
                    ny_entry := rt_c5
                    ny_stop  := nz(zone.rangeLow, ny_entry - 1.0)
                    riskPts  = ny_entry - ny_stop
                    ny_tp1   := ny_entry + (nyRR * riskPts * nyTp1Ratio)
                    ny_tp2   := ny_entry + (nyRR * riskPts)
    // Check bullish FVGs for SHORT inversion
    if not rt_ny_alerted and nyDetectShorts and array.size(rt_ny_bullFvgs) > 0
        for i = 0 to array.size(rt_ny_bullFvgs) - 1
            if rt_ny_alerted
                break
            zone = array.get(rt_ny_bullFvgs, i)
            if rt_c5 < zone.bot
                if not nyIsFvgLimit
                    rt_ny_alerted := true
                    ny_setupAlert := enableAlerts
                    ny_dir   := -1
                    ny_entry := rt_c5
                    ny_stop  := nz(zone.rangeHigh, ny_entry + 1.0)
                    riskPts  = ny_stop - ny_entry
                    ny_tp1   := ny_entry - (nyRR * riskPts * nyTp1Ratio)
                    ny_tp2   := ny_entry - (nyRR * riskPts)

// Asia real-time inversion
if rtBarClosed5 and inAsiaRTH and inAsiaEntryWin and not asia_armed and not rt_asia_alerted and nz(asiaDailyATR) > 0 and not asiaSkipToday
    // Check bearish FVGs for LONG inversion
    if asiaDetectLongs and array.size(rt_asia_bearFvgs) > 0
        for i = 0 to array.size(rt_asia_bearFvgs) - 1
            if rt_asia_alerted
                break
            zone = array.get(rt_asia_bearFvgs, i)
            if rt_c5 > zone.top
                if not asiaIsFvgLimit
                    rt_asia_alerted := true
                    asia_setupAlert := enableAlerts
                    asia_dir   := 1
                    asia_entry := rt_c5
                    asia_stop  := nz(zone.rangeLow, asia_entry - 1.0)
                    riskPts    = asia_entry - asia_stop
                    asia_tp1   := asia_entry + (asiaRR * riskPts * asiaTp1Ratio)
                    asia_tp2   := asia_entry + (asiaRR * riskPts)
    // Check bullish FVGs for SHORT inversion
    if not rt_asia_alerted and asiaDetectShorts and array.size(rt_asia_bullFvgs) > 0
        for i = 0 to array.size(rt_asia_bullFvgs) - 1
            if rt_asia_alerted
                break
            zone = array.get(rt_asia_bullFvgs, i)
            if rt_c5 < zone.bot
                if not asiaIsFvgLimit
                    rt_asia_alerted := true
                    asia_setupAlert := enableAlerts
                    asia_dir   := -1
                    asia_entry := rt_c5
                    asia_stop  := nz(zone.rangeHigh, asia_entry + 1.0)
                    riskPts    = asia_stop - asia_entry
                    asia_tp1   := asia_entry - (asiaRR * riskPts * asiaTp1Ratio)
                    asia_tp2   := asia_entry - (asiaRR * riskPts)

// Real-time limit fill scan - NY
if ny_inverted and not ny_armed and not rt_ny_alerted and rtBarClosed5 and inNyRTH and inNyEntryWin
    isLong = ny_limitDir == 1
    filled = (isLong and rt_l5 <= ny_limitPrice) or (not isLong and rt_h5 >= ny_limitPrice)
    if filled
        rt_ny_alerted := true
        ny_setupAlert := enableAlerts
        ny_dir   := ny_limitDir
        ny_entry := ny_limitPrice
        zone     = ny_limitZone
        if isLong
            ny_stop := nz(zone.rangeLow, ny_entry - 1.0)
            riskPts = ny_entry - ny_stop
            ny_tp1  := ny_entry + (nyRR * riskPts * nyTp1Ratio)
            ny_tp2  := ny_entry + (nyRR * riskPts)
        else
            ny_stop := nz(zone.rangeHigh, ny_entry + 1.0)
            riskPts = ny_stop - ny_entry
            ny_tp1  := ny_entry - (nyRR * riskPts * nyTp1Ratio)
            ny_tp2  := ny_entry - (nyRR * riskPts)

// Real-time limit fill scan - Asia
if asia_inverted and not asia_armed and not rt_asia_alerted and rtBarClosed5 and inAsiaRTH and inAsiaEntryWin
    isLong = asia_limitDir == 1
    filled = (isLong and rt_l5 <= asia_limitPrice) or (not isLong and rt_h5 >= asia_limitPrice)
    if filled
        rt_asia_alerted := true
        asia_setupAlert := enableAlerts
        asia_dir   := asia_limitDir
        asia_entry := asia_limitPrice
        zone       = asia_limitZone
        if isLong
            asia_stop := nz(zone.rangeLow, asia_entry - 1.0)
            riskPts   = asia_entry - asia_stop
            asia_tp1  := asia_entry + (asiaRR * riskPts * asiaTp1Ratio)
            asia_tp2  := asia_entry + (asiaRR * riskPts)
        else
            asia_stop := nz(zone.rangeHigh, asia_entry + 1.0)
            riskPts   = asia_stop - asia_entry
            asia_tp1  := asia_entry - (asiaRR * riskPts * asiaTp1Ratio)
            asia_tp2  := asia_entry - (asiaRR * riskPts)

// ============================================================================
// INVERSION DETECTION - NY (delayed — handles drawings + state)
// Bearish FVG: close > FVG top → LONG
// Bullish FVG: close < FVG bot → SHORT
// Entry mode: "Bar Close" = entry at c5, "FVG Limit" = entry at FVG boundary
// First armed setup per session-day wins
// ============================================================================
if barClosed5 and inNyRTH and inNyEntryWin and not ny_armed and not ny_inverted and nz(nyDailyATR) > 0 and not nySkipToday
    // Check bearish FVGs for LONG inversion
    if nyDetectLongs and array.size(ny_bearFvgs) > 0
        for i = 0 to array.size(ny_bearFvgs) - 1
            if ny_armed or ny_inverted
                break
            zone = array.get(ny_bearFvgs, i)
            if c5 > zone.top
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nyFvgSweptColor, 60))
                if nyIsFvgLimit
                    // fvg_limit mode: arm limit at FVG top (zone.top), fill on next bar
                    ny_inverted   := true
                    ny_limitPrice := zone.top
                    ny_limitDir   := 1
                    ny_limitZone  := zone
                else
                    // bar-close mode: enter at inversion bar close
                    ny_armed := true
                    ny_dir   := 1
                    ny_entry := c5
                    ny_stop  := nz(zone.rangeLow, ny_entry - 1.0)
                    riskPts  = ny_entry - ny_stop
                    ny_tp1   := ny_entry + (nyRR * riskPts * nyTp1Ratio)
                    ny_tp2   := ny_entry + (nyRR * riskPts)
                    if canDraw
                        [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(ny_entry, ny_stop, ny_tp1, ny_tp2, ny_dir, nyDailyATR, nyEntryWindow, "America/New_York")
                        ny_entryLine := eLine
                        ny_stopLine  := sLine
                        ny_tp1Line   := t1Line
                        ny_tp2Line   := t2Line
                        ny_stopLbl   := sLbl
                        ny_tp1Lbl    := t1Lbl
                        ny_tp2Lbl    := t2Lbl

    // Check bullish FVGs for SHORT inversion
    if not ny_armed and not ny_inverted and nyDetectShorts and array.size(ny_bullFvgs) > 0
        for i = 0 to array.size(ny_bullFvgs) - 1
            if ny_armed or ny_inverted
                break
            zone = array.get(ny_bullFvgs, i)
            if c5 < zone.bot
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(nyFvgSweptColor, 60))
                if nyIsFvgLimit
                    ny_inverted   := true
                    ny_limitPrice := zone.bot
                    ny_limitDir   := -1
                    ny_limitZone  := zone
                else
                    ny_armed := true
                    ny_dir   := -1
                    ny_entry := c5
                    ny_stop  := nz(zone.rangeHigh, ny_entry + 1.0)
                    riskPts  = ny_stop - ny_entry
                    ny_tp1   := ny_entry - (nyRR * riskPts * nyTp1Ratio)
                    ny_tp2   := ny_entry - (nyRR * riskPts)
                    if canDraw
                        [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(ny_entry, ny_stop, ny_tp1, ny_tp2, ny_dir, nyDailyATR, nyEntryWindow, "America/New_York")
                        ny_entryLine := eLine
                        ny_stopLine  := sLine
                        ny_tp1Line   := t1Line
                        ny_tp2Line   := t2Line
                        ny_stopLbl   := sLbl
                        ny_tp1Lbl    := t1Lbl
                        ny_tp2Lbl    := t2Lbl

// FVG LIMIT FILL SCAN - NY
// On each 5m bar after inversion, check if limit price was touched
if ny_inverted and not ny_armed and barClosed5 and inNyRTH and inNyEntryWin
    isLong = ny_limitDir == 1
    filled = (isLong and l5 <= ny_limitPrice) or (not isLong and h5 >= ny_limitPrice)
    if filled
        ny_armed    := true
        ny_inverted := false
        ny_dir      := ny_limitDir
        ny_entry    := ny_limitPrice
        zone        = ny_limitZone
        if isLong
            ny_stop := nz(zone.rangeLow, ny_entry - 1.0)
            riskPts = ny_entry - ny_stop
            ny_tp1  := ny_entry + (nyRR * riskPts * nyTp1Ratio)
            ny_tp2  := ny_entry + (nyRR * riskPts)
        else
            ny_stop := nz(zone.rangeHigh, ny_entry + 1.0)
            riskPts = ny_stop - ny_entry
            ny_tp1  := ny_entry - (nyRR * riskPts * nyTp1Ratio)
            ny_tp2  := ny_entry - (nyRR * riskPts)
        if canDraw
            [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(ny_entry, ny_stop, ny_tp1, ny_tp2, ny_dir, nyDailyATR, nyEntryWindow, "America/New_York")
            ny_entryLine := eLine
            ny_stopLine  := sLine
            ny_tp1Line   := t1Line
            ny_tp2Line   := t2Line
            ny_stopLbl   := sLbl
            ny_tp1Lbl    := t1Lbl
            ny_tp2Lbl    := t2Lbl

// Cancel NY limit if entry window closes
if ny_inverted and not inNyEntryWin
    ny_inverted  := false
    ny_limitPrice := na
    ny_limitDir  := 0
    ny_limitZone := na

// ============================================================================
// INVERSION DETECTION - Asia
// ============================================================================
if barClosed5 and inAsiaRTH and inAsiaEntryWin and not asia_armed and not asia_inverted and nz(asiaDailyATR) > 0 and not asiaSkipToday
    // Check bearish FVGs for LONG inversion
    if asiaDetectLongs and array.size(asia_bearFvgs) > 0
        for i = 0 to array.size(asia_bearFvgs) - 1
            if asia_armed or asia_inverted
                break
            zone = array.get(asia_bearFvgs, i)
            if c5 > zone.top
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(asiaFvgSweptColor, 60))
                if asiaIsFvgLimit
                    asia_inverted   := true
                    asia_limitPrice := zone.top
                    asia_limitDir   := 1
                    asia_limitZone  := zone
                else
                    asia_armed := true
                    asia_dir   := 1
                    asia_entry := c5
                    asia_stop  := nz(zone.rangeLow, asia_entry - 1.0)
                    riskPts    = asia_entry - asia_stop
                    asia_tp1   := asia_entry + (asiaRR * riskPts * asiaTp1Ratio)
                    asia_tp2   := asia_entry + (asiaRR * riskPts)
                    if canDraw
                        [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(asia_entry, asia_stop, asia_tp1, asia_tp2, asia_dir, asiaDailyATR, asiaEntryWindow, "America/New_York")
                        asia_entryLine := eLine
                        asia_stopLine  := sLine
                        asia_tp1Line   := t1Line
                        asia_tp2Line   := t2Line
                        asia_stopLbl   := sLbl
                        asia_tp1Lbl    := t1Lbl
                        asia_tp2Lbl    := t2Lbl

    // Check bullish FVGs for SHORT inversion
    if not asia_armed and not asia_inverted and asiaDetectShorts and array.size(asia_bullFvgs) > 0
        for i = 0 to array.size(asia_bullFvgs) - 1
            if asia_armed or asia_inverted
                break
            zone = array.get(asia_bullFvgs, i)
            if c5 < zone.bot
                if not na(zone.bx)
                    box.set_bgcolor(zone.bx, color.new(asiaFvgSweptColor, 60))
                if asiaIsFvgLimit
                    asia_inverted   := true
                    asia_limitPrice := zone.bot
                    asia_limitDir   := -1
                    asia_limitZone  := zone
                else
                    asia_armed := true
                    asia_dir   := -1
                    asia_entry := c5
                    asia_stop  := nz(zone.rangeHigh, asia_entry + 1.0)
                    riskPts    = asia_stop - asia_entry
                    asia_tp1   := asia_entry - (asiaRR * riskPts * asiaTp1Ratio)
                    asia_tp2   := asia_entry - (asiaRR * riskPts)
                    if canDraw
                        [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(asia_entry, asia_stop, asia_tp1, asia_tp2, asia_dir, asiaDailyATR, asiaEntryWindow, "America/New_York")
                        asia_entryLine := eLine
                        asia_stopLine  := sLine
                        asia_tp1Line   := t1Line
                        asia_tp2Line   := t2Line
                        asia_stopLbl   := sLbl
                        asia_tp1Lbl    := t1Lbl
                        asia_tp2Lbl    := t2Lbl

// FVG LIMIT FILL SCAN - Asia
if asia_inverted and not asia_armed and barClosed5 and inAsiaRTH and inAsiaEntryWin
    isLong = asia_limitDir == 1
    filled = (isLong and l5 <= asia_limitPrice) or (not isLong and h5 >= asia_limitPrice)
    if filled
        asia_armed    := true
        asia_inverted := false
        asia_dir      := asia_limitDir
        asia_entry    := asia_limitPrice
        zone          = asia_limitZone
        if isLong
            asia_stop := nz(zone.rangeLow, asia_entry - 1.0)
            riskPts   = asia_entry - asia_stop
            asia_tp1  := asia_entry + (asiaRR * riskPts * asiaTp1Ratio)
            asia_tp2  := asia_entry + (asiaRR * riskPts)
        else
            asia_stop := nz(zone.rangeHigh, asia_entry + 1.0)
            riskPts   = asia_stop - asia_entry
            asia_tp1  := asia_entry - (asiaRR * riskPts * asiaTp1Ratio)
            asia_tp2  := asia_entry - (asiaRR * riskPts)
        if canDraw
            [eLine, sLine, t1Line, t2Line, sLbl, t1Lbl, t2Lbl] = drawTradeLevels(asia_entry, asia_stop, asia_tp1, asia_tp2, asia_dir, asiaDailyATR, asiaEntryWindow, "America/New_York")
            asia_entryLine := eLine
            asia_stopLine  := sLine
            asia_tp1Line   := t1Line
            asia_tp2Line   := t2Line
            asia_stopLbl   := sLbl
            asia_tp1Lbl    := t1Lbl
            asia_tp2Lbl    := t2Lbl

// Cancel Asia limit if entry window closes
if asia_inverted and not inAsiaEntryWin
    asia_inverted  := false
    asia_limitPrice := na
    asia_limitDir  := 0
    asia_limitZone := na

// ============================================================================
// EXTEND FVG BOXES + LABELS + RANGE TRACKING - NY
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin
    if array.size(ny_bearFvgs) > 0
        for i = 0 to array.size(ny_bearFvgs) - 1
            zone = array.get(ny_bearFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), l5)
    if array.size(ny_bullFvgs) > 0
        for i = 0 to array.size(ny_bullFvgs) - 1
            zone = array.get(ny_bullFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), l5)

// ============================================================================
// EXTEND FVG BOXES + LABELS + RANGE TRACKING - Asia
// ============================================================================
if enableAsia and inAsiaRTH and inAsiaEntryWin
    if array.size(asia_bearFvgs) > 0
        for i = 0 to array.size(asia_bearFvgs) - 1
            zone = array.get(asia_bearFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), l5)
    if array.size(asia_bullFvgs) > 0
        for i = 0 to array.size(asia_bullFvgs) - 1
            zone = array.get(asia_bullFvgs, i)
            if not na(zone.bx)
                box.set_right(zone.bx, time)
            if not na(zone.lbl)
                label.set_x(zone.lbl, time)
            if barClosed5
                zone.rangeHigh := math.max(nz(zone.rangeHigh), h5)
                zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), l5)

// ============================================================================
// RANGE TRACKING - Real-time FVG zones (no drawings, just range updates)
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin and rtBarClosed5
    if array.size(rt_ny_bearFvgs) > 0
        for i = 0 to array.size(rt_ny_bearFvgs) - 1
            zone = array.get(rt_ny_bearFvgs, i)
            zone.rangeHigh := math.max(nz(zone.rangeHigh), rt_h5)
            zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), rt_l5)
    if array.size(rt_ny_bullFvgs) > 0
        for i = 0 to array.size(rt_ny_bullFvgs) - 1
            zone = array.get(rt_ny_bullFvgs, i)
            zone.rangeHigh := math.max(nz(zone.rangeHigh), rt_h5)
            zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), rt_l5)

if enableAsia and inAsiaRTH and inAsiaEntryWin and rtBarClosed5
    if array.size(rt_asia_bearFvgs) > 0
        for i = 0 to array.size(rt_asia_bearFvgs) - 1
            zone = array.get(rt_asia_bearFvgs, i)
            zone.rangeHigh := math.max(nz(zone.rangeHigh), rt_h5)
            zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), rt_l5)
    if array.size(rt_asia_bullFvgs) > 0
        for i = 0 to array.size(rt_asia_bullFvgs) - 1
            zone = array.get(rt_asia_bullFvgs, i)
            zone.rangeHigh := math.max(nz(zone.rangeHigh), rt_h5)
            zone.rangeLow  := math.min(nz(zone.rangeLow, 1e10), rt_l5)

// ============================================================================
// EXTEND TRADE LEVEL LINES + LABELS
// ============================================================================
if enableNY and inNyRTH and inNyEntryWin and not na(ny_entryLine)
    line.set_x2(ny_entryLine, math.max(time, line.get_x2(ny_entryLine)))
    line.set_x2(ny_stopLine, math.max(time, line.get_x2(ny_stopLine)))
    line.set_x2(ny_tp1Line, math.max(time, line.get_x2(ny_tp1Line)))
    line.set_x2(ny_tp2Line, math.max(time, line.get_x2(ny_tp2Line)))
    label.set_x(ny_stopLbl, math.max(time, label.get_x(ny_stopLbl)))
    label.set_x(ny_tp1Lbl, math.max(time, label.get_x(ny_tp1Lbl)))
    label.set_x(ny_tp2Lbl, math.max(time, label.get_x(ny_tp2Lbl)))

if enableAsia and inAsiaRTH and inAsiaEntryWin and not na(asia_entryLine)
    line.set_x2(asia_entryLine, math.max(time, line.get_x2(asia_entryLine)))
    line.set_x2(asia_stopLine, math.max(time, line.get_x2(asia_stopLine)))
    line.set_x2(asia_tp1Line, math.max(time, line.get_x2(asia_tp1Line)))
    line.set_x2(asia_tp2Line, math.max(time, line.get_x2(asia_tp2Line)))
    label.set_x(asia_stopLbl, math.max(time, label.get_x(asia_stopLbl)))
    label.set_x(asia_tp1Lbl, math.max(time, label.get_x(asia_tp1Lbl)))
    label.set_x(asia_tp2Lbl, math.max(time, label.get_x(asia_tp2Lbl)))

// ============================================================================
// ALERTS - fire when a new LSI setup is armed
// ============================================================================
nyDirStr   = ny_dir == 1 ? "Long" : "Short"
asiaDirStr = asia_dir == 1 ? "Long" : "Short"

if ny_setupAlert
    alert(asset + " NY " + nyDirStr + " armed @ " + str.tostring(ny_entry, format.mintick) + " | SL " + str.tostring(ny_stop, format.mintick) + " | TP1 " + str.tostring(ny_tp1, format.mintick) + " | TP2 " + str.tostring(ny_tp2, format.mintick), alert.freq_once_per_bar_close)

if asia_setupAlert
    alert(asset + " Asia " + asiaDirStr + " armed @ " + str.tostring(asia_entry, format.mintick) + " | SL " + str.tostring(asia_stop, format.mintick) + " | TP1 " + str.tostring(asia_tp1, format.mintick) + " | TP2 " + str.tostring(asia_tp2, format.mintick), alert.freq_once_per_bar_close)

alertcondition(ny_setupAlert,   "NY LSI Setup",   "NY LSI setup armed")
alertcondition(asia_setupAlert, "Asia LSI Setup", "Asia LSI setup armed")
alertcondition(ny_setupAlert or asia_setupAlert, "Any LSI Setup", "LSI setup armed")
