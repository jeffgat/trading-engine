//@version=6
strategy(
     title              = "ORB V1 Bot LDN/ES",
     overlay            = true,
     initial_capital    = 30000,
     pyramiding         = 0,
     margin_long        = 0,
     margin_short       = 0,
     commission_type    = strategy.commission.cash_per_contract,
     commission_value   = 0.05,
     calc_on_every_tick = true,
     process_orders_on_close = true,
     use_bar_magnifier  = true,
     fill_orders_on_standard_ohlc = false
)

// ----------------------------------------------------------------------------------------
// Inputs - Risk Settings
// ----------------------------------------------------------------------------------------
riskUsd      = input.float(300, "Risk per trade ($)", step=50, group="Risk Settings")
rr           = input.float(3.5, "Reward/Risk", step=0.25, group="Risk Settings")
tp1Ratio     = input.float(0.2, "Partial TP & BE Level (0.2 = 20% of target)", step=0.1, minval=0.1, maxval=0.9, group="Risk Settings")
minQty       = input.float(1.0, "Min Qty", step=0.1, group="Risk Settings")
qtyStep      = input.float(1.0, "Qty Step", step=0.1, group="Risk Settings")
beOffsetTicks = input.int(4, "BE Offset (ticks)", step=1, tooltip="Ticks above entry for BE stop to cover commission", group="Risk Settings")
execPointValue = input.float(5.0, "Execution Point Value ($)", step=1.0, tooltip="Point value of the execution instrument (MES=$5). Overrides chart syminfo for qty sizing.", group="Risk Settings")

// ----------------------------------------------------------------------------------------
// Inputs - Daily ATR
// ----------------------------------------------------------------------------------------
atrLength    = input.int(14, "ATR Length", minval=1, group="Daily ATR")

// ----------------------------------------------------------------------------------------
// Inputs - LDN Session Settings
// ----------------------------------------------------------------------------------------
ldnSessionRTH   = input.session("0300-0930", "LDN RTH (ny time)", group="LDN Session")
ldnOrbSession   = input.session("0300-0315", "LDN ORB window (ny time)", group="LDN Session")
ldnEntryWindow  = input.session("0315-0825", "LDN Entry window (ny time)", group="LDN Session")
ldnFlatWindow   = input.session("0820-0825", "LDN Flat window (ny time)", group="LDN Session")
ldnMaxGapAtrPct = input.float(85.0, "LDN Max Gap (% ATR)", step=1.0, tooltip="Maximum gap size as percentage of daily ATR (0 = no limit)", group="LDN Session")
ldnMinGapAtrPct = input.float(1.25, "LDN Min Gap (% ATR)", step=0.25, tooltip="Minimum gap size as percentage of daily ATR", group="LDN Session")
ldnStopAtrPct   = input.float(3.0, "LDN Stop Loss (% ATR)", step=0.5, minval=1.0, tooltip="Stop distance as percentage of daily ATR", group="LDN Session")

// ----------------------------------------------------------------------------------------
// Safety: intended for 5m charts
// ----------------------------------------------------------------------------------------
is5m = timeframe.isintraday and timeframe.multiplier == 5
barClosed = barstate.isconfirmed

// ----------------------------------------------------------------------------------------
// Session filters
// ----------------------------------------------------------------------------------------
inLdnRTH      = not na(time(timeframe.period, ldnSessionRTH, "America/New_York"))
inLdnORB      = not na(time(timeframe.period, ldnOrbSession, "America/New_York"))
inLdnEntryWin = not na(time(timeframe.period, ldnEntryWindow, "America/New_York"))
inLdnFlatWin  = not na(time(timeframe.period, ldnFlatWindow, "America/New_York"))
ldnAfterCutoff = inLdnRTH and not inLdnEntryWin

// new trading day
newDay = ta.change(time("D")) != 0

// ----------------------------------------------------------------------------------------
// exclude specific problematic dates
// ----------------------------------------------------------------------------------------
currentMonth = month(time, "America/New_York")
currentDay   = dayofmonth(time, "America/New_York")
currentYear  = year(time, "America/New_York")
isExcludedDate = currentYear == 2024 and currentMonth == 12 and currentDay == 18

// ----------------------------------------------------------------------------------------
// State Variables
// ----------------------------------------------------------------------------------------
var float orbHigh  = na
var float orbLow   = na
var bool  orbReady = false
var bool  hasTradedToday = false
var int   closedTradesAtDayStart = 0

var bool  longSetupActive  = false
var bool  shortSetupActive = false
var bool  longFirstFvgFound  = false
var bool  shortFirstFvgFound = false

var float longStopStored   = na
var float longTargetStored = na
var float longHalfwayStored = na
var float longEntryStored  = na
var float longQtyStored    = na
var float longHalfQty      = na
var bool  longBEActive      = false
var bool  longSingleContract = false
var float longFilledEntry  = na

var float shortStopStored   = na
var float shortTargetStored = na
var float shortHalfwayStored = na
var float shortEntryStored  = na
var float shortQtyStored    = na
var float shortHalfQty      = na
var bool  shortBEActive      = false
var bool  shortSingleContract = false
var float shortFilledEntry = na

var int longSetupBar  = na
var int shortSetupBar = na
var int fillBar = na

var string activeSession = na
var bool  tp1Alerted = false
var float prevPos = 0

// ----------------------------------------------------------------------------------------
// Reset on new day
// ----------------------------------------------------------------------------------------
if newDay
    orbHigh := na
    orbLow  := na
    orbReady := false
    hasTradedToday := false
    closedTradesAtDayStart := strategy.closedtrades

    longSetupActive := false
    shortSetupActive := false
    longFirstFvgFound := false
    shortFirstFvgFound := false
    longStopStored := na
    longTargetStored := na
    longHalfwayStored := na
    longEntryStored := na
    longQtyStored := na
    longHalfQty := na
    longBEActive := false
    longSingleContract := false
    longFilledEntry := na
    shortStopStored := na
    shortTargetStored := na
    shortHalfwayStored := na
    shortEntryStored := na
    shortQtyStored := na
    shortHalfQty := na
    shortBEActive := false
    shortSingleContract := false
    shortFilledEntry := na
    longSetupBar := na
    shortSetupBar := na
    fillBar := na
    activeSession := na

    strategy.cancel("LL")
    strategy.cancel("LS")

// ----------------------------------------------------------------------------------------
// Detect trade occurred
// ----------------------------------------------------------------------------------------
tradeHappened = ((strategy.opentrades > 0 and activeSession == "ldn") or (strategy.closedtrades > closedTradesAtDayStart and activeSession == "ldn"))

if tradeHappened and not hasTradedToday
    hasTradedToday := true
    longSetupActive := false
    shortSetupActive := false
    longFirstFvgFound := true
    shortFirstFvgFound := true
    longEntryStored := na
    shortEntryStored := na
    strategy.cancel("LL")
    strategy.cancel("LS")

// ----------------------------------------------------------------------------------------
// Build ORB (03:00-03:15)
// ----------------------------------------------------------------------------------------
if inLdnORB and inLdnRTH and is5m
    orbHigh := na(orbHigh) ? high : math.max(orbHigh, high)
    orbLow  := na(orbLow)  ? low  : math.min(orbLow, low)

if not inLdnORB and inLdnRTH and is5m and not orbReady and not na(orbHigh) and not na(orbLow)
    orbReady := true

// ----------------------------------------------------------------------------------------
// Daily ATR
// ----------------------------------------------------------------------------------------
dailyATR = request.security(syminfo.tickerid, "D", ta.atr(atrLength)[1], lookahead=barmerge.lookahead_on)

// ----------------------------------------------------------------------------------------
// FVG size requirements (uses dailyATR)
// ----------------------------------------------------------------------------------------
ldnMinGap = (ldnMinGapAtrPct / 100) * nz(dailyATR)
ldnMaxGap = ldnMaxGapAtrPct > 0 ? (ldnMaxGapAtrPct / 100) * nz(dailyATR) : float(na)

// ----------------------------------------------------------------------------------------
// FVG detection
// ----------------------------------------------------------------------------------------
longFvgTop    = low
longFvgBottom = high[2]
shortFvgTop   = low[2]
shortFvgBottom = high
longGapSize  = longFvgTop - longFvgBottom
shortGapSize = shortFvgTop - shortFvgBottom

longGapValid  = longGapSize >= ldnMinGap and (na(ldnMaxGap) or longGapSize <= ldnMaxGap)
shortGapValid = shortGapSize >= ldnMinGap and (na(ldnMaxGap) or shortGapSize <= ldnMaxGap)
longFVG  = high[2] < low and high[2] < high[1] and low[2] < low and longFvgTop > orbHigh and longGapValid
shortFVG = low[2] > high and low[2] > low[1] and high[2] > high and shortFvgBottom < orbLow and shortGapValid

// BE offset calculation
beOffset = beOffsetTicks * syminfo.mintick

// ----------------------------------------------------------------------------------------
// qty rounding helpers
// ----------------------------------------------------------------------------------------
floorToStep(x, step) =>
    step <= 0 ? x : math.floor(x / step) * step

// ----------------------------------------------------------------------------------------
// Activate setup
// ----------------------------------------------------------------------------------------
canArmSetup = (is5m and barClosed and inLdnRTH and inLdnEntryWin and orbReady and not hasTradedToday and not isExcludedDate and strategy.position_size == 0 and not (longSetupActive or shortSetupActive))

// Long setup arm
if canArmSetup and not longFirstFvgFound and longFVG
    entry   = longFvgTop
    stop    = entry - (ldnStopAtrPct / 100) * nz(dailyATR)
    riskPts = entry - stop

    if riskPts > 0
        qtyRaw = riskUsd / (riskPts * execPointValue)
        qty    = floorToStep(qtyRaw, qtyStep)
        isSingleContract = qty <= minQty
        halfQty = isSingleContract ? qty : floorToStep(qty / 2, qtyStep)
        halfQty := math.max(halfQty, minQty)

        if qty >= minQty
            longStopStored   := stop
            longTargetStored := entry + rr * riskPts
            longHalfwayStored := entry + (rr * riskPts * tp1Ratio)
            longEntryStored  := entry
            longQtyStored    := qty
            longHalfQty      := halfQty
            longSingleContract := isSingleContract
            longSetupActive  := true
            longFirstFvgFound := true
            longSetupBar     := bar_index

// Short setup arm
if canArmSetup and not shortFirstFvgFound and shortFVG
    entry   = shortFvgBottom
    stop    = entry + (ldnStopAtrPct / 100) * nz(dailyATR)
    riskPts = stop - entry

    if riskPts > 0
        qtyRaw = riskUsd / (riskPts * execPointValue)
        qty    = floorToStep(qtyRaw, qtyStep)
        isSingleContract = qty <= minQty
        halfQty = isSingleContract ? qty : floorToStep(qty / 2, qtyStep)
        halfQty := math.max(halfQty, minQty)

        if qty >= minQty
            shortStopStored   := stop
            shortTargetStored := entry - rr * riskPts
            shortHalfwayStored := entry - (rr * riskPts * tp1Ratio)
            shortEntryStored  := entry
            shortQtyStored    := qty
            shortHalfQty      := halfQty
            shortSingleContract := isSingleContract
            shortSetupActive  := true
            shortFirstFvgFound := true
            shortSetupBar     := bar_index

// ----------------------------------------------------------------------------------------
// Track actual entry fill price and active session
// ----------------------------------------------------------------------------------------
if strategy.position_size > 0 and na(longFilledEntry)
    longFilledEntry := strategy.opentrades.entry_price(0)
    activeSession := "ldn"
    fillBar := bar_index
if strategy.position_size < 0 and na(shortFilledEntry)
    shortFilledEntry := strategy.opentrades.entry_price(0)
    activeSession := "ldn"
    fillBar := bar_index

// Reset when flat
if strategy.position_size == 0
    activeSession := na
    tp1Alerted := false

// ----------------------------------------------------------------------------------------
// Update breakeven state (gated on fill bar + 1)
// ----------------------------------------------------------------------------------------
if strategy.position_size > 0 and not na(fillBar) and bar_index > fillBar
    if longSingleContract
        if not na(longHalfwayStored) and high >= longHalfwayStored
            longBEActive := true
    else
        positionReduced = strategy.position_size < longQtyStored and longQtyStored > 0 and not na(longFilledEntry)
        if positionReduced
            longBEActive := true

if strategy.position_size < 0 and not na(fillBar) and bar_index > fillBar
    if shortSingleContract
        if not na(shortHalfwayStored) and low <= shortHalfwayStored
            shortBEActive := true
    else
        positionReduced = math.abs(strategy.position_size) < shortQtyStored and shortQtyStored > 0 and not na(shortFilledEntry)
        if positionReduced
            shortBEActive := true

// ----------------------------------------------------------------------------------------
// Entry orders
// ----------------------------------------------------------------------------------------
if is5m and inLdnRTH and inLdnEntryWin and not hasTradedToday and strategy.position_size == 0
    if longSetupActive and bar_index > longSetupBar
        strategy.entry("LL", strategy.long, qty=longQtyStored, limit=longEntryStored)
    if shortSetupActive and bar_index > shortSetupBar
        strategy.entry("LS", strategy.short, qty=shortQtyStored, limit=shortEntryStored)

// ----------------------------------------------------------------------------------------
// Exit orders (gated on fill bar)
// ----------------------------------------------------------------------------------------
if strategy.position_size > 0 and not na(fillBar) and bar_index >= fillBar
    beStopPrice = (not na(longFilledEntry) ? longFilledEntry : longEntryStored) + beOffset
    finalStop = longBEActive ? beStopPrice : longStopStored

    if longSingleContract
        strategy.exit("LL-F", from_entry="LL", stop=finalStop, limit=longTargetStored, comment_loss=longBEActive ? "l-l-be" : "l-l-sl", comment_profit="l-l-tp2")
    else
        strategy.exit("LL-P", from_entry="LL", qty=longHalfQty, stop=finalStop, limit=longHalfwayStored, comment_loss=longBEActive ? "l-l-be" : "l-l-sl", comment_profit="l-l-tp1")
        strategy.exit("LL-F", from_entry="LL", stop=finalStop, limit=longTargetStored, comment_loss=longBEActive ? "l-l-be" : "l-l-sl", comment_profit="l-l-tp2")

if strategy.position_size < 0 and not na(fillBar) and bar_index >= fillBar
    beStopPrice = (not na(shortFilledEntry) ? shortFilledEntry : shortEntryStored) - beOffset
    finalStop = shortBEActive ? beStopPrice : shortStopStored

    if shortSingleContract
        strategy.exit("LS-F", from_entry="LS", stop=finalStop, limit=shortTargetStored, comment_loss=shortBEActive ? "l-s-be" : "l-s-sl", comment_profit="l-s-tp2")
    else
        strategy.exit("LS-P", from_entry="LS", qty=shortHalfQty, stop=finalStop, limit=shortHalfwayStored, comment_loss=shortBEActive ? "l-s-be" : "l-s-sl", comment_profit="l-s-tp1")
        strategy.exit("LS-F", from_entry="LS", stop=finalStop, limit=shortTargetStored, comment_loss=shortBEActive ? "l-s-be" : "l-s-sl", comment_profit="l-s-tp2")

// ----------------------------------------------------------------------------------------
// Cancel pending orders after cutoff
// ----------------------------------------------------------------------------------------
if ldnAfterCutoff
    if (longSetupActive or shortSetupActive) and strategy.position_size == 0
        alert('{"ticker": "MES", "action": "cancel"}', alert.freq_once_per_bar_close)
    strategy.cancel("LL")
    strategy.cancel("LS")
    longSetupActive := false
    shortSetupActive := false
    longEntryStored := na
    shortEntryStored := na
    longSetupBar := na
    shortSetupBar := na

if not inLdnRTH
    if (longSetupActive or shortSetupActive) and strategy.position_size == 0
        alert('{"ticker": "MES", "action": "cancel"}', alert.freq_once_per_bar_close)
    strategy.cancel("LL")
    strategy.cancel("LS")
    longSetupActive := false
    shortSetupActive := false
    longEntryStored := na
    shortEntryStored := na
    longSetupBar := na
    shortSetupBar := na

// ----------------------------------------------------------------------------------------
// Flat at end of session
// ----------------------------------------------------------------------------------------
if inLdnFlatWin and strategy.position_size != 0
    if strategy.position_size > 0
        strategy.close("LL", comment="ldn-eod-flat")
    if strategy.position_size < 0
        strategy.close("LS", comment="ldn-eod-flat")

// ----------------------------------------------------------------------------------------
// Hidden Plots for TradersPost Webhooks
// ----------------------------------------------------------------------------------------
currentTP1 = strategy.position_size > 0 ? longHalfwayStored : strategy.position_size < 0 ? shortHalfwayStored : na
currentTP2 = strategy.position_size > 0 ? longTargetStored : strategy.position_size < 0 ? shortTargetStored : na
currentStop = strategy.position_size > 0 ? longStopStored : strategy.position_size < 0 ? shortStopStored : na
currentBE = strategy.position_size > 0 ? longFilledEntry + beOffset : strategy.position_size < 0 ? shortFilledEntry - beOffset : na
currentEntry = strategy.position_size > 0 ? longEntryStored : strategy.position_size < 0 ? shortEntryStored : na
currentQty = (longSetupActive and longSetupActive[1] == false) ? longQtyStored : (shortSetupActive and shortSetupActive[1] == false) ? shortQtyStored : strategy.position_size > 0 ? longQtyStored : strategy.position_size < 0 ? shortQtyStored : na
currentHalfQty = strategy.position_size > 0 ? longHalfQty : strategy.position_size < 0 ? shortHalfQty : na
currentSingleContract = strategy.position_size > 0 ? longSingleContract : strategy.position_size < 0 ? shortSingleContract : false

setupEntry = (longSetupActive and longSetupActive[1] == false) ? longEntryStored : (shortSetupActive and shortSetupActive[1] == false) ? shortEntryStored : na
setupStop = (longSetupActive and longSetupActive[1] == false) ? longStopStored : (shortSetupActive and shortSetupActive[1] == false) ? shortStopStored : na
setupTP1 = (longSetupActive and longSetupActive[1] == false) ? longHalfwayStored : (shortSetupActive and shortSetupActive[1] == false) ? shortHalfwayStored : na
setupTP2 = (longSetupActive and longSetupActive[1] == false) ? longTargetStored : (shortSetupActive and shortSetupActive[1] == false) ? shortTargetStored : na
setupSingleContract = (longSetupActive and longSetupActive[1] == false) ? longSingleContract : (shortSetupActive and shortSetupActive[1] == false) ? shortSingleContract : false

plot(currentTP1, "TP1", display=display.none)
plot(currentTP2, "TP2", display=display.none)
plot(currentStop, "StopLoss", display=display.none)
plot(currentBE, "BreakevenPrice", display=display.none)
plot(currentEntry, "Entry", display=display.none)
plot(currentQty, "Quantity", display=display.none)
plot(currentHalfQty, "HalfQuantity", display=display.none)
plot(setupEntry, "SetupEntry", display=display.none)
plot(setupStop, "SetupStop", display=display.none)
plot(setupTP1, "SetupTP1", display=display.none)
plot(setupTP2, "SetupTP2", display=display.none)

// ----------------------------------------------------------------------------------------
// Alert Conditions for TradersPost
// ----------------------------------------------------------------------------------------
longEntrySignal = (longSetupActive and longSetupActive[1] == false)
shortEntrySignal = (shortSetupActive and shortSetupActive[1] == false)

// TP1 hit - fire on live touch or position reduction (position still open)
// Gate on fill bar + 1 to prevent same-bar entry + TP1 exit
positionMature = not na(fillBar) and bar_index > fillBar

tp1TouchLong = strategy.position_size > 0 and not na(currentTP1) and high >= currentTP1 and positionMature
tp1TouchShort = strategy.position_size < 0 and not na(currentTP1) and low <= currentTP1 and positionMature
tp1HitLong = (strategy.position_size > 0 and not currentSingleContract and not tp1Alerted and positionMature) and (
    (strategy.position_size < strategy.position_size[1]) or tp1TouchLong
)
tp1HitShort = (strategy.position_size < 0 and not currentSingleContract and not tp1Alerted and positionMature) and (
    (math.abs(strategy.position_size) < math.abs(strategy.position_size[1])) or tp1TouchShort
)
tp1HitSingleLong = (strategy.position_size > 0 and currentSingleContract and not tp1Alerted and positionMature) and tp1TouchLong
tp1HitSingleShort = (strategy.position_size < 0 and currentSingleContract and not tp1Alerted and positionMature) and tp1TouchShort

if longEntrySignal
    alert('{"ticker": "MES", "action": "exit"}', alert.freq_once_per_bar_close)
    if setupSingleContract
        alert('{"ticker": "MES", "action": "buy", "quantity": ' + str.tostring(currentQty) + ', "price": ' + str.tostring(setupEntry) + ', "takeProfit": {"limitPrice": ' + str.tostring(setupTP2) + '}, "stopLoss": {"type": "stop", "stopPrice": ' + str.tostring(setupStop) + '}, "delay": 3}', alert.freq_once_per_bar_close)
    else
        alert('{"ticker": "MES", "action": "buy", "quantity": ' + str.tostring(currentQty) + ', "price": ' + str.tostring(setupEntry) + ', "takeProfit": {"limitPrice": ' + str.tostring(setupTP2) + '}, "stopLoss": {"type": "stop", "stopPrice": ' + str.tostring(setupStop) + '}, "delay": 3}', alert.freq_once_per_bar_close)
if shortEntrySignal
    alert('{"ticker": "MES", "action": "exit"}', alert.freq_once_per_bar_close)
    if setupSingleContract
        alert('{"ticker": "MES", "action": "sell", "quantity": ' + str.tostring(currentQty) + ', "price": ' + str.tostring(setupEntry) + ', "takeProfit": {"limitPrice": ' + str.tostring(setupTP2) + '}, "stopLoss": {"type": "stop", "stopPrice": ' + str.tostring(setupStop) + '}, "delay": 3}', alert.freq_once_per_bar_close)
    else
        alert('{"ticker": "MES", "action": "sell", "quantity": ' + str.tostring(currentQty) + ', "price": ' + str.tostring(setupEntry) + ', "takeProfit": {"limitPrice": ' + str.tostring(setupTP2) + '}, "stopLoss": {"type": "stop", "stopPrice": ' + str.tostring(setupStop) + '}, "delay": 3}', alert.freq_once_per_bar_close)
if tp1HitLong
    alert('{"ticker": "MES", "action": "exit", "quantity": ' + str.tostring(currentHalfQty) + '}', alert.freq_once_per_bar)
    alert('{"ticker": "MES", "action": "sell", "orderType": "stop", "stopPrice": ' + str.tostring(currentBE) + ', "quantity": ' + str.tostring(currentHalfQty) + ', "sentiment": "flat", "delay": 3}', alert.freq_once_per_bar)
    alert('{"ticker": "MES", "action": "sell", "orderType": "limit", "limitPrice": ' + str.tostring(currentTP2) + ', "quantity": ' + str.tostring(currentHalfQty) + ', "sentiment": "flat", "cancel": false, "delay": 5}', alert.freq_once_per_bar)
    tp1Alerted := true
if tp1HitShort
    alert('{"ticker": "MES", "action": "exit", "quantity": ' + str.tostring(currentHalfQty) + '}', alert.freq_once_per_bar)
    alert('{"ticker": "MES", "action": "buy", "orderType": "stop", "stopPrice": ' + str.tostring(currentBE) + ', "quantity": ' + str.tostring(currentHalfQty) + ', "sentiment": "flat", "delay": 3}', alert.freq_once_per_bar)
    alert('{"ticker": "MES", "action": "buy", "orderType": "limit", "limitPrice": ' + str.tostring(currentTP2) + ', "quantity": ' + str.tostring(currentHalfQty) + ', "sentiment": "flat", "cancel": false, "delay": 5}', alert.freq_once_per_bar)
    tp1Alerted := true
if tp1HitSingleLong
    alert('{"ticker": "MES", "action": "sell", "orderType": "stop", "stopPrice": ' + str.tostring(currentBE) + ', "quantity": ' + str.tostring(currentQty) + ', "sentiment": "flat", "delay": 3}', alert.freq_once_per_bar)
    tp1Alerted := true
if tp1HitSingleShort
    alert('{"ticker": "MES", "action": "buy", "orderType": "stop", "stopPrice": ' + str.tostring(currentBE) + ', "quantity": ' + str.tostring(currentQty) + ', "sentiment": "flat", "delay": 3}', alert.freq_once_per_bar)
    tp1Alerted := true

// ----------------------------------------------------------------------------------------
// Final exit alert - flatten and cancel remaining orders
// ----------------------------------------------------------------------------------------
flatNow = prevPos != 0 and strategy.position_size == 0
if flatNow
    alert('{"ticker": "MES", "action": "exit"}', alert.freq_once_per_bar)

prevPos := strategy.position_size

// ----------------------------------------------------------------------------------------
// EOD Flat Alert
// ----------------------------------------------------------------------------------------
if inLdnFlatWin and strategy.position_size != 0
    alert('{"ticker": "MES", "action": "exit"}', alert.freq_once_per_bar_close)

// ----------------------------------------------------------------------------------------
// Visuals - ORB Lines
// ----------------------------------------------------------------------------------------
plotLdnORB = inLdnRTH and inLdnEntryWin
plot(plotLdnORB ? orbHigh : na, "LDN ORB High", style=plot.style_linebr, linewidth=2, color=color.new(#FF9800, 0))
plot(plotLdnORB ? orbLow  : na, "LDN ORB Low",  style=plot.style_linebr, linewidth=2, color=color.new(#FFB74D, 0))
